#!/usr/bin/env bash
# sgt-watch — Monitor a dispatched fleet and report outcomes
#
# Watches the status files written by worker agents into the fleet directory.
# Workers report status, escalation messages, and results in their worktrees;
# sgt-watch mirrors those files back to fleet state on each poll.
#
# Usage:
#   sgt-watch <task-id>              # watch a specific task
#   sgt-watch --list                 # list all known tasks
#   sgt-watch --sync <task-id>       # one-shot sync worktree → fleet state, then exit
#
# Workers write:
#   <worktree>/.sergeant-status    → in_progress, needs_input, blocked, done, failed
#   <worktree>/.sergeant-message   → escalation context, evidence, and question
#   <worktree>/.sergeant-result    → PR URL or report path
#
# Fleet state mirrors:
#   ~/.local/share/sergeant/fleet/<task-id>/<repo>/status
#   ~/.local/share/sergeant/fleet/<task-id>/<repo>/message
#   ~/.local/share/sergeant/fleet/<task-id>/<repo>/result

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FLEET_DIR="${SERGEANT_FLEET:-$HOME/.local/share/sergeant/fleet}"
POLL_INTERVAL="${SERGEANT_WATCH_INTERVAL:-5}"  # seconds

_die() { echo "ERROR: $*" >&2; exit 1; }

# ── --list mode ───────────────────────────────────────────────────────────────

if [[ "${1:-}" == "--list" ]]; then
  if [[ ! -d "$FLEET_DIR" ]] || [[ -z "$(ls -A "$FLEET_DIR" 2>/dev/null)" ]]; then
    echo "No tasks found in $FLEET_DIR"
    exit 0
  fi
  echo "Active tasks:"
  echo ""
  for task_dir in "$FLEET_DIR"/*/; do
    task_id="$(basename "$task_dir")"
    started="$(cat "$task_dir/started" 2>/dev/null || echo "unknown")"
    brief="$(grep '^Brief:' "$task_dir/brief.md" 2>/dev/null | sed 's/^Brief: *//' | cut -c1-60 || echo "")"

    # Count repo statuses
    total=0; done_count=0; failed_count=0; in_progress=0; needs_input=0; blocked=0; orphaned=0
    for repo_dir in "$task_dir"/*/; do
      [[ -d "$repo_dir" ]] || continue
      total=$((total+1))
      s="$(cat "$repo_dir/status" 2>/dev/null || echo "unknown")"
      case "$s" in
        done)        done_count=$((done_count+1)) ;;
        failed*)     failed_count=$((failed_count+1)) ;;
        in_progress) in_progress=$((in_progress+1)) ;;
        needs_input) needs_input=$((needs_input+1)) ;;
        blocked)     blocked=$((blocked+1)) ;;
        orphaned)    orphaned=$((orphaned+1)) ;;
      esac
    done

    echo "  $task_id"
    echo "    brief:   $brief"
    echo "    started: $started"
    echo "    repos:   $total total — $done_count done, $in_progress in-progress, $needs_input needs-input, $blocked blocked, $orphaned orphaned, $failed_count failed"
    echo ""
  done
  exit 0
fi

# ── --sync mode ───────────────────────────────────────────────────────────────

_pane_is_supervisor() {
  local pane="$1"
  local repo_dir="${2%/}"
  local pane_info pane_dead pane_command
  pane_info="$(tmux display-message -p -t "$pane" '#{pane_dead}|#{pane_start_command}' 2>/dev/null)" || return 1
  pane_dead="${pane_info%%|*}"
  pane_command="${pane_info#*|}"
  [[ "$pane_dead" == "0" && "$pane_command" == *sgt-worker* && "$pane_command" == *"$repo_dir"* ]]
}

_remote_logs() {
  local session="$1"
  local window="$2"
  if ! command -v babydriver >/dev/null 2>&1; then
    return 0
  fi
  babydriver logs "$session" --window "$window" -n 40 2>/dev/null || true
}

_parse_babydriver_status() {
  local window="$1"
  local payload
  payload="$(cat)"
  python3 - "$window" "$payload" <<'PY'
import json
import sys

window = sys.argv[1]
payload = json.loads(sys.argv[2])

def as_dict(value):
    return value if isinstance(value, dict) else {}

def as_list(value):
    return value if isinstance(value, list) else []

def as_string(value):
    return value if isinstance(value, str) else ""

session_value = payload.get("session")
session = as_dict(session_value)
tasks = as_list(payload.get("tasks"))
if not tasks:
    tasks = as_list(session.get("tasks"))

task = {}
matched = "0"
for candidate in tasks:
    candidate = as_dict(candidate)
    candidate_window = str(candidate.get("window") or candidate.get("name") or candidate.get("slug") or "")
    if candidate_window == window:
        task = candidate
        matched = "1"
        break

tmux_alive = payload.get("tmux_alive")
if tmux_alive is None:
    tmux_alive = session.get("tmux_alive")
if tmux_alive is None:
    tmux_alive = True

status = str(
    task.get("sergeant_status")
    or task.get("status")
    or task.get("state")
    or task.get("td_status")
    or payload.get("status")
    or ""
)
result = str(
    task.get("result")
    or task.get("result_url")
    or task.get("pr_url")
    or payload.get("result")
    or payload.get("result_url")
    or payload.get("pr_url")
    or ""
)
message = str(
    task.get("message")
    or task.get("summary")
    or payload.get("message")
    or payload.get("summary")
    or ""
)
diagnostic = str(
    task.get("diagnostic")
    or task.get("error")
    or payload.get("diagnostic")
    or payload.get("error")
    or ""
)
task_id = str(task.get("task_id") or task.get("td_task_id") or task.get("id") or "")

print("1" if tmux_alive else "0")
print(status)
print(result)
print(message)
print(diagnostic)
print(task_id)
print(matched)
PY
}

_map_remote_status() {
  local raw_status="$1"
  case "${raw_status,,}" in
    done|closed|complete|completed|success|succeeded) printf 'done\n' ;;
    in_review) printf 'in_progress\n' ;;
    failed|failure|error|errored|cancelled|canceled) printf 'failed: remote execution failed\n' ;;
    needs_input|needs-input|awaiting_input|awaiting-input) printf 'needs_input\n' ;;
    blocked|waiting|paused) printf 'blocked\n' ;;
    orphaned) printf 'orphaned\n' ;;
    ""|queued|open|started|running|in_progress|in-progress|active|dispatched) printf 'in_progress\n' ;;
    *) printf '%s\n' "$raw_status" ;;
  esac
}

_sync_remote_repo() {
  local repo_dir="$1"
  local worktree session window status_output remote_logs
  local remote_fields=() tmux_alive raw_status mapped_status result message diagnostic task_id matched
  worktree="$(cat "$repo_dir/worktree" 2>/dev/null || echo "")"
  session="$(cat "$repo_dir/remote_session" 2>/dev/null || true)"
  window="$(cat "$repo_dir/remote_window" 2>/dev/null || true)"

  if [[ -z "$session" || -z "$window" ]]; then
    [[ -n "$worktree" ]] && printf 'orphaned\n' > "$worktree/.sergeant-status"
    printf 'orphaned\n' > "$repo_dir/status"
    printf 'remote dispatch metadata is incomplete\n' > "$repo_dir/diagnostic"
    [[ -n "$worktree" ]] && "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_dir" "$worktree" || true
    return
  fi

  if ! command -v babydriver >/dev/null 2>&1; then
    [[ -n "$worktree" ]] && printf 'orphaned\n' > "$worktree/.sergeant-status"
    printf 'orphaned\n' > "$repo_dir/status"
    printf 'babydriver is unavailable for remote fleet sync\n' > "$repo_dir/diagnostic"
    [[ -n "$worktree" ]] && "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_dir" "$worktree" || true
    return
  fi

  if ! status_output="$(babydriver status "$session" 2>&1)"; then
    remote_logs="$(_remote_logs "$session" "$window")"
    {
      printf 'babydriver status failed for %s\n' "$session"
      printf '%s\n' "$status_output"
      [[ -z "$remote_logs" ]] || {
        printf 'logs:\n'
        printf '%s\n' "$remote_logs"
      }
    } > "$repo_dir/diagnostic"
    [[ -n "$worktree" ]] && printf 'orphaned\n' > "$worktree/.sergeant-status"
    printf 'orphaned\n' > "$repo_dir/status"
    [[ -n "$worktree" ]] && "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_dir" "$worktree" || true
    return
  fi

  while IFS= read -r parsed_line; do
    remote_fields+=("$parsed_line")
  done < <(printf '%s' "$status_output" | _parse_babydriver_status "$window" 2>/dev/null || true)
  if [[ "${#remote_fields[@]}" -lt 7 ]]; then
    {
      printf 'babydriver status returned invalid JSON for %s\n' "$session"
      printf '%s\n' "$status_output"
    } > "$repo_dir/diagnostic"
    [[ -n "$worktree" ]] && printf 'orphaned\n' > "$worktree/.sergeant-status"
    printf 'orphaned\n' > "$repo_dir/status"
    [[ -n "$worktree" ]] && "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_dir" "$worktree" || true
    return
  fi

  tmux_alive="${remote_fields[0]}"
  raw_status="${remote_fields[1]}"
  mapped_status="$(_map_remote_status "$raw_status")"
  result="${remote_fields[2]}"
  message="${remote_fields[3]}"
  diagnostic="${remote_fields[4]}"
  task_id="${remote_fields[5]}"
  matched="${remote_fields[6]}"
  [[ -n "$task_id" ]] && printf '%s\n' "$task_id" > "$repo_dir/remote_td_task"

  if [[ "$matched" != "1" ]]; then
    {
      printf 'requested remote task window %s was not found in babydriver status\n' "$window"
      printf '%s\n' "$status_output"
    } > "$repo_dir/diagnostic"
    [[ -n "$worktree" ]] && printf 'orphaned\n' > "$worktree/.sergeant-status"
    printf 'orphaned\n' > "$repo_dir/status"
    [[ -n "$worktree" ]] && "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_dir" "$worktree" || true
    return
  fi

  case "$mapped_status" in
    done|failed:*)
      if [[ -n "$result" ]]; then
        printf '%s\n' "$result" > "$repo_dir/result"
      else
        rm -f "$repo_dir/result"
      fi
      ;;
    *) rm -f "$repo_dir/result" ;;
  esac

  if [[ -n "$message" ]]; then
    printf '%s\n' "$message" > "$repo_dir/message"
  else
    rm -f "$repo_dir/message"
  fi

  remote_logs=""
  if [[ "$mapped_status" == "blocked" || "$mapped_status" == "needs_input" || "$mapped_status" == orphaned || "$mapped_status" == failed:* ]]; then
    remote_logs="$(_remote_logs "$session" "$window")"
  fi
  if [[ "${raw_status,,}" == "in_review" && -z "$message" ]]; then
    message="Remote worker is in_review; completion gates are still pending."
    printf '%s\n' "$message" > "$repo_dir/message"
  fi

  if [[ "$mapped_status" == "done" && -z "$result" ]]; then
    diagnostic="${diagnostic:-remote terminal status requires a result}"
    mapped_status="orphaned"
  elif [[ "$tmux_alive" != "1" && "$mapped_status" != "done" && "$mapped_status" != failed:* ]]; then
    diagnostic="${diagnostic:-remote worker session is not alive; resume with sgt-respond}"
    mapped_status="orphaned"
  fi

  if [[ -n "$diagnostic" || -n "$remote_logs" ]]; then
    {
      [[ -z "$diagnostic" ]] || printf '%s\n' "$diagnostic"
      [[ -z "$remote_logs" ]] || {
        printf 'logs:\n'
        printf '%s\n' "$remote_logs"
      }
    } > "$repo_dir/diagnostic"
  else
    rm -f "$repo_dir/diagnostic"
  fi

  [[ -n "$worktree" ]] && printf '%s\n' "$mapped_status" > "$worktree/.sergeant-status"
  printf '%s\n' "$mapped_status" > "$repo_dir/status"
  if [[ "$mapped_status" == "orphaned" && -n "$worktree" ]]; then
    "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_dir" "$worktree" || true
  fi
}

_sync_task() {
  local task_id="$1"
  local task_dir="$FLEET_DIR/$task_id"
  [[ -d "$task_dir" ]] || _die "Task not found: $task_id (looked in $FLEET_DIR)"

  for repo_dir in "$task_dir"/*/; do
    [[ -d "$repo_dir" ]] || continue
    local repo_name worktree wt_status fleet_status pane backend
    repo_name="$(basename "$repo_dir")"
    backend="$(cat "$repo_dir/backend" 2>/dev/null || echo "local-tmux")"
    if [[ "$backend" == "remote-babydriver" ]]; then
      _sync_remote_repo "$repo_dir"
      continue
    fi
    worktree="$(cat "$repo_dir/worktree" 2>/dev/null || echo "")"
    [[ -n "$worktree" ]] || continue

    # Sync .sergeant-status from worktree → fleet
    if [[ -f "$worktree/.sergeant-status" ]]; then
      wt_status="$(tr -d '\n' < "$worktree/.sergeant-status")"
      fleet_status="$(cat "$repo_dir/status" 2>/dev/null || echo "")"
      if [[ "$wt_status" != "$fleet_status" ]]; then
        echo "$wt_status" > "$repo_dir/status"
      fi
    fi

    if [[ -f "$worktree/.sergeant-status" ]]; then
      wt_status="$(tr -d '\n' < "$worktree/.sergeant-status")"
    else
      wt_status="${fleet_status:-in_progress}"
    fi

    # Results are valid only for terminal work; retries must not retain stale output.
    case "$wt_status" in
      done|failed:*)
        if [[ -f "$worktree/.sergeant-result" ]]; then
          cp "$worktree/.sergeant-result" "$repo_dir/result" 2>/dev/null || true
        else
          rm -f "$repo_dir/result"
        fi
        ;;
      *) rm -f "$repo_dir/result" ;;
    esac

    # Sync escalation context independently so message-only updates are visible.
    if [[ -f "$worktree/.sergeant-message" ]]; then
      cp "$worktree/.sergeant-message" "$repo_dir/message" 2>/dev/null || true
    else
      rm -f "$repo_dir/message"
    fi

    if [[ "$wt_status" == "done" && ! -s "$worktree/.sergeant-result" ]]; then
      printf 'orphaned\n' > "$worktree/.sergeant-status"
      printf 'orphaned\n' > "$repo_dir/status"
      printf 'terminal status done requires result\n' > "$repo_dir/diagnostic"
      "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_dir" "$worktree" || true
      continue
    fi

    case "$wt_status" in
      in_progress|needs_input|blocked|dispatched)
        pane="$(cat "$repo_dir/pane" 2>/dev/null || true)"
        if [[ -n "$pane" ]] && command -v tmux >/dev/null 2>&1 && \
            ! _pane_is_supervisor "$pane" "$repo_dir"; then
          printf 'orphaned\n' > "$worktree/.sergeant-status"
          printf 'orphaned\n' > "$repo_dir/status"
          printf 'recorded pane %s is dead or is not the expected worker supervisor; resume with sgt-respond\n' "$pane" > "$repo_dir/diagnostic"
          "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_dir" "$worktree" || true
        fi
        ;;
    esac
  done
}

if [[ "${1:-}" == "--sync" ]]; then
  [[ $# -ge 2 ]] || _die "Usage: sgt-watch --sync <task-id>"
  _sync_task "$2"
  exit 0
fi

# ── Watch mode ────────────────────────────────────────────────────────────────

[[ $# -ge 1 ]] || _die "Usage: sgt-watch <task-id>"
TASK_ID="$1"
TASK_DIR="$FLEET_DIR/$TASK_ID"
[[ -d "$TASK_DIR" ]] || _die "Task not found: $TASK_ID (looked in $FLEET_DIR)"

brief_line="$(grep '^Brief:' "$TASK_DIR/brief.md" 2>/dev/null | sed 's/^Brief: *//' || echo "$TASK_ID")"

echo "=== sgt-watch: $brief_line ==="
echo "task: $TASK_ID"
echo "fleet: $TASK_DIR"
echo "polling every ${POLL_INTERVAL}s — Ctrl-C to detach"
echo ""

_print_status() {
  local task_dir="$1"
  local all_terminal=true
  local any_failed=false

  for repo_dir in "$task_dir"/*/; do
    [[ -d "$repo_dir" ]] || continue
    repo_name="$(basename "$repo_dir")"
    status="$(cat "$repo_dir/status" 2>/dev/null || echo "unknown")"
    result="$(cat "$repo_dir/result" 2>/dev/null || echo "")"
    message="$(cat "$repo_dir/message" 2>/dev/null || echo "")"
    diagnostic="$(cat "$repo_dir/diagnostic" 2>/dev/null || echo "")"

    case "$status" in
      done)
        icon="✓"
        ;;
      failed*)
        icon="✗"
        any_failed=true
        ;;
      orphaned)
        icon="✗"
        any_failed=true
        ;;
      needs_input)
        icon="?"
        all_terminal=false
        ;;
      blocked)
        icon="!"
        all_terminal=false
        ;;
      in_progress|dispatched)
        icon="…"
        all_terminal=false
        ;;
      *)
        icon="·"
        all_terminal=false
        ;;
    esac

    printf "  %s  %-20s  %s\n" "$icon" "$repo_name" "$status"
    if [[ -n "$result" ]]; then
      printf "       %-20s  → %s\n" "" "$result"
    fi
    if [[ -n "$message" ]]; then
      while IFS= read -r message_line; do
        printf "       %-20s  %s\n" "" "$message_line"
      done <<< "$message"
    fi
    if [[ -n "$diagnostic" ]]; then
      while IFS= read -r diagnostic_line; do
        printf "       %-20s  %s\n" "" "$diagnostic_line"
      done <<< "$diagnostic"
    fi
  done

  echo ""
  if $any_failed; then
    return 2
  fi
  if $all_terminal; then
    return 0
  fi
  return 1
}

declare -A LAST_STATUS=()

while true; do
  _sync_task "$TASK_ID"

  # Check if status changed — only reprint when something changes
  current_snapshot=""
  for repo_dir in "$TASK_DIR"/*/; do
    [[ -d "$repo_dir" ]] || continue
    repo_name="$(basename "$repo_dir")"
    status="$(cat "$repo_dir/status" 2>/dev/null || echo "unknown")"
    message="$(cat "$repo_dir/message" 2>/dev/null || echo "")"
    current_snapshot+="$repo_name:$status:$message "
  done

  if [[ "${LAST_STATUS[snapshot]+x}" == "" || "${LAST_STATUS[snapshot]}" != "$current_snapshot" ]]; then
    LAST_STATUS[snapshot]="$current_snapshot"
    date '+%H:%M:%S'
    if _print_status "$TASK_DIR"; then
      echo "All repos done."
      echo ""
      # Print final results
      any_results=false
      for repo_dir in "$TASK_DIR"/*/; do
        result="$(cat "$repo_dir/result" 2>/dev/null || echo "")"
        if [[ -n "$result" ]]; then
          repo_name="$(basename "$repo_dir")"
          echo "  $repo_name: $result"
          any_results=true
        fi
      done
      $any_results && echo ""
      exit 0
    else
      print_status=$?
      if [[ "$print_status" -eq 2 ]]; then
        echo "Fleet finished with failures."
        exit 1
      fi
    fi
  fi

  sleep "$POLL_INTERVAL"
done
