#!/usr/bin/env bash
# sgt-watch - Monitor a dispatched fleet and report outcomes.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_sgt-lib.sh
source "$SCRIPT_DIR/_sgt-lib.sh"
FLEET_DIR="${SERGEANT_FLEET:-$FLEET_DIR}"
POLL_INTERVAL="${SERGEANT_WATCH_INTERVAL:-5}"

_die() { echo "ERROR: $*" >&2; exit 1; }

if [[ "${1:-}" == "--list" ]]; then
  if [[ ! -d "$FLEET_DIR" ]] || [[ -z "$(ls -A "$FLEET_DIR" 2>/dev/null)" ]]; then
    echo "No tasks found in $FLEET_DIR"
    exit 0
  fi
  echo "Active tasks:"
  echo ""
  for task_dir in "$FLEET_DIR"/*/; do
    task_id="$(basename "$task_dir")"
    started="$(cat "$task_dir/started" 2>/dev/null || echo "unknown")"
    brief="$(grep '^Brief:' "$task_dir/brief.md" 2>/dev/null | sed 's/^Brief: *//' | cut -c1-60 || echo "")"
    total=0; done_count=0; failed_count=0; in_progress=0; needs_input=0; blocked=0; orphaned=0
    for repo_dir in "$task_dir"/*/; do
      [[ -d "$repo_dir" ]] || continue
      total=$((total + 1))
      status="$(cat "$repo_dir/status" 2>/dev/null || echo "unknown")"
      case "$status" in
        done) done_count=$((done_count + 1)) ;;
        failed*) failed_count=$((failed_count + 1)) ;;
        in_progress) in_progress=$((in_progress + 1)) ;;
        needs_input) needs_input=$((needs_input + 1)) ;;
        blocked) blocked=$((blocked + 1)) ;;
        orphaned) orphaned=$((orphaned + 1)) ;;
      esac
    done
    echo "  $task_id"
    echo "    brief:   $brief"
    echo "    started: $started"
    echo "    repos:   $total total - $done_count done, $in_progress in-progress, $needs_input needs-input, $blocked blocked, $orphaned orphaned, $failed_count failed"
    echo ""
  done
  exit 0
fi

_pane_is_supervisor() {
  local pane="$1"
  local repo_dir="${2%/}"
  local actual agent command created pane_id pane_pid remainder worktree

  if [[ -s "$repo_dir/pane_identity" ]]; then
    _sgt_pane_identity_matches "$pane" "$repo_dir"
    return
  fi

  actual="$(_sgt_pane_identity "$pane")" || return 1
  remainder="${actual#*|}"
  pane_id="${remainder%%|*}"
  remainder="${remainder#*|}"
  pane_pid="${remainder%%|*}"
  remainder="${remainder#*|}"
  created="${remainder%%|*}"
  command="${remainder#*|}"
  worktree="$(cat "$repo_dir/worktree" 2>/dev/null || true)"
  agent="$(cat "$repo_dir/agent" 2>/dev/null || true)"
  [[ "${actual%%|*}" == 0 && "$pane_id" == "$pane" &&
     "$pane_pid" =~ ^[1-9][0-9]*$ && "$created" =~ ^[1-9][0-9]*$ &&
     -n "$worktree" && -n "$agent" &&
     "$command" == *sgt-interactive-worker* &&
     "$command" == *"$repo_dir"* && "$command" == *"$worktree"* &&
     "$command" == *"$agent"* ]] || return 1

  printf '%s\n' "$actual" > "$repo_dir/pane_identity_migration.tmp.$$" || return 1
  mv "$repo_dir/pane_identity_migration.tmp.$$" "$repo_dir/pane_identity_migration" || return 1
  printf '%s\n' "$actual" > "$repo_dir/pane_identity.tmp.$$" || return 1
  mv "$repo_dir/pane_identity.tmp.$$" "$repo_dir/pane_identity" || return 1
}

_sync_task() {
  local task_id="$1"
  local task_dir="$FLEET_DIR/$task_id"
  [[ -d "$task_dir" ]] || _die "Task not found: $task_id (looked in $FLEET_DIR)"

  for repo_dir in "$task_dir"/*/; do
    [[ -d "$repo_dir" ]] || continue
    local worktree wt_status fleet_status pane
    worktree="$(cat "$repo_dir/worktree" 2>/dev/null || echo "")"
    [[ -n "$worktree" ]] || continue

    fleet_status="$(cat "$repo_dir/status" 2>/dev/null || echo "")"
    if [[ -f "$worktree/.sergeant-status" ]]; then
      wt_status="$(tr -d '\n' < "$worktree/.sergeant-status")"
      if [[ "$wt_status" != "$fleet_status" ]]; then
        echo "$wt_status" > "$repo_dir/status"
      fi
    else
      wt_status="${fleet_status:-in_progress}"
    fi

    case "$wt_status" in
      done|failed:*)
        if [[ -f "$worktree/.sergeant-result" ]]; then
          cp "$worktree/.sergeant-result" "$repo_dir/result" 2>/dev/null || true
        else
          rm -f "$repo_dir/result"
        fi
        ;;
      *) rm -f "$repo_dir/result" ;;
    esac

    if [[ -f "$worktree/.sergeant-message" ]]; then
      cp "$worktree/.sergeant-message" "$repo_dir/message" 2>/dev/null || true
    else
      rm -f "$repo_dir/message"
    fi

    if [[ "$wt_status" == "done" && ! -s "$worktree/.sergeant-result" ]]; then
      printf 'orphaned\n' > "$worktree/.sergeant-status"
      printf 'orphaned\n' > "$repo_dir/status"
      printf 'terminal status done requires result\n' > "$repo_dir/diagnostic"
      "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_dir" "$worktree" || true
      continue
    fi

    case "$wt_status" in
      in_progress|dispatched)
        pane="$(cat "$repo_dir/pane" 2>/dev/null || true)"
        if [[ -n "$pane" ]] && command -v tmux >/dev/null 2>&1 && \
            ! _pane_is_supervisor "$pane" "$repo_dir"; then
          printf 'orphaned\n' > "$worktree/.sergeant-status"
          printf 'orphaned\n' > "$repo_dir/status"
          printf 'recorded pane %s is dead or is not the expected worker supervisor; resume with sgt-respond\n' "$pane" > "$repo_dir/diagnostic"
          "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_dir" "$worktree" || true
        fi
        ;;
    esac
  done
}

if [[ "${1:-}" == "--sync" ]]; then
  [[ $# -ge 2 ]] || _die "Usage: sgt-watch --sync <task-id>"
  _sync_task "$2"
  exit 0
fi

[[ $# -ge 1 ]] || _die "Usage: sgt-watch <task-id>"
TASK_ID="$1"
TASK_DIR="$FLEET_DIR/$TASK_ID"
[[ -d "$TASK_DIR" ]] || _die "Task not found: $TASK_ID (looked in $FLEET_DIR)"

brief_line="$(grep '^Brief:' "$TASK_DIR/brief.md" 2>/dev/null | sed 's/^Brief: *//' || echo "$TASK_ID")"
echo "=== sgt-watch: $brief_line ==="
echo "task: $TASK_ID"
echo "fleet: $TASK_DIR"
echo "polling every ${POLL_INTERVAL}s — Ctrl-C to detach"
echo ""

_print_status() {
  local task_dir="$1"
  local all_terminal=true
  local any_failed=false

  for repo_dir in "$task_dir"/*/; do
    [[ -d "$repo_dir" ]] || continue
    repo_name="$(basename "$repo_dir")"
    status="$(cat "$repo_dir/status" 2>/dev/null || echo "unknown")"
    result="$(cat "$repo_dir/result" 2>/dev/null || echo "")"
    message="$(cat "$repo_dir/message" 2>/dev/null || echo "")"
    diagnostic="$(cat "$repo_dir/diagnostic" 2>/dev/null || echo "")"
    stage="$(cat "$repo_dir/stage" 2>/dev/null || echo "implementation")"
    validation_status="$(cat "$repo_dir/validation_status" 2>/dev/null || echo "")"

    case "$status" in
      done) icon="✓" ;;
      failed*|orphaned) icon="✗"; any_failed=true ;;
      needs_input) icon="?"; all_terminal=false ;;
      blocked) icon="!"; all_terminal=false ;;
      in_progress|dispatched) icon="…"; all_terminal=false ;;
      *) icon="·"; all_terminal=false ;;
    esac

    printf "  %s  %-20s  %s  [stage=%s" "$icon" "$repo_name" "$status" "$stage"
    [[ -z "$validation_status" ]] || printf " validation=%s" "$validation_status"
    printf "]\n"
    [[ -z "$result" ]] || printf "       %-20s  → %s\n" "" "$result"
    if [[ -n "$message" ]]; then
      while IFS= read -r line; do printf "       %-20s  %s\n" "" "$line"; done <<< "$message"
    fi
    if [[ -n "$diagnostic" ]]; then
      while IFS= read -r line; do printf "       %-20s  %s\n" "" "$line"; done <<< "$diagnostic"
    fi
  done

  echo ""
  $any_failed && return 2
  $all_terminal && return 0
  return 1
}

LAST_SNAPSHOT=""
HAVE_SNAPSHOT=false
while true; do
  _sync_task "$TASK_ID"
  current_snapshot=""
  for repo_dir in "$TASK_DIR"/*/; do
    [[ -d "$repo_dir" ]] || continue
    repo_name="$(basename "$repo_dir")"
    status="$(cat "$repo_dir/status" 2>/dev/null || echo "unknown")"
    message="$(cat "$repo_dir/message" 2>/dev/null || echo "")"
    stage="$(cat "$repo_dir/stage" 2>/dev/null || echo "implementation")"
    validation_status="$(cat "$repo_dir/validation_status" 2>/dev/null || echo "")"
    current_snapshot+="$repo_name:$status:$stage:$validation_status:$message "
  done

  if ! $HAVE_SNAPSHOT || [[ "$LAST_SNAPSHOT" != "$current_snapshot" ]]; then
    LAST_SNAPSHOT="$current_snapshot"
    HAVE_SNAPSHOT=true
    date '+%H:%M:%S'
    if _print_status "$TASK_DIR"; then
      echo "All repos done."
      echo ""
      any_results=false
      for repo_dir in "$TASK_DIR"/*/; do
        result="$(cat "$repo_dir/result" 2>/dev/null || echo "")"
        if [[ -n "$result" ]]; then
          echo "  $(basename "$repo_dir"): $result"
          any_results=true
        fi
      done
      $any_results && echo ""
      exit 0
    else
      print_status=$?
      if [[ "$print_status" -eq 2 ]]; then
        echo "Fleet finished with failures."
        exit 1
      fi
    fi
  fi
  sleep "$POLL_INTERVAL"
done
