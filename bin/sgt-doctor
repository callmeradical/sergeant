#!/usr/bin/env bash
set -u

FORMAT=human
PROJECT=""

redact() {
  printf '%s' "$1" | sed -E \
    -e 's#(https?://)[^/@[:space:]]+@#\1[REDACTED]@#g' \
    -e 's#([Tt][Oo][Kk][Ee][Nn]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])[[:space:]]*[=:][[:space:]]*.*#\1=[REDACTED]#g' \
    -e 's#gh[pousr]_[A-Za-z0-9_]+#[REDACTED]#g' \
    -e 's#github_pat_[A-Za-z0-9_]+#[REDACTED]#g'
}

usage() {
  cat <<'EOF'
Usage: sgt-doctor [project] [--project NAME] [--json]

Read-only diagnostics for a Sergeant developer installation.
EOF
}

while (($# > 0)); do
  case "$1" in
    --json) FORMAT=json ;;
    --project)
      [[ -z "$PROJECT" ]] || { echo "ERROR: project specified more than once" >&2; exit 64; }
      shift
      if (($# == 0)) || [[ "$1" == -* ]]; then
        echo "ERROR: --project requires a name" >&2
        exit 64
      fi
      PROJECT="$1"
      ;;
    -h|--help) usage; exit 0 ;;
    -*) printf 'ERROR: unknown option: %s\n' "$(redact "$1")" >&2; usage >&2; exit 64 ;;
    *)
      [[ -z "$PROJECT" ]] || { echo "ERROR: project specified more than once" >&2; exit 64; }
      PROJECT="$1"
      ;;
  esac
  shift
done

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_LINK="$(readlink "$SOURCE_PATH")"
  case "$SOURCE_LINK" in
    /*) SOURCE_PATH="$SOURCE_LINK" ;;
    *) SOURCE_PATH="$(dirname "$SOURCE_PATH")/$SOURCE_LINK" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
# shellcheck source=_sgt-lib.sh
# shellcheck disable=SC1091
source "$SCRIPT_DIR/_sgt-lib.sh"

SERGEANT_FLEET="${SERGEANT_FLEET:-$FLEET_DIR}"
SGT_INSTALL_DIR="${SGT_INSTALL_DIR:-$HOME/.local/bin}"
SERGEANT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

LEVELS=()
IDS=()
MESSAGES=()
PASSES=0
WARNINGS=0
FAILURES=0

add_check() {
  local level="$1" id="$2" message="$3"
  id="$(redact "$id")"
  message="$(redact "$message")"
  LEVELS+=("$level")
  IDS+=("$id")
  MESSAGES+=("$message")
  case "$level" in
    PASS) PASSES=$((PASSES + 1)) ;;
    WARN) WARNINGS=$((WARNINGS + 1)) ;;
    FAIL) FAILURES=$((FAILURES + 1)) ;;
  esac
}

check_tool() {
  local severity="$1" id="$2" command_name="$3" hint="$4" version
  if ! command -v "$command_name" >/dev/null 2>&1; then
    add_check "$severity" "tools.$id" "not installed; $hint"
    return 1
  fi
  if version="$(
    case "$command_name" in
      tmux) "$command_name" -V 2>&1 ;;
      *) "$command_name" --version 2>&1 ;;
    esac
  )"; then
    version="${version%%$'\n'*}"
    add_check PASS "tools.$id" "${version:-available}"
    return 0
  fi
  add_check "$severity" "tools.$id" "installed command is not usable"
  return 1
}

parse_semver_triplet() {
  local version_text="$1" match major minor patch
  match="$(printf '%s\n' "$version_text" | grep -Eo '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -n1 || true)"
  [[ -n "$match" ]] || return 1
  IFS=. read -r major minor patch <<< "$match"
  patch="${patch:-0}"
  printf '%s %s %s\n' "$major" "$minor" "$patch"
}

goose_version_is_compatible() {
  local version_text="$1"
  local major minor patch
  read -r major minor patch < <(parse_semver_triplet "$version_text") || return 2
  if ((major > 1)); then
    return 0
  fi
  if ((major == 1 && minor >= 10)); then
    return 0
  fi
  return 1
}

check_selected_agent() {
  local selected_agent="$1" selected_by="$2" agent_version
  case "$selected_agent" in
    opencode|claude|goose) ;;
    *)
      add_check FAIL agents.harness "$selected_by selects unsupported agent: $selected_agent"
      return
      ;;
  esac
  if ! command -v "$selected_agent" >/dev/null 2>&1; then
    add_check FAIL agents.harness "$selected_by $selected_agent, but it is not installed"
    return
  fi
  if agent_version="$("$selected_agent" --version 2>&1)"; then
    agent_version="${agent_version%%$'\n'*}"
    if [[ "$selected_agent" == "goose" ]]; then
      if goose_version_is_compatible "$agent_version"; then
        :
      else
        case $? in
          1)
            add_check FAIL agents.harness "$selected_by goose (${agent_version:-available}), but Goose 1.10+ is required for resumable sessions"
            ;;
          2)
            add_check WARN agents.harness "$selected_by goose, but its version output is unparseable; need Goose 1.10+ for resumable sessions"
            ;;
        esac
        return
      fi
    fi
    add_check PASS agents.harness "$selected_by $selected_agent (${agent_version:-available})"
  else
    add_check FAIL agents.harness "$selected_by $selected_agent, but the installed command is not usable"
  fi
}

check_agent_harness() {
  local selected_agent
  if [[ -n "${SERGEANT_AGENT:-}" ]]; then
    selected_agent="$(_sgt_detect_agent)"
    check_selected_agent "$selected_agent" "SERGEANT_AGENT selects"
    return
  fi
  if [[ -n "${OPENCODE:-}" || -n "${OPENCODE_PID:-}" || -n "${CLAUDE_CODE_SESSION_ID:-}" || -n "${CLAUDE_CODE_SESSION_NAME:-}" ]]; then
    selected_agent="$(_sgt_detect_agent)"
    check_selected_agent "$selected_agent" "auto-detected"
    return
  fi
  selected_agent="$(_sgt_detect_agent)"
  check_selected_agent "$selected_agent" "default selects"
}

check_project_config() {
  local project="$1" global_config_ok="$2" file="$SERGEANT_CONFIG/$1.yaml" configured_name repos_type
  local repo_count index repo_name repo_path resolved_path configured_url actual_url group
  local seen_repo_names="" duplicate_repo_names=false
  if [[ ! -f "$file" ]]; then
    add_check FAIL "config.project.$project" "project file does not exist: $file"
    return
  fi
  if ! yq eval '.' "$file" >/dev/null 2>&1; then
    add_check FAIL "config.project.$project" "project YAML cannot be parsed"
    return
  fi
  configured_name="$(yq eval '.name // ""' "$file" 2>/dev/null)"
  repos_type="$(yq eval '.repos | type' "$file" 2>/dev/null)"
  if [[ "$configured_name" != "$project" ]]; then
    add_check FAIL "config.project.$project" "name must match the project filename"
  elif [[ "$repos_type" != "!!seq" ]]; then
    add_check FAIL "config.project.$project" "repos must be a list"
  else
    add_check PASS "config.project.$project" "project YAML is valid"
  fi

  [[ "$repos_type" == "!!seq" ]] || return
  repo_count="$(yq eval '.repos | length' "$file" 2>/dev/null)"
  if ((repo_count == 0)); then
    add_check FAIL "config.project.$project" "repos must not be empty"
    return
  fi
  for ((index = 0; index < repo_count; index++)); do
    repo_name="$(yq eval ".repos[$index].name // \"\"" "$file" 2>/dev/null)"
    if [[ "$seen_repo_names" == *$'\n'"$repo_name"$'\n'* ]]; then
      duplicate_repo_names=true
    fi
    seen_repo_names+=$'\n'"$repo_name"$'\n'
  done
  if $duplicate_repo_names; then
    add_check FAIL "config.project.$project" "repo names must be unique"
  fi
  for ((index = 0; index < repo_count; index++)); do
    repo_name="$(yq eval ".repos[$index].name // \"\"" "$file" 2>/dev/null)"
    repo_path="$(yq eval ".repos[$index].path // \"\"" "$file" 2>/dev/null)"
    configured_url="$(yq eval ".repos[$index].url // \"\"" "$file" 2>/dev/null)"
    group="$(yq eval ".repos[$index].group // \"\"" "$file" 2>/dev/null)"
    if [[ -z "$repo_name" || -z "$repo_path" ]]; then
      add_check FAIL "config.repo.$project.${repo_name:-$index}" "repo name and path are required"
      continue
    fi
    if [[ -n "$group" && "$(yq eval ".groups.\"$group\" | type" "$file" 2>/dev/null)" != "!!map" ]]; then
      add_check FAIL "config.repo.$project.$repo_name" "referenced group is not defined"
      continue
    fi
    if ((global_config_ok == 0)) && [[ "$repo_path" != /* && "$repo_path" != ~* ]]; then
      continue
    fi
    resolved_path="$(_resolve_path "$repo_path")"
    if [[ ! -d "$resolved_path" ]]; then
      add_check FAIL "config.repo.$project.$repo_name" "repository path does not exist: ${resolved_path/#$HOME/~}"
      continue
    fi
    if ! git -C "$resolved_path" rev-parse --git-dir >/dev/null 2>&1; then
      add_check FAIL "config.repo.$project.$repo_name" "configured path is not a Git repository"
      continue
    fi
    actual_url="$(git -C "$resolved_path" remote get-url origin 2>/dev/null)" || actual_url=""
    if [[ -z "$actual_url" ]]; then
      add_check FAIL "config.repo.$project.$repo_name" "origin remote is missing"
    elif [[ -n "$configured_url" && "$configured_url" != "$actual_url" ]]; then
      add_check WARN "config.repo.$project.$repo_name" "configured URL does not match the origin remote"
    else
      add_check PASS "config.repo.$project.$repo_name" "repository path and origin remote are valid"
    fi
    if ((TD_OK)); then
      if td_json="$(td list --json --work-dir "$resolved_path" 2>/dev/null)" \
        && python3 -c 'import json,sys; json.loads(sys.stdin.read())' <<< "$td_json" 2>/dev/null; then
        add_check PASS "td.$project.$repo_name" "td database is available"
      else
        add_check WARN "td.$project.$repo_name" "td database is unavailable or invalid"
      fi
    fi
  done
}

YQ_OK=0
if command -v yq >/dev/null 2>&1; then
  if yq_version="$(yq --version 2>&1)"; then
    yq_version="${yq_version%%$'\n'*}"
    add_check PASS tools.yq "${yq_version:-available}"
    YQ_OK=1
  else
    add_check FAIL tools.yq "installed command is not usable"
  fi
else
  add_check FAIL tools.yq "not installed; install yq before using Sergeant"
fi

check_tool FAIL git git "install Git" || true
GH_OK=0
if check_tool FAIL gh gh "install GitHub CLI"; then
  GH_OK=1
fi
check_tool FAIL tmux tmux "install tmux" || true
check_tool FAIL python3 python3 "install Python 3" || true
TD_OK=0
if check_tool WARN td td "install td for task lifecycle support"; then
  TD_OK=1
fi
check_tool WARN no-mistakes no-mistakes "install no-mistakes for delivery gates" || true
check_tool WARN treehouse treehouse "install treehouse for pooled worktrees" || true
check_tool WARN babydriver babydriver "install babydriver for remote dispatch" || true
check_tool WARN mise mise "install mise for Sergeant installation tasks" || true

check_agent_harness

if ((GH_OK)); then
  if github_identity="$(gh api user --jq .login 2>/dev/null)" && [[ -n "$github_identity" ]]; then
    github_identity="$(printf '%s' "$github_identity" | tr -cd '[:alnum:]_.-')"
    add_check PASS github.auth "authenticated as ${github_identity:-unknown}"
  else
    add_check FAIL github.auth "GitHub CLI is not authenticated"
  fi
fi

shopt -s nullglob
for source_script in "$SERGEANT_ROOT"/bin/sgt-* "$SERGEANT_ROOT"/bin/_sgt-lib.sh \
  "$SERGEANT_ROOT"/bin/_sgt-response-lock.sh "$SERGEANT_ROOT"/bin/oc-inject \
  "$SERGEANT_ROOT"/bin/wiki-daily-digest; do
  [[ -f "$source_script" ]] || continue
  script_name="$(basename "$source_script")"
  installed_script="$SGT_INSTALL_DIR/$script_name"
  if [[ -L "$installed_script" && ! -e "$installed_script" ]]; then
    add_check FAIL "install.$script_name" "installed command is a broken symlink"
  elif [[ ! -L "$installed_script" ]]; then
    add_check WARN "install.$script_name" "installed command symlink is missing"
  elif [[ "$installed_script" -ef "$source_script" ]]; then
    add_check PASS "install.$script_name" "installed symlink targets this Sergeant checkout"
  else
    add_check WARN "install.$script_name" "installed symlink targets a different checkout"
  fi
done
shopt -u nullglob

case ":$PATH:" in
  *":$SGT_INSTALL_DIR:"*) add_check PASS install.path "install directory is on PATH" ;;
  *) add_check WARN install.path "install directory is not on PATH" ;;
esac

plugin_source="$SERGEANT_ROOT/opencode/plugins/oc-inject.js"
plugin_link="$HOME/.config/opencode/plugins/oc-inject.js"
if [[ -L "$plugin_link" && ! -e "$plugin_link" ]]; then
  add_check FAIL integrations.opencode-plugin "plugin is a broken symlink"
elif [[ -L "$plugin_link" && "$plugin_link" -ef "$plugin_source" ]]; then
  add_check PASS integrations.opencode-plugin "plugin symlink targets this Sergeant checkout"
elif [[ -e "$plugin_link" ]]; then
  add_check WARN integrations.opencode-plugin "plugin is not linked to this Sergeant checkout"
else
  add_check WARN integrations.opencode-plugin "oc-inject plugin is not installed"
fi

for skill_agent in opencode claude; do
  case "$skill_agent" in
    opencode) skill_root="$HOME/.config/opencode/skills" ;;
    claude) skill_root="$HOME/.claude/skills" ;;
  esac
  if [[ ! -d "$skill_root" ]]; then
    add_check WARN "skills.$skill_agent" "skill directory is not installed"
  elif broken_skill="$(find -L "$skill_root" -type l -print -quit 2>/dev/null)" && [[ -n "$broken_skill" ]]; then
    add_check FAIL "skills.$skill_agent" "skill directory contains a broken symlink"
  elif [[ -z "$(find "$skill_root" -type f -name SKILL.md -print -quit 2>/dev/null)" ]]; then
    add_check WARN "skills.$skill_agent" "skill directory contains no SKILL.md files"
  else
    add_check PASS "skills.$skill_agent" "skill directory contains no broken symlinks"
  fi
done

distribution_skills_valid=true
distribution_skill_count=0
shopt -s nullglob
for skill_dir in "$SERGEANT_ROOT"/skills/*; do
  distribution_skill_count=$((distribution_skill_count + 1))
  if [[ ! -f "$skill_dir/SKILL.md" ]]; then
    distribution_skills_valid=false
    break
  fi
done
shopt -u nullglob
if ((distribution_skill_count == 0)); then
  add_check FAIL skills.distribution "bundled Sergeant skills directory is empty"
elif $distribution_skills_valid; then
  add_check PASS skills.distribution "bundled Sergeant skills are intact"
else
  add_check FAIL skills.distribution "a bundled Sergeant skill is missing SKILL.md"
fi

for runtime_name in config fleet install; do
  case "$runtime_name" in
    config) runtime_path="$SERGEANT_CONFIG" ;;
    fleet) runtime_path="$SERGEANT_FLEET" ;;
    install) runtime_path="$SGT_INSTALL_DIR" ;;
  esac
  if [[ ! -d "$runtime_path" ]]; then
    add_check FAIL "runtime.$runtime_name" "runtime directory does not exist: ${runtime_path/#$HOME/~}"
  elif [[ ! -w "$runtime_path" ]]; then
    add_check FAIL "runtime.$runtime_name" "runtime directory is not writable: ${runtime_path/#$HOME/~}"
  else
    add_check PASS "runtime.$runtime_name" "runtime directory is writable"
  fi
done

fleet_repos=0
if [[ -d "$SERGEANT_FLEET" ]]; then
  shopt -s nullglob
  for fleet_task_dir in "$SERGEANT_FLEET"/*; do
    [[ -d "$fleet_task_dir" ]] || continue
    fleet_task="$(basename "$fleet_task_dir")"
    for fleet_repo_dir in "$fleet_task_dir"/*; do
      [[ -d "$fleet_repo_dir" ]] || continue
      fleet_repos=$((fleet_repos + 1))
      fleet_repo="$(basename "$fleet_repo_dir")"
      fleet_id="fleet.$fleet_task.$fleet_repo"
      fleet_status_file="$fleet_repo_dir/status"
      fleet_status=""
      fleet_worktree=""
      if [[ -f "$fleet_status_file" ]]; then
        fleet_status="$(tr -d '\n' < "$fleet_status_file")"
      fi
      if [[ -f "$fleet_repo_dir/worktree" ]]; then
        fleet_worktree="$(tr -d '\n' < "$fleet_repo_dir/worktree")"
      fi
      case "$fleet_status" in
        done)
          if [[ ! -s "$fleet_repo_dir/result" ]]; then
            add_check FAIL "$fleet_id" "done state has no result"
          else
            add_check PASS "$fleet_id" "terminal state is complete"
          fi
          ;;
        failed*) add_check PASS "$fleet_id" "terminal failure is recorded" ;;
        orphaned) add_check FAIL "$fleet_id" "orphaned worker requires recovery with sgt-respond" ;;
        in_progress|dispatched|needs_input|blocked)
          if [[ -z "$fleet_worktree" || ! -d "$fleet_worktree" ]]; then
            add_check FAIL "$fleet_id" "nonterminal state has no live worktree"
            continue
          fi
          worktree_status=""
          if [[ -f "$fleet_worktree/.sergeant-status" ]]; then
            worktree_status="$(tr -d '\n' < "$fleet_worktree/.sergeant-status")"
          fi
          if [[ -n "$worktree_status" && "$worktree_status" != "$fleet_status" ]]; then
            add_check WARN "$fleet_id" "fleet status is stale relative to the worktree"
            continue
          fi
          fleet_target=""
          fleet_target_inferred=false
          if [[ -s "$fleet_repo_dir/pane" ]]; then
            fleet_target="$(tr -d '\n' < "$fleet_repo_dir/pane")"
          elif [[ -s "$fleet_repo_dir/tmux_session" && -s "$fleet_repo_dir/window_name" ]]; then
            fleet_target="$(tr -d '\n' < "$fleet_repo_dir/tmux_session"):$(tr -d '\n' < "$fleet_repo_dir/window_name")"
          else
            fleet_target="${SERGEANT_TMUX_SESSION:-sgt}:${fleet_task:0:12}/$fleet_repo"
            fleet_target_inferred=true
          fi
          if _sgt_tmux_pane_is_supervisor "$fleet_target" "$fleet_repo_dir"; then
            :
          elif tmux display-message -p -t "$fleet_target" '#{pane_id}' >/dev/null 2>&1; then
            add_check FAIL "$fleet_id" "nonterminal state references a stale or reused tmux pane"
            continue
          elif $fleet_target_inferred; then
            add_check WARN "$fleet_id" "nonterminal worker cannot verify a local tmux pane (it may be remote)"
            continue
          else
            add_check FAIL "$fleet_id" "nonterminal state references a dead tmux pane"
            continue
          fi
          if [[ "$fleet_status" == "needs_input" || "$fleet_status" == "blocked" ]]; then
            add_check WARN "$fleet_id" "worker is waiting in $fleet_status state"
          elif [[ -n "$(find "$fleet_status_file" -mtime +7 -print 2>/dev/null)" ]]; then
            add_check WARN "$fleet_id" "nonterminal state has been unchanged for more than seven days"
          else
            add_check PASS "$fleet_id" "nonterminal worker and tmux pane are live"
          fi
          ;;
        "") add_check FAIL "$fleet_id" "fleet status is missing" ;;
        *) add_check FAIL "$fleet_id" "unknown fleet status: $fleet_status" ;;
      esac
    done
  done
  shopt -u nullglob
fi
if ((fleet_repos == 0)); then
  add_check PASS fleet.state "no active fleet workers"
fi

GLOBAL_CONFIG_OK=1
if ((YQ_OK)); then
  if [[ ! -d "$SERGEANT_CONFIG" ]]; then
    add_check FAIL config.directory "configuration directory does not exist: $SERGEANT_CONFIG"
  elif [[ -f "$SERGEANT_CONFIG/config.yaml" ]]; then
    if yq eval '.' "$SERGEANT_CONFIG/config.yaml" >/dev/null 2>&1; then
      add_check PASS config.global "global YAML is valid"
    else
      GLOBAL_CONFIG_OK=0
      add_check FAIL config.global "global YAML cannot be parsed"
    fi
  else
    add_check WARN config.global "config.yaml is missing; defaulting dev_root to ~/Dev"
  fi
fi

if command -v graphify >/dev/null 2>&1; then
  if graphify_version="$(graphify --version 2>&1)"; then
    graphify_version="${graphify_version%%$'\n'*}"
    add_check PASS tools.graphify "${graphify_version:-available}"
  else
    add_check WARN tools.graphify "installed command is not usable"
  fi
else
  add_check WARN tools.graphify "not installed; knowledge-graph diagnostics are unavailable"
fi

if ((YQ_OK)) && [[ -n "$PROJECT" ]]; then
  check_project_config "$PROJECT" "$GLOBAL_CONFIG_OK"
elif ((YQ_OK)) && [[ -d "$SERGEANT_CONFIG" ]]; then
  shopt -s nullglob
  for project_file in "$SERGEANT_CONFIG"/*.yaml; do
    [[ "$(basename "$project_file")" == "config.yaml" ]] && continue
    check_project_config "$(basename "$project_file" .yaml)" "$GLOBAL_CONFIG_OK"
  done
  shopt -u nullglob
fi

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

if ((FAILURES > 0)); then
  OVERALL=broken
elif ((WARNINGS > 0)); then
  OVERALL=degraded
else
  OVERALL=healthy
fi

if [[ "$FORMAT" == json ]]; then
  printf '{"status":"%s","summary":{"passes":%d,"warnings":%d,"failures":%d},"checks":[' \
    "$OVERALL" "$PASSES" "$WARNINGS" "$FAILURES"
  for ((i = 0; i < ${#LEVELS[@]}; i++)); do
    ((i > 0)) && printf ','
    level="$(printf '%s' "${LEVELS[$i]}" | tr '[:upper:]' '[:lower:]')"
    printf '{"id":"%s","status":"%s","message":"%s"}' \
      "$(json_escape "${IDS[$i]}")" "$level" "$(json_escape "${MESSAGES[$i]}")"
  done
  printf ']}\n'
else
  echo "Sergeant doctor"
  for ((i = 0; i < ${#LEVELS[@]}; i++)); do
    printf '[%s] %s: %s\n' "${LEVELS[$i]}" "${IDS[$i]}" "${MESSAGES[$i]}"
  done
  printf '%d warning(s), %d failure(s)\n' "$WARNINGS" "$FAILURES"
fi

if ((FAILURES > 0)); then
  exit 2
elif ((WARNINGS > 0)); then
  exit 1
fi
exit 0
