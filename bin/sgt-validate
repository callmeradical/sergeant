#!/usr/bin/env bash
# sgt-validate - Launch coordinator-owned no-mistakes beside an interactive worker.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_sgt-lib.sh
source "$SCRIPT_DIR/_sgt-lib.sh"
# shellcheck source=bin/_sgt-intent.sh
source "$SCRIPT_DIR/_sgt-intent.sh"

[[ $# -eq 2 || ( $# -eq 4 && "$3" == "--skip" ) ]] || \
  _die "Usage: sgt-validate <task-id> <repo> [--skip <steps>]"

TASK_ID="$1"
REPO="$2"
SKIP="${4:-}"
[[ "$TASK_ID" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || _die "Invalid task ID: $TASK_ID"
[[ "$REPO" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || _die "Invalid repo: $REPO"
[[ -z "$SKIP" || "$SKIP" =~ ^[a-z]+(,[a-z]+)*$ ]] || _die "Invalid --skip list: $SKIP"

REPO_STATE="$FLEET_DIR/$TASK_ID/$REPO"
TASK_STATE="$FLEET_DIR/$TASK_ID"
[[ -d "$REPO_STATE" ]] || _die "Repo not found in task $TASK_ID: $REPO"
WORKTREE="$(cat "$REPO_STATE/worktree" 2>/dev/null || true)"
PANE="$(cat "$REPO_STATE/pane" 2>/dev/null || true)"
[[ -d "$WORKTREE" ]] || _die "Worker worktree unavailable"
_sgt_intent_revision_matches "$TASK_STATE" "$REPO_STATE" "$WORKTREE" || \
  _die "canonical intent revision mismatch; audited human decision/new revision required"
EXPECTED_REVISION="$(cat "$TASK_STATE/intent_revision")"
[[ -f "$WORKTREE/.sergeant-validation-ready" ]] || \
  _die "Worker validation-ready marker is required before no-mistakes"
_ready_field() {
  local key="$1" file="$2"
  awk -F= -v key="$key" '
    $1 == key { count++; value = substr($0, length(key) + 2) }
    END { if (count == 1 && value != "") print value; else exit 1 }
  ' "$file"
}
READY_INTENT="$(_ready_field intent_revision "$WORKTREE/.sergeant-validation-ready")" || \
  _die "validation-ready marker has incomplete HEAD or review evidence"
READY_HEAD="$(_ready_field head_sha "$WORKTREE/.sergeant-validation-ready")" || \
  _die "validation-ready marker has incomplete HEAD or review evidence"
STANDARDS_REVIEW="$(_ready_field standards_review "$WORKTREE/.sergeant-validation-ready")" || \
  _die "validation-ready marker has incomplete HEAD or review evidence"
SPEC_REVIEW="$(_ready_field spec_review "$WORKTREE/.sergeant-validation-ready")" || \
  _die "validation-ready marker has incomplete HEAD or review evidence"
READINESS_REVIEW="$(_ready_field readiness_review "$WORKTREE/.sergeant-validation-ready")" || \
  _die "validation-ready marker has incomplete HEAD or review evidence"
CURRENT_HEAD="$(git -C "$WORKTREE" rev-parse HEAD 2>/dev/null || true)"
[[ "$READY_INTENT" == "$EXPECTED_REVISION" ]] || \
  _die "validation-ready marker does not match the canonical intent revision"
[[ "$READY_HEAD" == "$CURRENT_HEAD" && "$STANDARDS_REVIEW" == "passed" && \
   "$SPEC_REVIEW" == "passed" && "$READINESS_REVIEW" == "passed" ]] || \
  _die "validation-ready marker has stale HEAD or review evidence"
_sgt_worktree_is_validation_clean "$WORKTREE" || \
  _die "Worker code tree must be clean before validation snapshot"
[[ ! -e "$REPO_STATE/validation_pane" && ! -L "$REPO_STATE/validation_pane" ]] || \
  _die "Validation pane is already recorded"
[[ ! -e "$REPO_STATE/validation-release" && ! -L "$REPO_STATE/validation-release" ]] || \
  _die "Validation release is already recorded"
_require_tmux
command -v no-mistakes >/dev/null 2>&1 || _die "no-mistakes is required"
PRIMARY_PANE_ID="$(cat "$TASK_STATE/primary_pane_id" 2>/dev/null || true)"
[[ -n "${TMUX_PANE:-}" && "$TMUX_PANE" == "$PRIMARY_PANE_ID" ]] || \
  _die "Current coordinator pane identity does not match dispatch ownership"
_sgt_pane_identity_matches "$TMUX_PANE" "$TASK_STATE" primary_pane_identity || \
  _die "Current coordinator pane identity does not match dispatch ownership"
if [[ -z "$PANE" ]] || ! _sgt_pane_identity_matches "$PANE" "$REPO_STATE"; then
  _die "Recorded worker pane identity does not match"
fi

WINDOW_NAME="validation-${REPO}-${TASK_ID}"
[[ ! -L "$REPO_STATE/window_name" && ! -L "$REPO_STATE/stage" ]] || \
  _die "Validation prior state must not be a symlink"
SOURCE_ROOT="$(git -C "$WORKTREE" rev-parse --show-toplevel)"
SOURCE_BRANCH="$(git -C "$WORKTREE" branch --show-current)"
[[ -n "$SOURCE_BRANCH" ]] || _die "Validation requires a named source branch"
VALIDATION_WORKTREE="${WORKTREE}-validation-${TASK_ID}"
VALIDATION_WORKTREE_RECORD="$REPO_STATE/validation_worktree"
VALIDATION_WORKTREE_IDENTITY_RECORD="$REPO_STATE/validation_worktree_identity"
VALIDATION_WORKTREE_GIT_DIR_RECORD="$REPO_STATE/validation_worktree_git_dir"
VALIDATION_WORKTREE_GIT_IDENTITY_RECORD="$REPO_STATE/validation_worktree_git_identity"
VALIDATION_WORKTREE_OWNER_RECORD="$REPO_STATE/validation_worktree_owner"
VALIDATION_WORKTREE_RECORD_TEMP="${VALIDATION_WORKTREE_RECORD}.tmp.$$"
VALIDATION_INTENT="$REPO_STATE/validation-intent.md"
VALIDATION_INTENT_TEMP="${VALIDATION_INTENT}.tmp.$$"
VALIDATION_RELEASE_TEMP="$REPO_STATE/validation-release.tmp"
VALIDATION_RELEASE_OWNER="$REPO_STATE/validation-release-owner"
VALIDATION_LAUNCH_LOCK="$REPO_STATE/validation-launch.lock"
VALIDATION_CHILD_READY="$REPO_STATE/validation-child-ready"
VALIDATION_CHILD_ACCEPTED="$REPO_STATE/validation-child-accepted"
VALIDATION_CHILD_COMMIT="$REPO_STATE/validation-child-commit"
VALIDATION_CHILD_COMMITTED="$REPO_STATE/validation-child-committed"
VALIDATION_SUCCESS="$REPO_STATE/validation-success"
VALIDATION_SUCCESS_ACK="$REPO_STATE/validation-success-ack"
WINDOW_BACKUP="$REPO_STATE/window_name.validation-backup.$$"
STAGE_BACKUP="$REPO_STATE/stage.validation-backup.$$"

_validation_path_exists() {
  [[ -e "$1" || -L "$1" ]]
}
_validation_object_identity() {
  [[ -e "$1" && ! -L "$1" ]] || return 1
  stat -c '%d:%i:%w' -- "$1" 2>/dev/null || stat -f '%d:%i:%B' "$1" 2>/dev/null
}
_validation_path_identity() {
  local identity
  identity="$(_validation_object_identity "$1")" || return 1
  if [[ -f "$1" ]]; then
    printf '%s:%s\n' "$identity" "$(cksum < "$1")"
  else
    printf '%s\n' "$identity"
  fi
}
_validation_transition() {
  [[ "${SGT_VALIDATE_FAIL_TRANSITION:-}" != "$1" ]]
}

VALIDATION_COMMITTED=false
VALIDATION_LOCK_OWNED=false
VALIDATION_LOCK_IDENTITY=""
VALIDATION_WORKTREE_OWNED=false
VALIDATION_WORKTREE_IDENTITY=""
VALIDATION_PANE=""
VALIDATION_IDENTITY=""
VALIDATION_PANE_OWNED=false
WINDOW_STATE_OWNED=false
STAGE_STATE_OWNED=false
VALIDATION_CANDIDATE=""
VALIDATION_OWNED_PATHS=()
VALIDATION_OWNED_IDENTITIES=()
_validation_current_pane_identity() {
  local pane="$1" identity
  identity="$(_sgt_pane_identity "$pane" || true)"
  if [[ -n "$identity" ]]; then
    printf '%s\n' "$identity"
    return 0
  fi
  tmux list-panes -t "$PANE" -F \
    '#{pane_dead}|#{pane_id}|#{pane_pid}|#{pane_created}|#{pane_start_command}' 2>/dev/null | \
    awk -F'|' -v pane="$pane" '$2 == pane { print; found = 1 } END { exit !found }'
}
_validation_adopt_pane() {
  local identity="$1" info pane command current
  [[ "${identity%%|*}" == "0" ]] || return 1
  info="${identity#*|}"
  pane="${info%%|*}"
  command="${identity##*|}"
  [[ -n "$pane" && "$command" == "$VALIDATION_COMMAND" ]] || return 1
  current="$(_validation_current_pane_identity "$pane" || true)"
  [[ "$current" == "$identity" ]] || return 1
  VALIDATION_PANE="$pane"
  VALIDATION_IDENTITY="$identity"
  VALIDATION_PANE_OWNED=true
}
_wait_validation_handshake() {
  local path="$1" expected="$2" attempt=0
  local attempts="${SGT_VALIDATION_HANDSHAKE_ATTEMPTS:-200}"
  while [[ "$attempt" -lt "$attempts" ]]; do
    if [[ -f "$path" && ! -L "$path" && "$(cat "$path")" == "$expected" && \
      "$(_validation_current_pane_identity "$VALIDATION_PANE" || true)" == \
      "$VALIDATION_IDENTITY" ]]; then
      _validation_record_owned_path "$path" || return 1
      return 0
    fi
    [[ "$(_validation_current_pane_identity "$VALIDATION_PANE" || true)" == \
      "$VALIDATION_IDENTITY" ]] || return 1
    sleep 0.05
    attempt=$((attempt + 1))
  done
  return 1
}
_validation_record_owned_path() {
  local path="$1" identity
  identity="$(_validation_path_identity "$path")" || return 1
  VALIDATION_OWNED_PATHS[${#VALIDATION_OWNED_PATHS[@]}]="$path"
  VALIDATION_OWNED_IDENTITIES[${#VALIDATION_OWNED_IDENTITIES[@]}]="$identity"
}
_validation_remove_owned_paths() {
  local index path identity failed=false
  for ((index=${#VALIDATION_OWNED_PATHS[@]} - 1; index >= 0; index--)); do
    path="${VALIDATION_OWNED_PATHS[$index]}"
    identity="${VALIDATION_OWNED_IDENTITIES[$index]}"
    [[ "$(_validation_path_identity "$path" || true)" == "$identity" ]] || continue
    if ! rm -rf -- "$path" 2>/dev/null; then
      printf 'ERROR: rollback could not remove owned validation path: %s\n' "$path" >&2
      failed=true
    fi
  done
  ! $failed
}
_validation_write_owned() {
  local path="$1" value="$2" transition="${3:-state}" keep="${4:-false}"
  local candidate identity
  candidate="${path}.candidate.$$.$RANDOM.$RANDOM"
  (umask 077; set -C; : > "$candidate") 2>/dev/null || return 1
  _validation_record_owned_path "$candidate" || return 1
  _validation_transition "${transition}-temp" || return 1
  identity="$(_validation_object_identity "$candidate")" || return 1
  printf '%s\n' "$value" > "$candidate" || return 1
  [[ "$(_validation_object_identity "$candidate" || true)" == "$identity" ]] || return 1
  _validation_record_owned_path "$candidate" || return 1
  _validation_transition "${transition}-write" || return 1
  ln "$candidate" "$path" 2>/dev/null || return 1
  _validation_record_owned_path "$path" || return 1
  _validation_transition "${transition}-rename" || return 1
  _validation_transition "$transition" || return 1
  VALIDATION_CANDIDATE="$candidate"
  if ! $keep; then
    [[ "$(_validation_object_identity "$candidate" || true)" == "$identity" ]] || return 1
    rm -f "$candidate" || return 1
  fi
}
_validation_copy_owned() {
  local source="$1" path="$2" transition="$3" candidate identity
  candidate="${path}.candidate.$$.$RANDOM.$RANDOM"
  (umask 077; set -C; : > "$candidate") 2>/dev/null || return 1
  _validation_record_owned_path "$candidate" || return 1
  _validation_transition "${transition}-temp" || return 1
  identity="$(_validation_object_identity "$candidate")" || return 1
  cp "$source" "$candidate" || return 1
  [[ "$(_validation_object_identity "$candidate" || true)" == "$identity" ]] || return 1
  _validation_record_owned_path "$candidate" || return 1
  _validation_transition "${transition}-write" || return 1
  ln "$candidate" "$path" 2>/dev/null || return 1
  _validation_record_owned_path "$path" || return 1
  _validation_transition "${transition}-rename" || return 1
  _validation_transition "$transition" || return 1
  rm -f "$candidate"
}
_validation_replace_owned() {
  local path="$1" value="$2" transition="$3" expected="$4" backup="$5"
  local displaced candidate candidate_identity
  _validation_write_owned "$backup.candidate" "$value" "$transition" true || return 1
  candidate="$backup.candidate"
  candidate_identity="$(_validation_path_identity "$candidate")" || return 1
  mv "$path" "$backup" || return 1
  displaced="$(_validation_path_identity "$backup" || true)"
  if [[ "$displaced" != "$expected" ]]; then
    if ! _validation_path_exists "$path" && [[ -n "$displaced" ]]; then
      ln "$backup" "$path" 2>/dev/null && rm -f "$backup"
    fi
    return 1
  fi
  ln "$candidate" "$path" 2>/dev/null || return 1
  _validation_record_owned_path "$path" || return 1
  _validation_transition "${transition}-publish" || return 1
  rm -f "$candidate" || return 1
  if [[ "$(_validation_path_identity "$VALIDATION_CANDIDATE" || true)" == \
    "$candidate_identity" ]]; then
    rm -f "$VALIDATION_CANDIDATE" || return 1
  fi
}
_validation_process_start() {
  ps -o lstart= -p "$1" 2>/dev/null | awk '{$1=$1; print}'
}
_validation_lock_field() {
  local key="$1" file="$2"
  awk -F= -v key="$key" '
    $1 == key { count++; value = substr($0, length(key) + 2) }
    END { if (count == 1 && value != "") print value; else exit 1 }
  ' "$file"
}
_remove_validation_lock_identity() {
  local expected="$1" displaced identity
  displaced="$REPO_STATE/.validation-launch.lock.recovery.$$.$RANDOM.$RANDOM"
  ! _validation_path_exists "$displaced" || return 1
  mv "$VALIDATION_LAUNCH_LOCK" "$displaced" || return 1
  identity="$(_validation_path_identity "$displaced" || true)"
  if [[ "$identity" != "$expected" ]]; then
    if ! _validation_path_exists "$VALIDATION_LAUNCH_LOCK" && [[ -n "$identity" ]]; then
      ln "$displaced" "$VALIDATION_LAUNCH_LOCK" 2>/dev/null && rm -f "$displaced"
    fi
    return 1
  fi
  rm -f "$displaced"
}
_recover_validation_lock() {
  local identity owner_pid owner_start owner_coordinator owner_purpose current_start
  [[ -f "$VALIDATION_LAUNCH_LOCK" && ! -L "$VALIDATION_LAUNCH_LOCK" ]] || return 1
  [[ "$(wc -l < "$VALIDATION_LAUNCH_LOCK")" -eq 4 ]] || return 1
  owner_pid="$(_validation_lock_field pid "$VALIDATION_LAUNCH_LOCK")" || return 1
  owner_start="$(_validation_lock_field start "$VALIDATION_LAUNCH_LOCK")" || return 1
  owner_coordinator="$(_validation_lock_field coordinator "$VALIDATION_LAUNCH_LOCK")" || return 1
  owner_purpose="$(_validation_lock_field purpose "$VALIDATION_LAUNCH_LOCK")" || return 1
  [[ "$owner_pid" =~ ^[0-9]+$ && "$owner_coordinator" == "$LOCK_COORDINATOR" && \
    "$owner_purpose" == "$LOCK_PURPOSE" ]] || return 1
  identity="$(_validation_path_identity "$VALIDATION_LAUNCH_LOCK")" || return 1
  if kill -0 "$owner_pid" 2>/dev/null; then
    current_start="$(_validation_process_start "$owner_pid" || true)"
    [[ -n "$current_start" && "$current_start" != "$owner_start" ]] || return 1
  fi
  _remove_validation_lock_identity "$identity"
}
_acquire_validation_lock() {
  local candidate identity owner_start attempt
  candidate="$REPO_STATE/.validation-launch.lock.$$.$RANDOM.$RANDOM"
  owner_start="$(_validation_process_start "$$")" || return 1
  (umask 077; set -C; {
    printf 'pid=%s\n' "$$"
    printf 'start=%s\n' "$owner_start"
    printf 'coordinator=%s\n' "$LOCK_COORDINATOR"
    printf 'purpose=%s\n' "$LOCK_PURPOSE"
  } > "$candidate") 2>/dev/null || return 1
  _validation_record_owned_path "$candidate" || return 1
  identity="$(_validation_path_identity "$candidate")" || return 1
  for attempt in 1 2; do
    if ln "$candidate" "$VALIDATION_LAUNCH_LOCK" 2>/dev/null; then
      VALIDATION_LOCK_IDENTITY="$(_validation_path_identity "$VALIDATION_LAUNCH_LOCK")" || \
        return 1
      [[ "$VALIDATION_LOCK_IDENTITY" == "$identity" ]] || return 1
      VALIDATION_LOCK_OWNED=true
      rm -f "$candidate" || return 1
      return 0
    fi
    [[ "$attempt" -eq 1 ]] && _recover_validation_lock || return 1
  done
  return 1
}
_release_validation_lock() {
  $VALIDATION_LOCK_OWNED || return 0
  _remove_validation_lock_identity "$VALIDATION_LOCK_IDENTITY" || return 1
  VALIDATION_LOCK_OWNED=false
}
_rollback_validation_launch() {
  local current_identity handshake_path cleanup_failed=false
  $VALIDATION_COMMITTED && return 0
  if [[ -n "${VALIDATION_HANDSHAKE:-}" ]]; then
    for handshake_path in "$VALIDATION_CHILD_READY" "$VALIDATION_CHILD_ACCEPTED" \
      "$VALIDATION_CHILD_COMMIT" "$VALIDATION_CHILD_COMMITTED" \
      "$VALIDATION_SUCCESS" "$VALIDATION_SUCCESS_ACK"; do
      if [[ -f "$handshake_path" && ! -L "$handshake_path" && \
        "$(cat "$handshake_path")" == "$VALIDATION_HANDSHAKE" ]]; then
        if ! _validation_record_owned_path "$handshake_path"; then
          printf 'ERROR: rollback could not record owned handshake path: %s\n' \
            "$handshake_path" >&2
          cleanup_failed=true
        fi
      fi
    done
  fi
  if $VALIDATION_PANE_OWNED && [[ -n "$VALIDATION_PANE" ]]; then
    current_identity="$(_validation_current_pane_identity "$VALIDATION_PANE" || true)"
    if [[ "$current_identity" == "$VALIDATION_IDENTITY" || \
      "$current_identity" == "1|${VALIDATION_IDENTITY#*|}" ]]; then
      if ! tmux kill-pane -t "$VALIDATION_PANE" 2>/dev/null; then
        printf 'ERROR: rollback could not stop owned validation pane: %s\n' \
          "$VALIDATION_PANE" >&2
        cleanup_failed=true
      fi
    fi
  fi
  _validation_remove_owned_paths || cleanup_failed=true
  if $WINDOW_STATE_OWNED && ! _validation_path_exists "$REPO_STATE/window_name" && \
    [[ "$(_validation_path_identity "$WINDOW_BACKUP" || true)" == "$OLD_WINDOW_IDENTITY" ]]; then
    if ! ln "$WINDOW_BACKUP" "$REPO_STATE/window_name" 2>/dev/null || \
      ! rm -f "$WINDOW_BACKUP"; then
      printf 'ERROR: rollback could not restore prior window state\n' >&2
      cleanup_failed=true
    fi
  fi
  if $STAGE_STATE_OWNED && ! _validation_path_exists "$REPO_STATE/stage" && \
    [[ "$(_validation_path_identity "$STAGE_BACKUP" || true)" == "$OLD_STAGE_IDENTITY" ]]; then
    if ! ln "$STAGE_BACKUP" "$REPO_STATE/stage" 2>/dev/null || \
      ! rm -f "$STAGE_BACKUP"; then
      printf 'ERROR: rollback could not restore prior stage state\n' >&2
      cleanup_failed=true
    fi
  fi
  if $VALIDATION_WORKTREE_OWNED && \
     [[ "$(_validation_path_identity "$VALIDATION_WORKTREE" || true)" == \
       "$VALIDATION_WORKTREE_IDENTITY" ]]; then
    if ! rm -rf "$VALIDATION_WORKTREE"; then
      printf 'ERROR: rollback could not remove owned validation checkout: %s\n' \
        "$VALIDATION_WORKTREE" >&2
      cleanup_failed=true
    fi
  fi
  if ! _release_validation_lock; then
    printf 'ERROR: rollback could not release validation launch lock: %s\n' \
      "$VALIDATION_LAUNCH_LOCK" >&2
    cleanup_failed=true
  fi
  ! $cleanup_failed
}
_finish_validation_launch() {
  local status=$? original_status
  original_status="$status"
  trap - EXIT
  if $VALIDATION_COMMITTED; then
    if ! _release_validation_lock; then
      printf 'ERROR: committed validation launch could not release lock: %s\n' \
        "$VALIDATION_LAUNCH_LOCK" >&2
      status=1
    fi
  else
    if ! _rollback_validation_launch; then
      printf 'ERROR: validation launch failed with status %s and rollback cleanup also failed\n' \
        "$original_status" >&2
      status=1
    fi
  fi
  exit "$status"
}
trap _finish_validation_launch EXIT

LOCK_COORDINATOR="$PRIMARY_PANE_ID|$(_sgt_read_owned_file \
  "$TASK_STATE/primary_pane_identity")" || _die "Coordinator identity record is unsafe"
LOCK_PURPOSE="$TASK_ID/$REPO/validation-launch"
if ! _acquire_validation_lock; then
  _die "Validation launch is already reserved or unsafe: $VALIDATION_LAUNCH_LOCK"
fi
OLD_WINDOW_IDENTITY="$(_validation_path_identity "$REPO_STATE/window_name")" || \
  _die "Failed to capture prior window state identity"
OLD_STAGE_IDENTITY="$(_validation_path_identity "$REPO_STATE/stage")" || \
  _die "Failed to capture prior stage identity"

_validation_path_exists "$VALIDATION_WORKTREE" && \
  _die "Validation code snapshot already exists: $VALIDATION_WORKTREE"
for path in "$VALIDATION_WORKTREE_RECORD" "$VALIDATION_WORKTREE_RECORD_TEMP" \
  "$VALIDATION_WORKTREE_IDENTITY_RECORD" "$VALIDATION_WORKTREE_GIT_DIR_RECORD" \
  "$VALIDATION_WORKTREE_GIT_IDENTITY_RECORD" "$VALIDATION_WORKTREE_OWNER_RECORD" \
  "$VALIDATION_INTENT" "$VALIDATION_INTENT_TEMP" "$REPO_STATE/validation_pane" \
  "$REPO_STATE/validation-release" "$VALIDATION_RELEASE_OWNER" \
  "$REPO_STATE/validation_head" \
  "$REPO_STATE/validation_pane_identity" "$REPO_STATE/validation_pane_pid" \
  "$REPO_STATE/validation_process_group" "$REPO_STATE/validation_process_start" \
  "$REPO_STATE/validation_status" "$VALIDATION_RELEASE_TEMP" \
  "$VALIDATION_CHILD_READY" "$VALIDATION_CHILD_ACCEPTED" "$VALIDATION_CHILD_COMMIT" \
  "$VALIDATION_CHILD_COMMITTED" "$VALIDATION_SUCCESS" "$VALIDATION_SUCCESS_ACK" \
  "$WINDOW_BACKUP" "$STAGE_BACKUP"; do
  ! _validation_path_exists "$path" || _die "Validation launch state already exists: $path"
done
mkdir "$VALIDATION_WORKTREE" || _die "Failed to reserve isolated validation code snapshot"
VALIDATION_WORKTREE_IDENTITY="$(_validation_path_identity "$VALIDATION_WORKTREE")" || \
  _die "Failed to capture validation code snapshot identity"
VALIDATION_WORKTREE_OWNED=true
git clone --shared --no-checkout "$SOURCE_ROOT" "$VALIDATION_WORKTREE" >/dev/null 2>&1 || \
  _die "Failed to create isolated validation code snapshot"
git -C "$VALIDATION_WORKTREE" checkout -q -B "$SOURCE_BRANCH" "$CURRENT_HEAD" || \
  _die "Failed to create isolated validation code snapshot"
SOURCE_REMOTE="$(git -C "$SOURCE_ROOT" remote get-url origin 2>/dev/null || true)"
if [[ -n "$SOURCE_REMOTE" ]]; then
  git -C "$VALIDATION_WORKTREE" remote set-url origin "$SOURCE_REMOTE" || \
    _die "Failed to preserve validation snapshot remote"
fi
if [[ "$(git -C "$VALIDATION_WORKTREE" rev-parse HEAD)" != "$CURRENT_HEAD" ]] || \
   ! _sgt_worktree_is_validation_clean "$VALIDATION_WORKTREE"; then
  _die "Isolated validation code snapshot did not preserve reviewed HEAD"
fi
VALIDATION_GIT_DIR="$(git -C "$VALIDATION_WORKTREE" rev-parse --path-format=absolute \
  --git-common-dir)" || _die "Failed to capture validation Git directory"
VALIDATION_GIT_IDENTITY="$(_validation_path_identity "$VALIDATION_GIT_DIR")" || \
  _die "Failed to capture validation Git directory identity"
VALIDATION_OWNER="$LOCK_PURPOSE|$VALIDATION_LOCK_IDENTITY|$CURRENT_HEAD"
(umask 077; set -C; printf '%s\n' "$VALIDATION_OWNER" > \
  "$VALIDATION_GIT_DIR/sergeant-validation-owner") 2>/dev/null || \
  _die "Failed to persist validation checkout owner"
_validation_write_owned "$VALIDATION_WORKTREE_RECORD" "$VALIDATION_WORKTREE" marker || \
  _die "Failed to publish validation code snapshot marker"
_validation_write_owned "$VALIDATION_WORKTREE_IDENTITY_RECORD" \
  "$VALIDATION_WORKTREE_IDENTITY" worktree-identity || \
  _die "Failed to publish validation checkout identity"
_validation_write_owned "$VALIDATION_WORKTREE_GIT_DIR_RECORD" "$VALIDATION_GIT_DIR" \
  worktree-git-dir || _die "Failed to publish validation Git directory"
_validation_write_owned "$VALIDATION_WORKTREE_GIT_IDENTITY_RECORD" \
  "$VALIDATION_GIT_IDENTITY" worktree-git-identity || \
  _die "Failed to publish validation Git identity"
_validation_write_owned "$VALIDATION_WORKTREE_OWNER_RECORD" "$VALIDATION_OWNER" \
  worktree-owner || _die "Failed to publish validation checkout owner"
_validation_transition intent-copy || _die "Failed to snapshot canonical validation intent"
_validation_copy_owned "$WORKTREE/.sergeant-intent.md" "$VALIDATION_INTENT" intent || \
  _die "Failed to snapshot canonical validation intent"
[[ "$(_sgt_intent_revision "$VALIDATION_INTENT")" == "$EXPECTED_REVISION" ]] || {
  _die "Validation intent snapshot revision mismatch"
}
printf -v VALIDATION_COMMAND '%q %q %q %q %q' \
  "$SCRIPT_DIR/sgt-validation-worker" "$REPO_STATE" "$VALIDATION_WORKTREE" "$EXPECTED_REVISION" "$SKIP"
PANE_FORMAT='#{pane_dead}|#{pane_id}|#{pane_pid}|#{pane_created}|#{pane_start_command}'
PANE_SNAPSHOT="$(tmux list-panes -t "$PANE" -F "$PANE_FORMAT" 2>/dev/null || true)"
set +e
SPLIT_IDENTITY="$(tmux split-window -P -F "$PANE_FORMAT" -t "$PANE" \
  -c "$VALIDATION_WORKTREE" "$VALIDATION_COMMAND")"
SPLIT_STATUS=$?
set -e
if [[ -n "$SPLIT_IDENTITY" ]]; then
  _validation_adopt_pane "$SPLIT_IDENTITY" || \
    _die "Failed to verify created validation pane identity"
else
  NEW_PANE_IDENTITIES="$(tmux list-panes -t "$PANE" -F "$PANE_FORMAT" 2>/dev/null | \
    while IFS= read -r identity; do
      printf '%s\n' "$PANE_SNAPSHOT" | grep -Fqx -- "$identity" || printf '%s\n' "$identity"
    done)"
  if [[ -z "$NEW_PANE_IDENTITIES" || "$NEW_PANE_IDENTITIES" == *$'\n'* ]] || \
    ! _validation_adopt_pane "$NEW_PANE_IDENTITIES"; then
    _die "Failed to reconcile created validation pane identity"
  fi
fi
if [[ -f "$VALIDATION_CHILD_READY" && ! -L "$VALIDATION_CHILD_READY" && \
  "$(cat "$VALIDATION_CHILD_READY")" == "$EXPECTED_REVISION|$VALIDATION_PANE|"* ]]; then
  _validation_record_owned_path "$VALIDATION_CHILD_READY" || \
    _die "Failed to capture validation child readiness"
fi
VALIDATION_INFO="${VALIDATION_IDENTITY#*|}"
VALIDATION_INFO="${VALIDATION_INFO#*|}"
VALIDATION_PID="${VALIDATION_INFO%%|*}"
VALIDATION_PGID="$(ps -o pgid= -p "$VALIDATION_PID" 2>/dev/null | tr -d ' ' || true)"
VALIDATION_START="$(ps -o lstart= -p "$VALIDATION_PID" 2>/dev/null | awk '{$1=$1; print}' || true)"
[[ -n "$VALIDATION_PID" && -n "$VALIDATION_PGID" && -n "$VALIDATION_START" ]] || \
  _die "Failed to capture validation process ownership"
VALIDATION_HANDSHAKE="$EXPECTED_REVISION|$VALIDATION_PANE|$VALIDATION_PID|$VALIDATION_START"
_wait_validation_handshake "$VALIDATION_CHILD_READY" "$VALIDATION_HANDSHAKE" || \
  _die "Validation child did not become ready"
_validation_transition pane-identity || _die "Failed to capture validation pane identity"
[[ "$SPLIT_STATUS" -eq 0 ]] || _die "Failed to launch validation pane"
[[ "$(_validation_current_pane_identity "$VALIDATION_PANE" || true)" == \
  "$VALIDATION_IDENTITY" && "${VALIDATION_IDENTITY%%|*}" == "0" ]] || \
  _die "Validation pane exited before launch publication"
if ! tmux rename-window -t "$PANE" "$WINDOW_NAME"; then
  _die "Failed to rename validation window"
fi

_validation_write_owned "$REPO_STATE/validation_pane" "$VALIDATION_PANE" \
  state-validation_pane || \
  _die "Failed to publish validation pane"
_validation_write_owned "$REPO_STATE/validation_pane_identity" "$VALIDATION_IDENTITY" \
  state-validation_pane_identity || \
  _die "Failed to publish validation pane identity"
_validation_write_owned "$REPO_STATE/validation_pane_pid" "$VALIDATION_PID" \
  state-validation_pane_pid || \
  _die "Failed to publish validation pane PID"
_validation_write_owned "$REPO_STATE/validation_process_group" "$VALIDATION_PGID" \
  state-validation_process_group || \
  _die "Failed to publish validation process group"
_validation_write_owned "$REPO_STATE/validation_process_start" "$VALIDATION_START" \
  state-validation_process_start || \
  _die "Failed to publish validation process start"
WINDOW_STATE_OWNED=true
_validation_replace_owned "$REPO_STATE/window_name" "$WINDOW_NAME" state-window_name \
  "$OLD_WINDOW_IDENTITY" "$WINDOW_BACKUP" || \
  _die "Failed to publish validation window name"
_validation_write_owned "$REPO_STATE/validation_head" "$CURRENT_HEAD" \
  state-validation_head || \
  _die "Failed to publish validation HEAD"
STAGE_STATE_OWNED=true
_validation_replace_owned "$REPO_STATE/stage" "validation" state-stage \
  "$OLD_STAGE_IDENTITY" "$STAGE_BACKUP" || \
  _die "Failed to publish validation stage"
_validation_write_owned "$REPO_STATE/validation_status" "launched" \
  state-validation_status || \
  _die "Failed to publish validation status"
_validation_write_owned "$REPO_STATE/validation-release" "$VALIDATION_HANDSHAKE" release || \
  _die "Failed to publish validation release"
ln "$REPO_STATE/validation-release" "$VALIDATION_RELEASE_OWNER" 2>/dev/null || \
  _die "Failed to publish validation release owner"
_validation_record_owned_path "$VALIDATION_RELEASE_OWNER" || \
  _die "Failed to capture validation release owner"
_wait_validation_handshake "$VALIDATION_CHILD_ACCEPTED" "$VALIDATION_HANDSHAKE" || \
  _die "Validation child did not accept release"
_validation_write_owned "$VALIDATION_CHILD_COMMIT" "$VALIDATION_HANDSHAKE" child-commit || \
  _die "Failed to commit validation child release"
_wait_validation_handshake "$VALIDATION_CHILD_COMMITTED" "$VALIDATION_HANDSHAKE" || \
  _die "Validation child did not acknowledge committed state"
[[ "$(_validation_current_pane_identity "$VALIDATION_PANE" || true)" == \
  "$VALIDATION_IDENTITY" ]] || _die "Validation child exited before commit"
_validation_write_owned "$VALIDATION_SUCCESS" "$VALIDATION_HANDSHAKE" success || \
  _die "Failed to publish validation success"
_wait_validation_handshake "$VALIDATION_SUCCESS_ACK" "$VALIDATION_HANDSHAKE" || \
  _die "Validation child did not acknowledge success"
[[ "$(_validation_current_pane_identity "$VALIDATION_PANE" || true)" == \
  "$VALIDATION_IDENTITY" ]] || _die "Validation child exited before success publication"
rm -f "$WINDOW_BACKUP" "$STAGE_BACKUP"
VALIDATION_COMMITTED=true
printf 'Validation launched in pane %s beside worker %s.\n' "$VALIDATION_PANE" "$PANE"
