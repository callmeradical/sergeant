#!/usr/bin/env bash
# sgt-dispatch — Dispatch subagents across repos in a project
#
# Creates an isolated git worktree per repo, writes a mission brief into each,
# and spawns an agent in a local tmux window.
#
# Usage:
#   sgt-dispatch <project> "<brief>" [options]
#   sgt-dispatch <project> --td <task-id> [options]   # brief from td task
#
# Options:
#   --repos repo1,repo2,...   Repos to dispatch (required unless --td auto-detects)
#   --td <task-id>            Pull brief and context from a td task
#   --branch <name>           Branch name for all worktrees (default: derived from brief)
#   --deps "repo1>repo2,..."  Dependency ordering: repo1 must finish before repo2 starts
#   --agent <harness>         Interactive harness: opencode, goose, or claude
#   --stage <name>            Window stage slug (default: implementation)
#   --intent-file <path>       Canonical structured intent for safety/stateful work
#   --dry-run                 Print what would happen, don't execute
#
# Examples:
#   sgt-dispatch smith "Add OAuth via Google" --repos smith,smith-app,smith-infra
#   sgt-dispatch smith --td td-a3cf60 --repos smith
#   sgt-dispatch smith --td td-a3cf60   # auto-detects repo from td db

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_sgt-lib.sh
source "$SCRIPT_DIR/_sgt-lib.sh"
# shellcheck source=bin/_sgt-intent.sh
source "$SCRIPT_DIR/_sgt-intent.sh"

# ── Parse args ───────────────────────────────────────────────────────────────

[[ $# -ge 1 ]] || _die "Usage: sgt-dispatch <project> \"<brief>\" [options]"
PROJECT="$1"; shift

CONFIG_FILE="$SERGEANT_CONFIG/$PROJECT.yaml"
[[ -f "$CONFIG_FILE" ]] || _die "Project not found: $PROJECT (looked for $CONFIG_FILE)"

BRIEF=""
REPOS_ARG=""
BRANCH_ARG=""
DEPS_ARG=""
TD_TASK_ID=""
INTENT_FILE=""
AGENT_OVERRIDE=""
STAGE="implementation"
DRY_RUN=false

# Brief is optional positional arg (not present when --td is used)
if [[ $# -gt 0 && "${1:0:2}" != "--" ]]; then
  BRIEF="$1"; shift
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repos)   REPOS_ARG="$2";   shift 2 ;;
    --td)      TD_TASK_ID="$2";  shift 2 ;;
    --branch)  BRANCH_ARG="$2";  shift 2 ;;
    --deps)    DEPS_ARG="$2";    shift 2 ;;
    --agent)
      [[ -n "${2:-}" ]] || _die "--agent requires opencode, goose, or claude"
      AGENT_OVERRIDE="$2"
      shift 2
      ;;
    --stage)
      [[ -n "${2:-}" ]] || _die "--stage requires a lowercase slug"
      STAGE="$2"
      shift 2
      ;;
    --intent-file)
      [[ -n "${2:-}" ]] || _die "--intent-file requires a path"
      INTENT_FILE="$2"
      shift 2
      ;;
    --dry-run) DRY_RUN=true;     shift   ;;
    *) _die "Unknown option: $1" ;;
  esac
done

[[ -z "$AGENT_OVERRIDE" ]] || AGENT_CMD="$AGENT_OVERRIDE"
[[ "$STAGE" =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]] || _die "stage must be a lowercase slug: $STAGE"

# ── Resolve td task (if --td provided) ───────────────────────────────────────

TD_CONTEXT=""
TD_REPO=""

if [[ -n "$TD_TASK_ID" ]]; then
  _require_marcus_td
  _require_yq

  # Find which repo owns this task by trying each repo's td db
  repo_count="$(yq '.repos | length' "$CONFIG_FILE")"
  for ((i=0; i<repo_count; i++)); do
    rname="$(yq ".repos[$i].name" "$CONFIG_FILE")"
    raw_path="$(yq ".repos[$i].path" "$CONFIG_FILE")"
    repo_path="$(_resolve_path "$raw_path")"
    _sgt_is_git_repo "$repo_path" || continue

    task_json="$(td list --json --work-dir "$repo_path" \
      --filter "id=$TD_TASK_ID" 2>/dev/null || echo "[]")"
    count="$(echo "$task_json" | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo 0)"

    if [[ "$count" -gt 0 ]]; then
      TD_REPO="$rname"
      # Pull title and description for brief
      td_title="$(echo "$task_json" | python3 -c "
import sys,json; t=json.load(sys.stdin)[0]
print(t.get('title',''))
" 2>/dev/null)"

      # Get full context from td
      TD_CONTEXT="$(td context "$TD_TASK_ID" --work-dir "$repo_path" 2>/dev/null || echo "")"

      # Set brief from td title if not provided
      [[ -z "$BRIEF" ]] && BRIEF="$td_title"

      # Auto-set repos if not specified
      [[ -z "$REPOS_ARG" ]] && REPOS_ARG="$rname"

      break
    fi
  done

  if [[ -z "$TD_REPO" ]]; then
    _die "td task $TD_TASK_ID not found in any repo of project $PROJECT"
  fi

  echo "td task: $TD_TASK_ID in $TD_REPO"
  echo "title:   $BRIEF"
  echo ""
fi

[[ -n "$BRIEF" ]]     || _die "Provide a brief or use --td <task-id>"
[[ -n "$REPOS_ARG" ]] || _die "Must specify --repos. Run 'sgt-context $PROJECT' to see available repos."

TARGET_REPOS=()
IFS=',' read -ra TARGET_REPOS <<< "$REPOS_ARG"

_require_yq
_require_git
_require_tmux
[[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || \
  _die "sgt-dispatch requires an interactive coordinator tmux pane"
PRIMARY_PANE_ID="$TMUX_PANE"
PRIMARY_PANE_IDENTITY="$(_sgt_pane_identity "$PRIMARY_PANE_ID" || true)"
[[ -n "$PRIMARY_PANE_IDENTITY" && "${PRIMARY_PANE_IDENTITY%%|*}" == "0" && \
   "${PRIMARY_PANE_IDENTITY#*|}" == "$PRIMARY_PANE_ID|"* ]] || \
  _die "sgt-dispatch could not bind exact coordinator pane identity"
_require_interactive_agent

INTENT_TMP="$(mktemp)"

# ── Auto-create td tasks when no --td given ───────────────────────────────────
# When we weren't given a specific task ID, create td tasks in each target repo
# now so the work is tracked end-to-end.
#
# We store a map of repo→task_id in a temp file so the brief-writing loop
# can inject the right td task ID per repo.

REPO_TD_MAP="$(mktemp)"
TD_CREATE_STATE_FILE="$(mktemp)"
TD_CREATE_STDERR="$(mktemp)"
_cleanup_dispatch_tmps() {
  rm -f "$REPO_TD_MAP" "$TD_CREATE_STATE_FILE" "$TD_CREATE_STDERR" "$INTENT_TMP" "${DEPS_TMP:-}"
}
trap _cleanup_dispatch_tmps EXIT

_sgt_intent_prepare "$INTENT_FILE" "$BRIEF" "$INTENT_TMP"
INTENT_REVISION="$(_sgt_intent_revision "$INTENT_TMP")"

_rollback_generated_td_tasks() {
  local failure_message="$1"
  local cleanup_failed=false
  local cleanup_output=""

  while IFS=$'\t' read -r repo_name task_id work_dir; do
    [[ -n "$task_id" ]] || continue
    if ! delete_output="$(td delete "$task_id" --work-dir "$work_dir" --force --json 2>&1)"; then
      cleanup_failed=true
      if [[ -n "$cleanup_output" ]]; then
        cleanup_output+=$'\n'
      fi
      if [[ -n "$delete_output" ]]; then
        cleanup_output+="cleanup failed for $task_id in $repo_name: $delete_output"
      else
        cleanup_output+="cleanup failed for $task_id in $repo_name"
      fi
    fi
  done < <(
    python3 - "$TD_CREATE_STATE_FILE" <<'PY'
import json
import sys

path = sys.argv[1]
with open(path, encoding="utf-8") as handle:
    for line in handle:
        line = line.strip()
        if not line:
            continue
        item = json.loads(line)
        print("\t".join([item["repo"], item["task_id"], item["work_dir"]]))
PY
  )

  if $cleanup_failed; then
    _die "$failure_message"$'\n'"$cleanup_output"
  fi

  : > "$TD_CREATE_STATE_FILE"
  _die "$failure_message"
}

_build_repo_td_map_or_die() {
  local td_results="$1"
  local selected_repos_csv="$2"
  : > "$TD_CREATE_STDERR"
  if ! TD_RESULTS="$td_results" TARGET_REPOS_CSV="$selected_repos_csv" python3 - <<'PY' > "$REPO_TD_MAP" 2>"$TD_CREATE_STDERR"
import json
import os
import sys

selected = [repo for repo in os.environ["TARGET_REPOS_CSV"].split(",") if repo]
seen = set()
seen_task_ids = set()

try:
    results = json.loads(os.environ["TD_RESULTS"])
except json.JSONDecodeError:
    print("failed to inject td task results", file=sys.stderr)
    raise SystemExit(1)

if not isinstance(results, list):
    print("failed to inject td task results", file=sys.stderr)
    raise SystemExit(1)

for item in results:
    if not isinstance(item, dict):
        print("failed to inject td task results", file=sys.stderr)
        raise SystemExit(1)
    repo = item.get("repo")
    task_id = item.get("task_id")
    if not isinstance(repo, str) or not isinstance(task_id, str):
        print("failed to inject td task results", file=sys.stderr)
        raise SystemExit(1)
    if not task_id or any(ch.isspace() for ch in task_id):
        print(f"invalid td task id for repo: {repo}", file=sys.stderr)
        raise SystemExit(1)
    if repo not in selected:
        print(f"unexpected td task result for repo: {repo}", file=sys.stderr)
        raise SystemExit(1)
    if repo in seen:
        print(f"duplicate td task result for repo: {repo}", file=sys.stderr)
        raise SystemExit(1)
    if task_id in seen_task_ids:
        print(f"duplicate td task id: {task_id}", file=sys.stderr)
        raise SystemExit(1)
    seen.add(repo)
    seen_task_ids.add(task_id)
    print(f"{repo} {task_id}")

for repo in selected:
    if repo not in seen:
        print(f"missing td task for selected repo: {repo}", file=sys.stderr)
        raise SystemExit(1)
PY
  then
    local validation_error
    validation_error="$(cat "$TD_CREATE_STDERR")"
    [[ -n "$validation_error" ]] || validation_error="failed to inject td task results"
    _rollback_generated_td_tasks "$validation_error"
  fi
}

if [[ -z "$TD_TASK_ID" ]] && ! $DRY_RUN; then
  _require_marcus_td
  TD_TITLE="$(python3 - "$BRIEF" <<'PY'
import sys

title = " ".join(sys.argv[1].split())
if len(title) > 200:
    title = title[:197].rstrip() + "..."
print(title)
PY
)"
  echo "Creating td tasks ..."
  : > "$TD_CREATE_STATE_FILE"
  : > "$TD_CREATE_STDERR"
  if ! td_results="$(SGT_TD_STATE_FILE="$TD_CREATE_STATE_FILE" "$SCRIPT_DIR/sgt-td-create" "$PROJECT" "$TD_TITLE" \
    --repos "$REPOS_ARG" \
    --description "$BRIEF" \
    --type task \
    --priority P1 \
    --json 2>"$TD_CREATE_STDERR")"; then
    td_error="$(cat "$TD_CREATE_STDERR")"
    [[ -n "$td_error" ]] || td_error="$td_results"
    _die "td task creation failed: $td_error"
  fi

  _build_repo_td_map_or_die "$td_results" "$REPOS_ARG"

  if [[ -s "$REPO_TD_MAP" ]]; then
    while IFS=' ' read -r rname tid; do
      echo "  created $tid in $rname"
    done < "$REPO_TD_MAP"
    echo ""
  fi
fi

# ── Generate task ID ──────────────────────────────────────────────────────────

_rand6() { dd if=/dev/urandom bs=32 count=1 2>/dev/null | od -An -tx1 | tr -d ' \n' | cut -c1-6; }

slug="$(echo "$BRIEF" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-//;s/-$//' | cut -c1-24 | sed 's/-$//')"
TASK_ID="${slug}-$(_rand6)"

# ── Determine branch name ─────────────────────────────────────────────────────

if [[ -n "$BRANCH_ARG" ]]; then
  BRANCH="$BRANCH_ARG"
else
  bslug="$(echo "$BRIEF" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-//;s/-$//' | cut -c1-40 | sed 's/-$//')"
  if [[ "$bslug" =~ ^(feat|fix|chore|refactor|docs|test)- ]]; then
    BRANCH="${bslug/-//}"
  else
    BRANCH="feat/$bslug"
  fi
fi

TASK_DIR="$FLEET_DIR/$TASK_ID"
# All dispatches share a single "sgt" tmux session — each task gets its own
# windows within it. This keeps tmux list-sessions clean.
# Override with SERGEANT_TMUX_SESSION=<name> if you want task-scoped sessions.
SGT_TMUX_SESSION="${SERGEANT_TMUX_SESSION:-sgt}"
TMUX_SESSION="$SGT_TMUX_SESSION"

echo ""
echo "=== sgt-dispatch: $PROJECT ==="
echo "brief:   $BRIEF"
echo "task-id: $TASK_ID"
echo "branch:  $BRANCH"
echo ""

# ── Validate repos ────────────────────────────────────────────────────────────

repo_count="$(yq '.repos | length' "$CONFIG_FILE")"

for rname in "${TARGET_REPOS[@]}"; do
  found=false
  for ((i=0; i<repo_count; i++)); do
    n="$(yq ".repos[$i].name" "$CONFIG_FILE")"
    [[ "$n" == "$rname" ]] && found=true && break
  done
  $found || _die "Repo '$rname' not found in project $PROJECT"
done

# ── Parse dependency order ────────────────────────────────────────────────────
# Format: "infra>api,infra>app" → infra must finish before api and app
# Store in a temp file: "<dependent> <prereq>" one per line

DEPS_TMP="$(mktemp)"
trap _cleanup_dispatch_tmps EXIT

if [[ -n "$DEPS_ARG" ]]; then
  IFS=',' read -ra dep_pairs <<< "$DEPS_ARG"
  for pair in "${dep_pairs[@]}"; do
    prereq="${pair%%>*}"
    dependent="${pair##*>}"
    echo "$dependent $prereq" >> "$DEPS_TMP"
  done
fi

# Look up comma-separated prereqs for a repo
_wait_for() {
  grep "^$1 " "$DEPS_TMP" 2>/dev/null | awk '{print $2}' | paste -sd ',' - 2>/dev/null || true
}

_record_dispatch_orphan() {
  local repo_task_dir="$1"
  local worktree_path="$2"
  local reason="$3"
  printf 'orphaned\n' > "$repo_task_dir/status"
  printf '%s\n' "$reason" > "$repo_task_dir/diagnostic"
  "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_task_dir" "$worktree_path" || true
}

# ── Capture primary pane (for sgt-notify callbacks) ──────────────────────────

PRIMARY_PANE=""
PRIMARY_PANE="$(tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null || true)"

OC_PID="${OPENCODE_PID:-}"
OC_SESSION=""
if [[ "$OC_PID" =~ ^[0-9]+$ ]]; then
  OC_ROOT="${OC_INJECT_ROOT:-$HOME/.local/share/opencode/inbox}"
  OC_REGISTRY="$OC_ROOT/processes/$OC_PID/registry.json"
  OC_PROCESS_START="$(ps -o lstart= -p "$OC_PID" 2>/dev/null | awk '{$1=$1; print}' || true)"
  if kill -0 "$OC_PID" 2>/dev/null && [[ -f "$OC_REGISTRY" ]] && \
    [[ "$(jq -r '.pid // empty' "$OC_REGISTRY" 2>/dev/null || true)" == "$OC_PID" ]] && \
    [[ "$(jq -r '.processStart // empty' "$OC_REGISTRY" 2>/dev/null || true)" == "$OC_PROCESS_START" ]]; then
    OC_SESSION_CANDIDATE="${OPENCODE_SESSION_ID:-}"
    if jq -e --arg s "$OC_SESSION_CANDIDATE" '.sessions | has($s)' "$OC_REGISTRY" >/dev/null 2>&1; then
      OC_SESSION="$OC_SESSION_CANDIDATE"
    fi
  fi
fi

# ── Create fleet task directory ───────────────────────────────────────────────

if $DRY_RUN; then
  echo "[dry-run] fleet dir: $TASK_DIR"
else
  mkdir -p "$TASK_DIR"
  _sgt_intent_install "$INTENT_TMP" "$TASK_DIR/.sergeant-intent.md"
  printf '%s\n' "$INTENT_REVISION" > "$TASK_DIR/intent_revision"
  printf "Project: %s\nBrief:   %s\nBranch:  %s\nRepos:   %s\n" \
    "$PROJECT" "$BRIEF" "$BRANCH" "${TARGET_REPOS[*]}" > "$TASK_DIR/brief.md"
  [[ -n "$TD_TASK_ID" ]] && echo "$TD_TASK_ID" > "$TASK_DIR/td_task"
  date -u +%Y-%m-%dT%H:%M:%SZ > "$TASK_DIR/started"
  [[ -n "$PRIMARY_PANE" ]] && echo "$PRIMARY_PANE" > "$TASK_DIR/primary_pane"
  if [[ -n "$PRIMARY_PANE_ID" && -n "$PRIMARY_PANE_IDENTITY" ]]; then
    printf '%s\n' "$PRIMARY_PANE_ID" > "$TASK_DIR/primary_pane_id"
    printf '%s\n' "$PRIMARY_PANE_IDENTITY" > "$TASK_DIR/primary_pane_identity"
  fi
  if [[ -n "$OC_SESSION" ]]; then
    jq -nc --argjson pid "$OC_PID" --arg sessionId "$OC_SESSION" \
      '{pid: $pid, sessionId: $sessionId}' > "$TASK_DIR/oc_target.json"
  fi
fi

# ── Create tmux session (local only) ─────────────────────────────────────────

if ! $DRY_RUN; then
  # Create the shared session if it doesn't exist yet; no-op if already running.
  tmux new-session -d -s "$TMUX_SESSION" -n "sergeant" 2>/dev/null || true
  echo "tmux session: $TMUX_SESSION"
  echo ""
fi

# ── Dispatch per repo ─────────────────────────────────────────────────────────

for rname in "${TARGET_REPOS[@]}"; do
  # Find repo index in config
  for ((i=0; i<repo_count; i++)); do
    n="$(yq ".repos[$i].name" "$CONFIG_FILE")"
    [[ "$n" == "$rname" ]] && break
  done

  raw_path="$(yq ".repos[$i].path" "$CONFIG_FILE")"
  repo_path="$(_resolve_path "$raw_path")"
  repo_role="$(yq ".repos[$i].role // \"\"" "$CONFIG_FILE")"
  repo_group="$(yq ".repos[$i].group // \"\"" "$CONFIG_FILE")"

  echo "--- $rname ---"

  if ! _sgt_is_git_repo "$repo_path"; then
    echo "  SKIP: not cloned at $repo_path (run bin/sgt-sync $PROJECT first)"
    echo ""
    continue
  fi

  # ── Resolve merged instructions (defaults → group → repo) ──────────────────

  default_inst="$(yq '.defaults.agent_instructions // ""' "$CONFIG_FILE")"
  group_description=""
  group_inst=""
  if [[ -n "$repo_group" && "$repo_group" != "null" ]]; then
    group_description="$(yq ".groups.\"$repo_group\".description // \"\"" "$CONFIG_FILE")"
    group_inst="$(yq ".groups.\"$repo_group\".agent_instructions // \"\"" "$CONFIG_FILE")"
  fi
  repo_inst="$(yq ".repos[$i].agent_instructions // \"\"" "$CONFIG_FILE")"

  merged=""
  [[ -n "$default_inst" && "$default_inst" != "null" ]] && merged+="$default_inst"$'\n'
  [[ -n "$group_inst"   && "$group_inst"   != "null" ]] && merged+="$group_inst"$'\n'
  [[ -n "$repo_inst"    && "$repo_inst"    != "null" ]] && merged+="$repo_inst"$'\n'

  # ── Resolve dependencies ────────────────────────────────────────────────────

  wait_for="$(_wait_for "$rname")"
  deps_section=""
  if [[ -n "$wait_for" ]]; then
    deps_section="## Dependencies"$'\n\n'
    IFS=',' read -ra prereqs <<< "$wait_for"
    for prereq in "${prereqs[@]}"; do
      prereq_fleet="$TASK_DIR/$prereq"
      deps_section+="Wait for \`$prereq\` to complete before opening your PR."$'\n'
      deps_section+="Check fleet state: \`cat $prereq_fleet/status\`"$'\n'
      deps_section+="(or check worktree directly: \`cat \$(cat $prereq_fleet/worktree)/.sergeant-status\`)"$'\n\n'
    done
  fi

  # ── Determine worktree strategy ────────────────────────────────────────────
  # Prefer treehouse if treehouse.toml exists in the repo (pre-warmed pool).
  # Fall back to plain git worktree add otherwise.

  repo_task_dir="$TASK_DIR/$rname"
  use_treehouse=false
  if [[ -f "$repo_path/treehouse.toml" ]] && command -v treehouse &>/dev/null; then
    use_treehouse=true
  fi

  if $DRY_RUN; then
    if $use_treehouse; then
      echo "  worktree: treehouse lease (pool: ~/.treehouse/)"
    else
      echo "  worktree: $(dirname "$repo_path")/${rname}-sgt-${TASK_ID}"
    fi
    echo "  branch:   $BRANCH"
    [[ -n "$wait_for" ]] && echo "  waits for: $wait_for"
    echo ""
    continue
  fi

  # ── Acquire worktree ─────────────────────────────────────────────────────────

  mkdir -p "$repo_task_dir"
  _sgt_intent_install "$INTENT_TMP" "$repo_task_dir/.sergeant-intent.md"
  printf '%s\n' "$INTENT_REVISION" > "$repo_task_dir/intent_revision"
  echo "$BRANCH"    > "$repo_task_dir/branch"
  echo "dispatched" > "$repo_task_dir/status"
  [[ -n "$wait_for" ]] && echo "$wait_for" > "$repo_task_dir/wait_for"

  if $use_treehouse; then
    _info "acquiring treehouse lease for $rname ..."
    lease_holder="sgt-${TASK_ID}-${rname}"
    worktree_path="$(cd "$repo_path" && treehouse get --lease --lease-holder "$lease_holder" 2>/dev/null)"
    if [[ -z "$worktree_path" ]]; then
      _info "WARNING: treehouse lease failed — falling back to git worktree add"
      use_treehouse=false
    else
      _info "leased: $worktree_path"
      echo "treehouse"      > "$repo_task_dir/wt_type"
      echo "$lease_holder"  > "$repo_task_dir/wt_holder"
      # Create and checkout the task branch in the leased worktree
      if git -C "$worktree_path" show-ref --verify --quiet "refs/heads/$BRANCH" 2>/dev/null; then
        git -C "$worktree_path" checkout "$BRANCH" 2>&1 | sed 's/^/    /'
      else
        git -C "$worktree_path" checkout -b "$BRANCH" 2>&1 | sed 's/^/    /'
      fi
    fi
  fi

  if ! $use_treehouse; then
    worktree_path="$(dirname "$repo_path")/${rname}-sgt-${TASK_ID}"
    echo "git" > "$repo_task_dir/wt_type"
    _info "creating git worktree: $worktree_path"
    if [[ -d "$worktree_path" ]]; then
      _info "already exists — reusing"
    else
      if git -C "$repo_path" show-ref --verify --quiet "refs/heads/$BRANCH" 2>/dev/null; then
        git -C "$repo_path" worktree add "$worktree_path" "$BRANCH" 2>&1 | sed 's/^/    /'
      else
        git -C "$repo_path" worktree add -b "$BRANCH" "$worktree_path" 2>&1 | sed 's/^/    /'
      fi
    fi
  fi

  echo "$worktree_path" > "$repo_task_dir/worktree"
  [[ -f "$worktree_path/.git" && ! -L "$worktree_path/.git" ]] || \
    _die "worktree has no immutable Git pointer: $worktree_path"
  worktree_git_pointer="$(cat "$worktree_path/.git")"
  [[ "$worktree_git_pointer" == "gitdir: "* ]] || \
    _die "worktree Git pointer is malformed: $worktree_path/.git"
  worktree_git_dir="${worktree_git_pointer#gitdir: }"
  if [[ "$worktree_git_dir" != /* ]]; then
    worktree_git_dir="$worktree_path/$worktree_git_dir"
  fi
  worktree_git_dir="$(cd "$worktree_git_dir" 2>/dev/null && pwd -P)" || \
    _die "worktree Git directory is unavailable: $worktree_git_dir"
  printf '%s\n' "$worktree_git_pointer" > "$repo_task_dir/worktree_git_pointer"
  printf '%s\n' "$worktree_git_dir" > "$repo_task_dir/worktree_git_dir"
  _sgt_intent_install "$INTENT_TMP" "$worktree_path/.sergeant-intent.md"

  # ── Write brief ─────────────────────────────────────────────────────────────

  role_line=""
  if [[ -n "$repo_role" && "$repo_role" != "null" ]]; then
    role_line="Role: $repo_role"
  fi

  # Resolve td task ID for this repo:
  # --td flag: use provided ID (only for the owning repo)
  # auto-created: look up from the map
  REPO_TD_TASK_ID=""
  if [[ -n "$TD_TASK_ID" && "$rname" == "$TD_REPO" ]]; then
    REPO_TD_TASK_ID="$TD_TASK_ID"
  elif [[ -f "$REPO_TD_MAP" ]]; then
    REPO_TD_TASK_ID="$(grep "^$rname " "$REPO_TD_MAP" 2>/dev/null | awk '{print $2}' || true)"
  fi

  # Build td section for brief
  td_section=""
  td_task_line=""
  if [[ -n "$REPO_TD_TASK_ID" ]]; then
    # Fetch full context if this came from --td
    repo_td_context=""
    if [[ -n "$TD_CONTEXT" && "$rname" == "$TD_REPO" ]]; then
      repo_td_context="$TD_CONTEXT"
    fi

    td_context_block=""
    if [[ -n "$repo_td_context" ]]; then
      td_context_block="$(printf '\nFull task context:\n%s' "$repo_td_context")"
    fi

    td_section="## Task management

This work is tracked in td as: \`$REPO_TD_TASK_ID\`

At session start:
\`\`\`
td start $REPO_TD_TASK_ID --work-dir .
\`\`\`

Log meaningful progress:
\`\`\`
td log \"message\" --work-dir .
\`\`\`

Before writing .sergeant-status=done, hand off:
\`\`\`
td handoff $REPO_TD_TASK_ID --work-dir .
td review $REPO_TD_TASK_ID --work-dir .
\`\`\`
$td_context_block"
    td_task_line="**td task:** $REPO_TD_TASK_ID"
    # Store td task ID in fleet state
    echo "$REPO_TD_TASK_ID" > "$repo_task_dir/td_task"
  fi

  review_axis_label="two"
  accessibility_axis_markdown=""
  review_context="$(printf '%s %s %s %s %s' "$BRIEF" "$repo_role" "$repo_group" "$group_description" "$merged" | tr '[:upper:]' '[:lower:]')"
  if [[ "$review_context" =~ (^|[^[:alnum:]])(ui|frontend|front-end|visual|interaction|accessibility|user-facing[[:space:]]+output)([^[:alnum:]]|$) ]]; then
    review_axis_label="three"
    accessibility_axis_markdown=$'\n- **Accessibility axis:** Because this is UI-facing work, launch a separate independent accessibility review covering keyboard access, semantics, focus behavior, contrast, responsive behavior, and assistive-technology compatibility as applicable.'
  fi

  cat > "$worktree_path/.sergeant-brief.md" << BRIEF_EOF
# Sergeant Brief

**Task ID:** $TASK_ID
**Project:** $PROJECT
**Repo:** $rname
**Branch:** $BRANCH
**Worktree:** $worktree_path
**Fleet state:** $repo_task_dir/
$td_task_line

---

## Mission

$BRIEF

This agent is responsible for the **$rname** repo only.
$role_line

$deps_section
$td_section

## Active instructions

$merged

---

## Deliver

Follow these gates in order. Preserve the evidence in the PR description or a linked review artifact.

### 1. Pin scope and source of truth

Before implementation, fetch refs and pin the fixed point, normally the merge-base with the current origin/main. Record the base SHA, commit list and diff scope; if that base is unavailable, record the explicit alternative.

Identify the originating spec from the full td task context, this Sergeant mission, and any referenced issue, PRD, spec, or ADR. If no originating spec exists, record that explicitly.

.sergeant-intent.md is the canonical source for implementation decisions, independent reviews, PR description, and the one final no-mistakes --intent. Intent revision: $INTENT_REVISION. Successor and recovery work must inherit this exact revision. Do not silently regenerate it; only an audited human decision creates a new intent revision.

### 2. Route the work

Triage context and readiness before choosing an implementation loop: read the full td issue/spec/comments and linked material, check for redundant or prior work, identify the work category, and record whether it is ready.

- **Huge or foggy:** Surface a wayfinding/spec/ticketing blocker with the missing decisions. Surface \`wayfinder\`, \`to-spec\`, and Sergeant's custom \`to-tickets\` as escalation or planning paths. Do not silently execute them as implementation or invent the route.
- **Hard bug or performance regression:** When available, load and use the canonical \`diagnosing-bugs\` skill. First establish one fast deterministic red-capable command. Reproduce and minimise, rank falsifiable hypotheses, instrument one variable at a time, then turn the minimal reproduction into a regression test before fixing it.
- **Uncertain state, design, or UI:** When available, load and use the canonical \`prototype\` skill. Create a clearly throwaway prototype, surface it for human-in-the-loop feedback, and never promote prototype code directly. Discard it and implement the approved direction through the normal TDD path.
- **Approved feature or fix:** When available, load and use the canonical \`tdd\` skill before implementation. Implement tracer-bullet vertical slices with TDD.
- **Merge or rebase conflict:** When available, load and use the canonical \`resolving-merge-conflicts\` skill. Trace both intents to their issues/specs, preserve both where possible, and never abort automatically. Escalate when intent cannot be reconciled.

If a canonical skill cannot be loaded, follow the embedded rules in this brief for that phase.

### 3. Implement approved work with TDD

Establish public behavioral seams before writing tests. Use seams already specified by td/spec; if a consequential seam is genuinely undecided, surface needs_input rather than guessing.

For safety-sensitive or stateful work, implementation is blocked unless the canonical intent has concrete State Transitions, Failure Windows, and Negative Test Matrix sections supplied through the explicit readiness path. Publish needs_input when any is missing. The named standard-isolated lighter path applies only when the objective does not trigger Sergeant's safety/stateful classifier.

For each non-trivial behavior, work red before green: one vertical slice, test, and minimum implementation at a time. Run the failing focused test for the right reason, add only enough implementation to pass, then refactor after green. Reject tautological tests, internal mocking, and horizontal slicing such as writing all tests before all implementation. Scrutinize refactoring during review. Do not speculate ahead.

### 4. Escalate and resume

Your worker runs as a persistent interactive agent session in its recorded tmux pane. Non-interactive agent modes are prohibited: do not launch \`opencode run\`, \`goose run\`, Claude print mode, \`--auto\`, \`--prompt\`, or an equivalent one-shot agent. Sergeant delivers only a fixed ID-bearing notification through interactive terminal input; prompt, response, and secret bodies remain in durable files and never appear in process arguments.

For every Sergeant notification, read \`.sergeant-notification\` and copy the exact supervisor-scoped token from the nudge (\`notification_id|target_nonce\`) to the named file under \`.sergeant-notification-acks/\`. Do not act until that supervisor sends acceptance and the named file under \`.sergeant-notification-accepts/\` contains the same token. Then follow the instruction exactly once and write the token to the named file under \`.sergeant-notification-complete/\`. Repeated nudges with the same token are retries, not new work.

If an agent exits before a terminal or waiting state, the supervisor records \`orphaned\` with durable diagnostics and td recovery pointers. Resume orphaned work through \`sgt-respond\`; do not overwrite or discard its recovery state.

When Sergeant notifies you of a response, read \`.sergeant-response\`, \`.sergeant-response-id\`, and \`.sergeant-response-generation\`; apply the approved decision once and restore \`.sergeant-status\` to \`in_progress\`, a terminal state, or a later gate generation. Write \`.sergeant-response-applied\` with exactly one \`response_id\`, \`gate_generation\`, and matching \`status\`, then run \`sgt-ack-response $TASK_ID $rname "\$(cat .sergeant-response-id)"\` from this exact worker pane. Do not clear, replay, or acknowledge a response by hand; the command validates pane ownership and proof, archives replay evidence, and atomically records consumption.

Completion requires both .sergeant-status=done and a non-empty .sergeant-result; a PR or successful turn alone is not terminal completion.

Supported nonterminal statuses are \`in_progress\`, \`needs_input\`, and \`blocked\`; terminal statuses are \`done\` and \`failed: <reason>\`.

For \`needs_input\` or \`blocked\`, write \`.sergeant-message\` with concise context, evidence, the exact question or blocker, a recommendation, and 2-4 options when useful. Call \`sgt-notify $TASK_ID "needs_input [$rname]: <summary>"\` or the equivalent \`blocked\` message. The worker remains alive and waits for a response; do not exit or mark the task failed.

When \`.sergeant-response\` appears, follow the post-application proof and \`sgt-ack-response\` protocol above. Valid proof is \`in_progress\` after applying the decision, \`done\` with a non-empty result, \`failed: <nonblank reason>\`, or a later \`needs_input\`/\`blocked\` gate generation. Unexpected exit or invalid proof retains active transport, while successful acknowledgement archives replay evidence before clearing it. Clear \`.sergeant-message\`, log the decision to td when tracked, and continue only when a consequential question is answered.

Maintain \`.sergeant-gate-generation\` as a monotonic integer for waiting gates. Before every new \`needs_input\` or \`blocked\` publication, increment the generation and persist it before writing the waiting status and message. A repeated blocker message is still a new gate only when the generation advances.

### 5. Validate

Run focused tests and typechecking/lint regularly. Run the repository's full required suite once at the end.

Before the final shipping boundary, launch an independent readiness review over mutation before validation, partial publication and rollback, identity and provenance, stale and legacy states, suppressed failures, race windows, and missing negative tests. Record evidence against the canonical intent.

Commit the reviewed branch before publishing readiness. Validation requires a clean worktree at that committed HEAD; do not create readiness evidence from an uncommitted diff.

Never run no-mistakes from this agent process. After implementation, repository-native validation, and independent reviews complete with zero blockers, write \`.sergeant-validation-ready\` with exactly one \`intent_revision=$INTENT_REVISION\`, the current \`head_sha=\$(git rev-parse HEAD)\`, and \`standards_review=passed\`, \`spec_review=passed\`, and \`readiness_review=passed\`. Then notify Sergeant that coordinator-owned validation may begin.

The coordinator invokes \`sgt-validate $TASK_ID $rname\`, which runs no-mistakes interactively in a split pane of this window with the canonical intent and without \`--yes\`. The validation run is read-only; actionable findings become separate td work.

### 6. Route no-mistakes findings

The Sergeant coordinator owns every no-mistakes gate and finding. Do not approve a validation gate, route a finding, or remediate validation output from this worker pane. Actionable findings become separate deduplicated td work and remediation never runs no-mistakes. Resume this worker only through an explicit Sergeant response tied to that owning work.

### 7. Independent $review_axis_label-axis review

Before completion, load and use the canonical \`code-review\` skill when available, then launch separate parallel subagents for these axes so their contexts cannot contaminate each other. Keep their output in separate sections. Do not blend or rerank the axes. If the skill cannot be loaded, use the embedded review rules below.

- **Standards axis:** Review the diff versus the pinned merge-base against active repo instructions, AGENTS, CONTRIBUTING, and coding standards. Add a concise Fowler smell heuristic (duplication, long functions/modules, large parameter lists, feature envy, data clumps, primitive obsession, shotgun surgery, and inappropriate intimacy). Separate hard documented-standard violations from judgement-call smells, and skip findings enforced by tooling.
- **Spec axis:** Review against the originating td issue/spec/mission. Report missing or partial requirements, scope creep, and incorrectly implemented requirements. If no spec exists, report this axis as skipped/no spec.$accessibility_axis_markdown

### 8. Remediate and repeat

Remediate every blocking repository-native test or independent-review finding, rerun affected tests, then rerun all required independent review axes. Repeat until blocking findings are zero on each axis. Do not remediate no-mistakes findings in this validation run; their owning td work requires a separate dispatch.

### 9. Complete delivery and td lifecycle

The branch was committed before readiness. Open the PR via \`gh pr create\`. If this work has a td task, log decisions throughout, handoff before td review, and run td review only after implementation and review evidence is ready.

Do not write \`done\` merely because a PR exists. Success requires: the branch is committed; the PR is open; focused and full validation are complete; required CI is green; there are no unresolved non-outdated review threads; dependency order is satisfied; and independent review is complete with zero blocking findings.

While waiting for CI, reviews, or dependencies, keep \`.sergeant-status\` as \`in_progress\`. Use \`needs_input\` or \`blocked\` and the escalation protocol for recoverable waits. Reserve \`failed: <exact reason>\` for an unrecoverable terminal failure. Only after every success gate passes:

1. Write the PR URL: \`echo "https://github.com/..." > .sergeant-result\`
2. Write \`echo "done" > .sergeant-status\`
3. Notify: \`sgt-notify $TASK_ID "done: PR https://github.com/..."\`

For failure, notify with \`sgt-notify $TASK_ID "failed: <exact blocker>"\`.

The primary sergeant session is watching via \`sgt-watch $TASK_ID\`.
BRIEF_EOF

  echo "in_progress" > "$repo_task_dir/status"
  _info "brief written → $worktree_path/.sergeant-brief.md"

  # ── Spawn agent ─────────────────────────────────────────────────────────────

  WINDOW_NAME="${STAGE}-${rname}-${TASK_ID}"
  _info "spawning tmux window '$WINDOW_NAME' in session $TMUX_SESSION"
  printf '%s\n' "$TMUX_SESSION" > "$repo_task_dir/tmux_session"
  printf '%s\n' "$WINDOW_NAME" > "$repo_task_dir/window_name"
  printf '%s\n' "$STAGE" > "$repo_task_dir/stage"
  printf '%s\n' "$AGENT_CMD" > "$repo_task_dir/agent"
  initial_notification_id="$(dd if=/dev/urandom bs=16 count=1 2>/dev/null | od -An -tx1 | tr -d ' \n')"
  _sgt_publish_worker_notification "$repo_task_dir" "$worktree_path" \
    "$initial_notification_id" initial "Read the .sergeant-brief.md file and execute the mission."
  WORKER_RUN_CMD="$(_sgt_worker_command \
    "$SCRIPT_DIR/sgt-interactive-worker" "$repo_task_dir" "$worktree_path" "$AGENT_CMD")"
  if pane_target="$(tmux new-window -P -F '#{pane_id}' -t "$TMUX_SESSION:" \
    -n "$WINDOW_NAME" -c "$worktree_path" "$WORKER_RUN_CMD")"; then
    if [[ -z "$pane_target" ]]; then
      printf 'orphaned\n' > "$repo_task_dir/status"
      printf 'tmux launched no worker pane\n' > "$repo_task_dir/diagnostic"
      "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_task_dir" "$worktree_path" || true
      _die "tmux returned no pane for $rname"
    fi
    printf '%s\n' "$pane_target" > "$repo_task_dir/pane"
    if pane_identity="$(_sgt_pane_identity "$pane_target")" && [[ -n "$pane_identity" ]]; then
      printf '%s\n' "$pane_identity" > "$repo_task_dir/pane_identity"
      _sgt_notification_target_create "$repo_task_dir" "$initial_notification_id" \
        "$pane_identity" >/dev/null
    else
      tmux kill-pane -t "$pane_target" 2>/dev/null || true
      printf 'orphaned\n' > "$repo_task_dir/status"
      printf 'tmux failed to capture exact worker pane identity\n' > "$repo_task_dir/diagnostic"
      "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_task_dir" "$worktree_path" || true
      _die "tmux failed to capture exact worker pane identity for $rname"
    fi
    if ! _sgt_wait_worker_notification "$pane_target" "$repo_task_dir" "$initial_notification_id"; then
      tmux kill-pane -t "$pane_target" 2>/dev/null || true
      printf 'orphaned\n' > "$repo_task_dir/status"
      printf 'interactive worker did not acknowledge its durable notification\n' > "$repo_task_dir/diagnostic"
      "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_task_dir" "$worktree_path" || true
      _die "interactive worker notification acknowledgement timed out for $rname"
    fi
  else
    printf 'orphaned\n' > "$repo_task_dir/status"
    printf 'tmux failed to launch worker supervisor\n' > "$repo_task_dir/diagnostic"
    "$SCRIPT_DIR/sgt-td-memory" handoff "$repo_task_dir" "$worktree_path" || true
    _die "tmux failed to launch worker supervisor for $rname"
  fi

  echo ""
done

# ── Summary ───────────────────────────────────────────────────────────────────

if ! $DRY_RUN; then
  echo "=== dispatch complete ==="
  echo ""
  echo "Task ID: $TASK_ID"
  echo "Fleet:   $TASK_DIR"
  echo "Observe: tmux attach -t $TMUX_SESSION  (windows: <stage>-<repo>-$TASK_ID)"
  echo "Watch:   bin/sgt-watch $TASK_ID"
  echo ""

  # ── Wiki: log the dispatch event ─────────────────────────────────────────
  _wiki_body="## Dispatch

- **Task ID:** \`$TASK_ID\`
- **Project:** $PROJECT
- **Branch:** \`$BRANCH\`
- **Repos:** ${REPOS_ARG:-auto}
- **td task:** ${TD_TASK_ID:+\`$TD_TASK_ID\`}${TD_TASK_ID:-none}
- **Brief:** $BRIEF"

  _sgt_wiki_write \
    "sgt-dispatch: $BRIEF" \
    "activity" \
    "Dispatched $TASK_ID to project $PROJECT" \
    "sergeant,dispatch,$PROJECT" \
    "$_wiki_body"
fi
