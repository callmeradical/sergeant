#!/usr/bin/env bash
# sgt-context — Emit a structured agent context block for a project
#
# Reads the project YAML, resolves instruction layering (defaults → group → repo),
# and prints a block an agent can read at session start to orient itself.
#
# Usage: sgt-context <project>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=_sgt-lib.sh
source "$SCRIPT_DIR/_sgt-lib.sh"

[[ $# -ge 1 ]] || _die "Usage: sgt-context <project>"
PROJECT="$1"
CONFIG_FILE="$SERGEANT_CONFIG/$PROJECT.yaml"
[[ -f "$CONFIG_FILE" ]] || _die "Project not found: $PROJECT (looked for $CONFIG_FILE)"
_require_yq

# ── Header ──────────────────────────────────────────────────────────────────
name="$(yq '.name' "$CONFIG_FILE")"
desc="$(yq '.description // ""' "$CONFIG_FILE")"

echo "# Sergeant project context: $name"
echo "# Generated by: sgt-context $PROJECT"
echo "# Config: $CONFIG_FILE"
echo "# dev_root: $DEV_ROOT"
echo ""

if [[ -n "$desc" && "$desc" != "null" ]]; then
  echo "## Description"
  echo ""
  echo "$desc"
  echo ""
fi

# ── Defaults ────────────────────────────────────────────────────────────────
default_instructions="$(yq '.defaults.agent_instructions // ""' "$CONFIG_FILE")"

# ── Repos ───────────────────────────────────────────────────────────────────
echo "## Repositories"
echo ""

repo_count="$(yq '.repos | length' "$CONFIG_FILE")"

for ((i=0; i<repo_count; i++)); do
  repo_name="$(yq ".repos[$i].name" "$CONFIG_FILE")"
  raw_path="$(yq ".repos[$i].path" "$CONFIG_FILE")"
  path="$(_resolve_path "$raw_path")"
  group="$(yq ".repos[$i].group // \"\"" "$CONFIG_FILE")"
  role="$(yq ".repos[$i].role // \"\"" "$CONFIG_FILE")"
  repo_instructions="$(yq ".repos[$i].agent_instructions // \"\"" "$CONFIG_FILE")"

  echo "### $repo_name"
  echo ""
  echo "- **path:** \`$path\`"

  if [[ -n "$group" && "$group" != "null" ]]; then
    echo "- **group:** $group"
  fi

  if [[ -n "$role" && "$role" != "null" ]]; then
    echo "- **role:** $role"
  fi

  # Check clone status
  if [[ -d "$path/.git" ]]; then
    branch="$(git -C "$path" branch --show-current 2>/dev/null || echo "unknown")"
    echo "- **status:** cloned (branch: $branch)"
  elif [[ -d "$path" ]]; then
    echo "- **status:** directory exists (not a git repo)"
  else
    echo "- **status:** NOT CLONED"
  fi

  # Resolve instructions: defaults → group → repo
  effective_instructions=""

  if [[ -n "$default_instructions" && "$default_instructions" != "null" ]]; then
    effective_instructions="$default_instructions"
  fi

  if [[ -n "$group" && "$group" != "null" ]]; then
    group_instructions="$(yq ".groups.\"$group\".agent_instructions // \"\"" "$CONFIG_FILE")"
    if [[ -n "$group_instructions" && "$group_instructions" != "null" ]]; then
      if [[ -n "$effective_instructions" ]]; then
        effective_instructions="$effective_instructions
$group_instructions"
      else
        effective_instructions="$group_instructions"
      fi
    fi
  fi

  if [[ -n "$repo_instructions" && "$repo_instructions" != "null" ]]; then
    if [[ -n "$effective_instructions" ]]; then
      effective_instructions="$effective_instructions
$repo_instructions"
    else
      effective_instructions="$repo_instructions"
    fi
  fi

  if [[ -n "$effective_instructions" ]]; then
    echo ""
    echo "**Instructions:**"
    echo ""
    echo "$effective_instructions" | sed 's/^/> /'
  fi

  echo ""
done

# ── Groups ───────────────────────────────────────────────────────────────────
group_count="$(yq '.groups | length' "$CONFIG_FILE" 2>/dev/null || echo 0)"
if [[ "$group_count" -gt 0 && "$group_count" != "null" ]]; then
  echo "## Groups"
  echo ""
  yq '.groups | to_entries | .[] | "### " + .key + "\n" + (.value.description // "") + "\n"' "$CONFIG_FILE" 2>/dev/null || true
fi

# ── Graphify ─────────────────────────────────────────────────────────────────
graphify_raw="$(yq '.graphify.output // ""' "$CONFIG_FILE")"
if [[ -n "$graphify_raw" && "$graphify_raw" != "null" ]]; then
  graphify_output="$(_resolve_path "$graphify_raw")"
  echo "## Knowledge Graph"
  echo ""
  echo "- **output:** \`$graphify_output\`"

  include_groups="$(yq '.graphify.include_groups // []' "$CONFIG_FILE" 2>/dev/null || true)"
  if [[ -n "$include_groups" && "$include_groups" != "[]" ]]; then
    echo "- **graphed groups:** $include_groups"
  fi

  if [[ -f "$graphify_output/GRAPH_REPORT.md" ]]; then
    echo "- **graph:** available — read \`$graphify_output/GRAPH_REPORT.md\` for architecture overview"
  else
    echo "- **graph:** not yet built — run \`bin/sgt-graphify $PROJECT\` to build"
  fi

  echo ""
fi
