#!/usr/bin/env bash
# sgt-sync — Clone missing repos and pull existing ones for a project
# Usage: sgt-sync <project>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=_sgt-lib.sh
source "$SCRIPT_DIR/_sgt-lib.sh"

[[ $# -ge 1 ]] || _die "Usage: sgt-sync <project>"
PROJECT="$1"
CONFIG_FILE="$SERGEANT_CONFIG/$PROJECT.yaml"
[[ -f "$CONFIG_FILE" ]] || _die "Project not found: $PROJECT (looked for $CONFIG_FILE)"
_require_yq

echo "=== syncing $PROJECT ==="
echo ""

repo_count="$(yq '.repos | length' "$CONFIG_FILE")"

for ((i=0; i<repo_count; i++)); do
  name="$(yq ".repos[$i].name" "$CONFIG_FILE")"
  raw_path="$(yq ".repos[$i].path" "$CONFIG_FILE")"
  path="$(_resolve_path "$raw_path")"
  url="$(yq ".repos[$i].url // \"\"" "$CONFIG_FILE")"

  echo "--- $name ---"

  if [[ -d "$path/.git" ]]; then
    echo "  exists — pulling..."
    branch="$(git -C "$path" branch --show-current 2>/dev/null || echo "")"
    if [[ -n "$branch" ]]; then
      git -C "$path" pull --ff-only 2>&1 | sed 's/^/  /' || {
        echo "  WARNING: pull failed (diverged or no upstream). Skipping."
      }
    else
      echo "  WARNING: detached HEAD — skipping pull."
    fi
  elif [[ -d "$path" ]]; then
    echo "  WARNING: directory exists but is not a git repo. Skipping."
  elif [[ -n "$url" && "$url" != "null" ]]; then
    parent="$(dirname "$path")"
    mkdir -p "$parent"
    echo "  cloning from $url ..."
    git clone "$url" "$path" 2>&1 | sed 's/^/  /'
  else
    echo "  NOT CLONED and no url configured — skipping."
  fi

  echo ""
done

echo "Done."
