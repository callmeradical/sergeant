#!/usr/bin/env bash
# sgt-notify — Inject a worker update into the primary sergeant session.
#
# Called by workers for escalations and terminal outcomes. Prefers oc-inject
# which queues messages when the session is busy and injects without taking over
# the prompt bar. Falls back to raw tmux send-keys when not running inside OpenCode.
#
# Usage:
#   sgt-notify <task-id> "<message>"
#
# Examples:
#   sgt-notify fix-argocd-adopt-orphan-0bd2da "done: PR https://github.com/.../pull/217"
#   sgt-notify feat-api-design-123abc "needs_input [api]: choose pagination contract"
#   sgt-notify fix-flaky-test-456def "blocked [app]: fixture unavailable"
#   sgt-notify feat-gitops-post-promoti-5f5be4 "failed: helm lint error in values.yaml"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_sgt-lib.sh
source "$SCRIPT_DIR/_sgt-lib.sh"

[[ $# -ge 2 ]] || _die "Usage: sgt-notify <task-id> \"<message>\""

TASK_ID="$1"
MESSAGE="$2"
INJECT="Agent task $TASK_ID update: $MESSAGE"

TASK_DIR="$FLEET_DIR/$TASK_ID"
OC_INJECT_BIN="$SCRIPT_DIR/oc-inject"
OC_TARGET_FILE="$TASK_DIR/oc_target.json"

# ── Prefer oc-inject ─────────────────────────────────────────────────────────
# oc-inject writes to the OpenCode session directly via the plugin API:
#  - If session is idle → injects immediately as a new conversation turn
#  - If session is busy → queues the message, drains on next idle
#  - Never takes over the prompt bar
_notify_done=0
_notify_uncertain=0
if [[ -f "$OC_TARGET_FILE" ]]; then
  OC_PID=$(jq -r '.pid // empty' "$OC_TARGET_FILE" 2>/dev/null || true)
  OC_SESSION=$(jq -r '.sessionId // empty' "$OC_TARGET_FILE" 2>/dev/null || true)
  if [[ -n "$OC_PID" && -n "$OC_SESSION" ]]; then
    OC_COMMAND=""
    [[ ! -f "$OC_INJECT_BIN" ]] || OC_COMMAND="$OC_INJECT_BIN"
    if [[ -z "$OC_COMMAND" ]] && command -v oc-inject >/dev/null 2>&1; then
      OC_COMMAND="$(command -v oc-inject)"
    fi
    if [[ -n "$OC_COMMAND" ]]; then
      set +e
      "$OC_COMMAND" --pid "$OC_PID" "$INJECT" "$OC_SESSION"
      _inject_status=$?
      set -e
      if [[ "$_inject_status" -eq 0 ]]; then
        echo "sgt-notify: sent via oc-inject." >&2
        _notify_done=1
      elif [[ "$_inject_status" -eq 2 ]]; then
        echo "sgt-notify: oc-inject claimed delivery but acknowledgement is pending; not falling back." >&2
        _notify_done=1
        _notify_uncertain=1
      else
        echo "sgt-notify: coordinator OpenCode target unavailable — trying tmux." >&2
      fi
    fi
  fi
fi

# ── Fallback: tmux send-keys ─────────────────────────────────────────────────
if [[ "$_notify_done" -eq 0 ]]; then
  PRIMARY_PANE_FILE="$TASK_DIR/primary_pane"

  if [[ ! -f "$PRIMARY_PANE_FILE" ]]; then
    echo "sgt-notify: no primary_pane and no live oc-inject target — cannot notify" >&2
    exit 1
  fi

  PRIMARY_PANE="$(cat "$PRIMARY_PANE_FILE")"

  if [[ -z "$PRIMARY_PANE" ]]; then
    echo "sgt-notify: primary_pane file empty — cannot notify" >&2
    exit 1
  fi

  if ! tmux has-session -t "${PRIMARY_PANE%%.*}" 2>/dev/null; then
    echo "sgt-notify: tmux session gone — cannot notify" >&2
    exit 1
  fi

  echo "sgt-notify: injecting via tmux into pane $PRIMARY_PANE" >&2
  tmux send-keys -t "$PRIMARY_PANE" "$INJECT" Enter
  echo "sgt-notify: sent via tmux." >&2
fi

# ── Wiki: classify terminal outcomes separately from escalations ─────────────
case "$MESSAGE" in
  done*|failed*)
    _event="completion"
    _heading="Agent Completion"
    ;;
  needs_input*|blocked*)
    _event="escalation"
    _heading="Agent Escalation"
    ;;
  *)
    _event="update"
    _heading="Agent Update"
    ;;
esac
_pr_url=$(echo "$MESSAGE" | grep -oE 'https://github\.com/[^ ]+' | head -1 || true)
_wiki_body="## $_heading

- **Task ID:** \`$TASK_ID\`
- **Event:** $_event
- **Result:** $MESSAGE
- **PR:** ${_pr_url:+[$_pr_url]($_pr_url)}${_pr_url:-none}"

_sgt_wiki_write \
  "sgt-notify: $TASK_ID $_event" \
  "activity" \
  "Agent $TASK_ID: $MESSAGE" \
  "sergeant,notify,$TASK_ID" \
  "$_wiki_body"

[[ "$_notify_uncertain" -eq 0 ]] || exit 2
