#!/usr/bin/env bash
# sgt-td-create — Create td tasks in project repos for a cross-repo brief
#
# Creates one td task per specified repo, with a shared title and per-repo
# description. Returns the created task IDs so sgt-dispatch can use them.
#
# Usage:
#   sgt-td-create <project> "<title>" --repos repo1,repo2 [options]
#
# Options:
#   --repos repo1,repo2,...   Repos to create tasks in (required)
#   --description "<text>"    Shared description for all tasks
#   --type <type>             Task type: bug|feature|task|chore (default: task)
#   --priority <P0-P4>        Priority (default: P1)
#   --parent <id>             Parent epic ID (applies to all tasks)
#   --json                    Output created task IDs as JSON
#
# Output (default): one line per repo: "<repo>  <task-id>  <title>"
# Output (--json):  array of {repo, task_id, title, work_dir}
#
# Example:
#   ids=$(sgt-td-create smith "feat: add OAuth" --repos smith,smith-app --json)
#   # then pass each id to sgt-dispatch --td

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_sgt-lib.sh"

_require_td() {
  command -v td &>/dev/null || _die "td is required."
}

[[ $# -ge 2 ]] || _die "Usage: sgt-td-create <project> \"<title>\" --repos <list> [options]"
PROJECT="$1"; shift
TITLE="$1";   shift

CONFIG_FILE="$SERGEANT_CONFIG/$PROJECT.yaml"
[[ -f "$CONFIG_FILE" ]] || _die "Project not found: $PROJECT"
_require_yq
_require_td

REPOS_ARG=""
DESCRIPTION=""
TASK_TYPE="task"
PRIORITY="P1"
PARENT=""
JSON_OUT=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repos)       REPOS_ARG="$2";    shift 2 ;;
    --description) DESCRIPTION="$2";  shift 2 ;;
    --type)        TASK_TYPE="$2";    shift 2 ;;
    --priority)    PRIORITY="$2";     shift 2 ;;
    --parent)      PARENT="$2";       shift 2 ;;
    --json)        JSON_OUT=true;     shift   ;;
    *) _die "Unknown option: $1" ;;
  esac
done

[[ -n "$REPOS_ARG" ]] || _die "Must specify --repos"

TARGET_REPOS=()
IFS=',' read -ra TARGET_REPOS <<< "$REPOS_ARG"

repo_count="$(yq '.repos | length' "$CONFIG_FILE")"

for rname in "${TARGET_REPOS[@]}"; do
  found=false
  for ((i=0; i<repo_count; i++)); do
    n="$(yq ".repos[$i].name" "$CONFIG_FILE")"
    [[ "$n" == "$rname" ]] && found=true && break
  done
  $found || _die "Repo '$rname' not found in project $PROJECT"
done

STATE_FILE="${SGT_TD_STATE_FILE:-$(mktemp)}"
OWN_STATE_FILE=false
[[ -z "${SGT_TD_STATE_FILE:-}" ]] && OWN_STATE_FILE=true
: > "$STATE_FILE"

CREATE_STDERR_FILE="$(mktemp)"
trap 'rm -f "$CREATE_STDERR_FILE"; $OWN_STATE_FILE && rm -f "$STATE_FILE"' EXIT

_record_created() {
  python3 - "$STATE_FILE" "$1" "$2" "$TITLE" "$3" <<'PY'
import json
import sys

path, repo, task_id, title, work_dir = sys.argv[1:]
with open(path, "a", encoding="utf-8") as handle:
    handle.write(json.dumps({
        "repo": repo,
        "task_id": task_id,
        "title": title,
        "work_dir": work_dir,
    }))
    handle.write("\n")
PY
}

_emit_results() {
  if $JSON_OUT; then
    python3 - "$STATE_FILE" <<'PY'
import json
import sys

path = sys.argv[1]
items = []
with open(path, encoding="utf-8") as handle:
    for line in handle:
        line = line.strip()
        if line:
            items.append(json.loads(line))
print(json.dumps(items))
PY
  else
    python3 - "$STATE_FILE" <<'PY'
import json
import sys

path = sys.argv[1]
with open(path, encoding="utf-8") as handle:
    for line in handle:
        line = line.strip()
        if not line:
            continue
        item = json.loads(line)
        print(f"{item['repo']:<20}  {item['task_id']}  {item['title']}")
PY
  fi
}

_rollback_or_die() {
  local message="$1"
  local cleanup_failed=false
  local cleanup_output=""

  while IFS=$'\t' read -r repo_name task_id work_dir; do
    [[ -n "$task_id" ]] || continue
    if ! delete_output="$(td delete "$task_id" --work-dir "$work_dir" --force --json 2>&1)"; then
      cleanup_failed=true
      if [[ -n "$cleanup_output" ]]; then
        cleanup_output+=$'\n'
      fi
      if [[ -n "$delete_output" ]]; then
        cleanup_output+="cleanup failed for $task_id in $repo_name: $delete_output"
      else
        cleanup_output+="cleanup failed for $task_id in $repo_name"
      fi
    fi
  done < <(
    python3 - "$STATE_FILE" <<'PY'
import json
import sys

path = sys.argv[1]
with open(path, encoding="utf-8") as handle:
    for line in handle:
        line = line.strip()
        if not line:
            continue
        item = json.loads(line)
        print("\t".join([item["repo"], item["task_id"], item["work_dir"]]))
PY
  )

  if $cleanup_failed; then
    printf '%s\n%s\n' "$message" "$cleanup_output" >&2
  else
    printf '%s\n' "$message" >&2
  fi
  exit 1
}

for rname in "${TARGET_REPOS[@]}"; do
  for ((i=0; i<repo_count; i++)); do
    n="$(yq ".repos[$i].name" "$CONFIG_FILE")"
    [[ "$n" == "$rname" ]] && break
  done

  raw_path="$(yq ".repos[$i].path" "$CONFIG_FILE")"
  repo_path="$(_resolve_path "$raw_path")"

  [[ -d "$repo_path/.git" ]] || _rollback_or_die "repo '$rname' is not cloned at $repo_path"

  td list --json --work-dir "$repo_path" --limit 1 &>/dev/null || \
    _rollback_or_die "td is not initialized in repo '$rname' ($repo_path)"

  repo_role="$(yq ".repos[$i].role // \"\"" "$CONFIG_FILE")"
  full_desc="${DESCRIPTION}"
  if [[ -n "$repo_role" && "$repo_role" != "null" ]]; then
    if [[ -n "$full_desc" ]]; then
      full_desc="$full_desc

Repo role: $repo_role"
    else
      full_desc="Repo role: $repo_role"
    fi
  fi

  td_args=(
    create "$TITLE"
    --type "$TASK_TYPE"
    --priority "$PRIORITY"
    --work-dir "$repo_path"
    --json
  )
  [[ -n "$full_desc" ]] && td_args+=(--description "$full_desc")
  [[ -n "$PARENT"    ]] && td_args+=(--parent "$PARENT")

  : > "$CREATE_STDERR_FILE"
  if ! result="$(td "${td_args[@]}" 2>"$CREATE_STDERR_FILE")"; then
    create_error="$(cat "$CREATE_STDERR_FILE")"
    [[ -n "$create_error" ]] || create_error="td create failed for $rname"
    _rollback_or_die "$create_error"
  fi

  task_id="$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])" 2>/dev/null)"
  [[ -n "$task_id" ]] || _rollback_or_die "td create returned invalid JSON for $rname"

  _record_created "$rname" "$task_id" "$repo_path"
done

_emit_results
