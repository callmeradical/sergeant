#!/usr/bin/env bash
# sgt-validation-worker - Run coordinator-owned no-mistakes in an interactive pane.

set -uo pipefail

[[ $# -ge 3 && $# -le 4 ]] || {
  echo "Usage: sgt-validation-worker <repo-state-dir> <worktree> <intent-revision> [skip]" >&2
  exit 2
}

REPO_STATE="$1"
WORKTREE="$2"
EXPECTED_REVISION="$3"
SKIP="${4:-}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_sgt-intent.sh
source "$SCRIPT_DIR/_sgt-intent.sh"
# shellcheck source=bin/_sgt-lib.sh
source "$SCRIPT_DIR/_sgt-lib.sh"

[[ -d "$REPO_STATE" && -d "$WORKTREE" ]] || {
  echo "ERROR: validation state or worktree unavailable" >&2
  exit 2
}
[[ -t 0 && -t 1 ]] || {
  echo "ERROR: validation worker requires a terminal" >&2
  exit 2
}
VALIDATION_INTENT="$REPO_STATE/validation-intent.md"
[[ -f "$VALIDATION_INTENT" ]] || {
  echo "ERROR: canonical validation intent unavailable" >&2
  exit 2
}
[[ "$(_sgt_intent_revision "$VALIDATION_INTENT")" == "$EXPECTED_REVISION" ]] || {
  echo "ERROR: canonical validation intent revision mismatch" >&2
  exit 2
}
command -v no-mistakes >/dev/null 2>&1 || {
  echo "ERROR: no-mistakes is required" >&2
  exit 2
}

_lock_field() {
  local key="$1"
  awk -F= -v key="$key" '
    $1 == key { count++; value = substr($0, length(key) + 2) }
    END { if (count == 1 && value != "") print value; else exit 1 }
  ' "$REPO_STATE/validation-launch.lock"
}
_coordinator_is_alive() {
  local pid start current
  [[ -f "$REPO_STATE/validation-launch.lock" && \
    ! -L "$REPO_STATE/validation-launch.lock" ]] || return 1
  pid="$(_lock_field pid)" || return 1
  start="$(_lock_field start)" || return 1
  [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null || return 1
  current="$(ps -o lstart= -p "$pid" 2>/dev/null | awk '{$1=$1; print}')"
  [[ -n "$current" && "$current" == "$start" ]]
}
_publish_handshake() {
  local path="$1" value="$2" temporary
  temporary="${path}.tmp.$$"
  (umask 077; set -C; printf '%s\n' "$value" > "$temporary") 2>/dev/null || return 1
  ln "$temporary" "$path" 2>/dev/null || return 1
  rm -f "$temporary"
}

[[ -n "${TMUX_PANE:-}" ]] || {
  echo "ERROR: validation pane identity unavailable" >&2
  exit 2
}
CHILD_PID="$$"
CHILD_START="$(ps -o lstart= -p "$CHILD_PID" 2>/dev/null | awk '{$1=$1; print}')"
[[ -n "$CHILD_START" ]] || exit 2
HANDSHAKE="$EXPECTED_REVISION|$TMUX_PANE|$CHILD_PID|$CHILD_START"
_coordinator_is_alive || {
  echo "ERROR: validation coordinator unavailable" >&2
  exit 2
}
_publish_handshake "$REPO_STATE/validation-child-ready" "$HANDSHAKE" || exit 2

while [[ ! -f "$REPO_STATE/validation-release" ]]; do
  _coordinator_is_alive || {
    echo "ERROR: validation coordinator exited before release" >&2
    exit 2
  }
  sleep 0.05
done
_coordinator_is_alive || exit 2
[[ -f "$REPO_STATE/validation-release-owner" && \
  ! -L "$REPO_STATE/validation-release-owner" && \
  "$REPO_STATE/validation-release" -ef "$REPO_STATE/validation-release-owner" && \
  "$(_sgt_read_owned_file "$REPO_STATE/validation-release" 2>/dev/null || true)" == \
  "$HANDSHAKE" && \
  "$(_sgt_read_owned_file "$REPO_STATE/validation-release-owner" 2>/dev/null || true)" == \
  "$HANDSHAKE" ]] || {
  echo "ERROR: validation release revision mismatch" >&2
  exit 2
}
if [[ -z "${TMUX_PANE:-}" ]] || \
   ! _sgt_pane_identity_matches "$TMUX_PANE" "$REPO_STATE" validation_pane_identity; then
    echo "ERROR: validation pane identity does not match coordinator state" >&2
    exit 2
fi
EXPECTED_HEAD="$(cat "$REPO_STATE/validation_head" 2>/dev/null || true)"
if [[ -z "$EXPECTED_HEAD" || \
      "$(git -C "$WORKTREE" rev-parse HEAD 2>/dev/null || true)" != "$EXPECTED_HEAD" ]] || \
   ! _sgt_worktree_is_validation_clean "$WORKTREE"; then
    echo "ERROR: isolated validation code snapshot no longer matches reviewed HEAD" >&2
    exit 2
fi

_publish_handshake "$REPO_STATE/validation-child-accepted" "$HANDSHAKE" || exit 2
while [[ ! -f "$REPO_STATE/validation-child-commit" ]]; do
  _coordinator_is_alive || {
    echo "ERROR: validation coordinator exited before commit" >&2
    exit 2
  }
  sleep 0.05
done
[[ ! -L "$REPO_STATE/validation-child-commit" && \
  "$(cat "$REPO_STATE/validation-child-commit")" == "$HANDSHAKE" ]] || exit 2
_coordinator_is_alive || exit 2
[[ -z "${SGT_VALIDATION_COMMIT_ACK_DELAY:-}" ]] || \
  sleep "$SGT_VALIDATION_COMMIT_ACK_DELAY"
_coordinator_is_alive || exit 2
_publish_handshake "$REPO_STATE/validation-child-committed" "$HANDSHAKE" || exit 2
while [[ ! -f "$REPO_STATE/validation-success" ]]; do
  _coordinator_is_alive || {
    echo "ERROR: validation coordinator exited before success" >&2
    exit 2
  }
  sleep 0.05
done
[[ ! -L "$REPO_STATE/validation-success" && \
  "$(cat "$REPO_STATE/validation-success")" == "$HANDSHAKE" ]] || exit 2
[[ -z "${SGT_VALIDATION_SUCCESS_ACK_DELAY:-}" ]] || \
  sleep "$SGT_VALIDATION_SUCCESS_ACK_DELAY"
_coordinator_is_alive || exit 2
_publish_handshake "$REPO_STATE/validation-success-ack" "$HANDSHAKE" || exit 2
while [[ -e "$REPO_STATE/validation-launch.lock" || \
  -L "$REPO_STATE/validation-launch.lock" ]]; do
  if ! _coordinator_is_alive; then
    [[ ! -e "$REPO_STATE/validation-launch.lock" && \
      ! -L "$REPO_STATE/validation-launch.lock" ]] && break
    exit 2
  fi
  sleep 0.05
done

printf 'running\n' > "$REPO_STATE/validation_status"
cd "$WORKTREE" || exit 2
args=(axi run --intent "$(cat "$VALIDATION_INTENT")")
[[ -z "$SKIP" ]] || args+=(--skip "$SKIP")
no-mistakes "${args[@]}"
status=$?
printf 'exited:%s\n' "$status" > "$REPO_STATE/validation_status"
exit "$status"
