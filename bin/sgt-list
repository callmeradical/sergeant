#!/usr/bin/env bash
# sgt-list — List all known sergeant projects from ~/.config/sergeant/
# Usage: sgt-list

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=_sgt-lib.sh
source "$SCRIPT_DIR/_sgt-lib.sh"

if [[ ! -d "$SERGEANT_CONFIG" ]]; then
  echo "No sergeant config directory found at $SERGEANT_CONFIG" >&2
  echo "Create it and add project YAML files to get started." >&2
  exit 1
fi

# Collect project YAMLs (exclude config.yaml and other non-project files)
found=0
for f in "$SERGEANT_CONFIG"/*.yaml; do
  [[ -e "$f" ]] || continue
  name="$(basename "$f" .yaml)"
  [[ "$name" == "config" ]] && continue  # skip global config

  found=$((found+1))
  if command -v yq &>/dev/null; then
    desc="$(yq '.description // ""' "$f" 2>/dev/null | tr -d '\n')"
  else
    desc=""
  fi
  if [[ -n "$desc" && "$desc" != "null" ]]; then
    printf "%-20s  %s\n" "$name" "$desc"
  else
    printf "%s\n" "$name"
  fi
done

if [[ $found -eq 0 ]]; then
  echo "No projects found in $SERGEANT_CONFIG" >&2
  echo "Create a project YAML to get started. See schema/project.yaml.example" >&2
  exit 1
fi
