#!/usr/bin/env bash
# sgt-cleanup — Remove worktrees and fleet state for a completed task
#
# Handles both treehouse-leased worktrees (treehouse return) and
# plain git worktrees (git worktree remove).
#
# task-id must be the fleet-owned task directory basename. Cleanup rejects
# paths, traversal tokens, and symlink aliases before touching fleet state.
#
# Usage:
#   sgt-cleanup <task-id>           # remove all worktrees + fleet state
#   sgt-cleanup <task-id> <repo>    # remove one repo's worktree only

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=_sgt-lib.sh
source "$SCRIPT_DIR/_sgt-lib.sh"

[[ $# -ge 1 ]] || _die "Usage: sgt-cleanup <task-id> [repo]"
TASK_ID="$1"
FILTER_REPO="${2:-}"

case "$TASK_ID" in
  ""|"."|".."|/*|*/*)
    _die "Invalid task ID: $TASK_ID"
    ;;
esac

TASK_DIR="$FLEET_DIR/$TASK_ID"

[[ ! -L "$TASK_DIR" ]] || _die "Invalid task ID: $TASK_ID"

if [[ ! -d "$TASK_DIR" ]]; then
  echo "Task already cleaned up: $TASK_ID"
  exit 0
fi

FLEET_ROOT="$(cd "$FLEET_DIR" && pwd -P)"
TASK_ROOT="$(cd "$TASK_DIR" && pwd -P)"
[[ "$TASK_ROOT" == "$FLEET_ROOT/$TASK_ID" ]] || _die "Invalid task ID: $TASK_ID"

_worktree_cwd_pids() {
  local worktree="$1"
  local canonical_worktree current_pid error error_file line output path process_pids

  [[ -d "$worktree" ]] || return 0
  canonical_worktree="$(cd "$worktree" && pwd -P)"
  command -v lsof >/dev/null 2>&1 || _die "lsof is required to verify worktree process cleanup"
  process_pids="$(ps -axo pid= | tr -d ' ' || true)"
  [[ -n "$process_pids" ]] || return 0
  error_file="$(mktemp)"
  output="$(lsof -w -S2 -a -d cwd -Fn \
    -p "$(tr '\n' ',' <<< "$process_pids" | sed 's/,$//')" 2> "$error_file" || true)"
  if [[ -s "$error_file" ]]; then
    error="$(cat "$error_file")"
    rm -f "$error_file"
    _die "Failed to inspect process working directories: $error"
  fi
  rm -f "$error_file"
  current_pid=""

  while IFS= read -r line; do
    case "$line" in
      p*)
        current_pid="${line#p}"
        ;;
      n*)
        path="${line#n}"
        if [[ "$path" == "$canonical_worktree" || "$path" == "$canonical_worktree/"* ]]; then
          printf '%s\n' "$current_pid"
        fi
        ;;
    esac
  done <<< "$output"
}

_process_tree_records() {
  local root_pid="$1"
  local child_pid identity

  for child_pid in $(pgrep -P "$root_pid" 2>/dev/null || true); do
    _process_tree_records "$child_pid"
  done
  identity="$(ps -o lstart= -p "$root_pid" 2>/dev/null | sed 's/^ *//;s/ *$//' || true)"
  [[ -n "$identity" ]] && printf '%s|%s\n' "$root_pid" "$identity"
}

_recorded_tree_pids() {
  local records="$1"
  local identity pid

  while IFS='|' read -r pid identity; do
    [[ -n "$pid" ]] && printf '%s\n' "$pid"
  done <<< "$records"
}

_live_recorded_tree_pids() {
  local records="$1"
  local current_identity identity pid

  while IFS='|' read -r pid identity; do
    [[ -n "$pid" && -n "$identity" ]] || continue
    current_identity="$(ps -o lstart= -p "$pid" 2>/dev/null | sed 's/^ *//;s/ *$//' || true)"
    [[ "$current_identity" == "$identity" ]] && printf '%s\n' "$pid"
  done <<< "$records"
}

_terminate_pids() {
  local pids="$1"
  local signal="${2:-TERM}"
  local pid

  [[ -n "$pids" ]] || return 0
  while IFS= read -r pid; do
    [[ -n "$pid" && "$pid" != "$$" ]] || continue
    kill -"$signal" "$pid" 2>/dev/null || true
  done <<< "$pids"
}

_process_group_pids() {
  local process_group="$1"

  [[ -n "$process_group" ]] || return 0
  pgrep -g "$process_group" 2>/dev/null || true
}

_terminate_process_group() {
  local process_group="$1"
  local signal="${2:-TERM}"

  [[ -n "$process_group" ]] || return 0
  kill -"$signal" -- -"$process_group" 2>/dev/null || true
}

_stop_local_worker() {
  local repo_dir="$1"
  local worktree="$2"
  local pane pane_info pane_dead pane_pid pane_pgid pane_command tree_records tree_pids live_tree_pids cwd_pids

  pane="$(cat "$repo_dir/pane" 2>/dev/null || true)"
  tree_records=""
  tree_pids=""

  if [[ -n "$pane" ]]; then
    command -v tmux >/dev/null 2>&1 || _die "tmux is required to terminate recorded worker pane $pane"
    pane_info="$(tmux display-message -p -t "$pane" \
      '#{pane_dead}|#{pane_pid}|#{pane_start_command}' 2>/dev/null || true)"

    if [[ -n "$pane_info" ]]; then
      pane_dead="${pane_info%%|*}"
      pane_info="${pane_info#*|}"
      pane_pid="${pane_info%%|*}"
      pane_command="${pane_info#*|}"

      if [[ "$pane_dead" != "0" ]]; then
        echo "  worker pane already stopped: $pane"
      elif [[ "$pane_command" != *sgt-worker* || "$pane_command" != *"$repo_dir"* ]]; then
        echo "  recorded pane no longer belongs to this worker: $pane"
      else
        tree_records="$(_process_tree_records "$pane_pid")"
        tree_pids="$(_recorded_tree_pids "$tree_records")"
        pane_pgid="$(ps -o pgid= -p "$pane_pid" 2>/dev/null | tr -d ' ' || true)"
        echo "  terminating worker pane: $pane"
        tmux kill-pane -t "$pane" 2>/dev/null || \
          ! tmux display-message -p -t "$pane" '#{pane_id}' >/dev/null 2>&1 || \
          _die "Failed to terminate worker pane $pane"
      fi
    else
      echo "  worker pane already gone: $pane"
    fi
  fi

  _terminate_pids "$tree_pids"
  _terminate_process_group "${pane_pgid:-}"

  for _ in $(seq 1 50); do
    live_tree_pids="$(printf '%s\n%s\n' \
      "$(_process_group_pids "${pane_pgid:-}")" \
      "$(_live_recorded_tree_pids "$tree_records")" | sed '/^$/d' | sort -u)"
    [[ -z "$live_tree_pids" ]] && break
    sleep 0.1
  done

  if [[ -n "$live_tree_pids" ]]; then
    _terminate_process_group "${pane_pgid:-}" KILL
    _terminate_pids "$(_live_recorded_tree_pids "$tree_records")" KILL
    for _ in $(seq 1 20); do
      live_tree_pids="$(printf '%s\n%s\n' \
        "$(_process_group_pids "${pane_pgid:-}")" \
        "$(_live_recorded_tree_pids "$tree_records")" | sed '/^$/d' | sort -u)"
      [[ -z "$live_tree_pids" ]] && break
      sleep 0.1
    done
  fi

  [[ -z "$live_tree_pids" ]] || \
    _die "Worker processes did not terminate: $(tr '\n' ' ' <<< "$live_tree_pids")"
  cwd_pids="$(_worktree_cwd_pids "$worktree")"
  [[ -z "$cwd_pids" ]] || \
    _die "Other processes still have $worktree as their current directory: $(tr '\n' ' ' <<< "$cwd_pids")"
}

_require_terminal_repos() {
  local cleanup_phase evidence_dir partial_phase removing_phase repo_dir repo_name \
    retry_root retry_type status worktree worktree_status wt_type

  for repo_dir in "$TASK_DIR"/*/; do
    [[ -d "$repo_dir" ]] || continue
    repo_dir="${repo_dir%/}"
    repo_name="$(basename "$repo_dir")"
    if [[ -n "$FILTER_REPO" && "$repo_name" != "$FILTER_REPO" ]]; then
      continue
    fi

    status="$(tr -d '\n' < "$repo_dir/status" 2>/dev/null || echo unknown)"
    case "$status" in
      done)
        [[ -s "$repo_dir/result" ]] || \
          _die "$repo_name is not safely terminal: done requires a reconciled result"
        ;;
      failed:\ *[![:space:]]) ;;
      *) _die "$repo_name is not terminal: $status" ;;
    esac

    worktree="$(cat "$repo_dir/worktree" 2>/dev/null || true)"
    wt_type="$(cat "$repo_dir/wt_type" 2>/dev/null || echo git)"
    cleanup_phase="$(cat "$repo_dir/cleanup-phase" 2>/dev/null || true)"
    retry_type="$(sed -n '3p' "$repo_dir/cleanup-phase" 2>/dev/null || true)"
    retry_root="$(sed -n '4p' "$repo_dir/cleanup-phase" 2>/dev/null || true)"
    partial_phase="$(printf 'partial-removal\n%s\n%s\n%s\n' \
      "$worktree" "$retry_type" "$retry_root")"
    removing_phase="$(printf 'removing\n%s\n%s\n%s\n' \
      "$worktree" "$retry_type" "$retry_root")"
    if [[ -n "$worktree" && -d "$worktree" ]]; then
      if [[ "$cleanup_phase" == $'removing\n'"$worktree" || \
        "$cleanup_phase" == "$removing_phase" ]]; then
        _restore_worker_evidence "$repo_dir" "$worktree"
      fi
      [[ -f "$worktree/.sergeant-status" ]] || \
        _die "$repo_name worktree terminal proof is missing"
      worktree_status="$(tr -d '\n' < "$worktree/.sergeant-status")"
      [[ "$worktree_status" == "$status" ]] || \
        _die "$repo_name is not reconciled: fleet status $status differs from worktree status $worktree_status"
      if [[ "$status" == "done" ]]; then
        [[ -s "$worktree/.sergeant-result" ]] || \
          _die "$repo_name worktree is not safely terminal: done requires a result"
        cmp -s "$repo_dir/result" "$worktree/.sergeant-result" || \
          _die "$repo_name worktree result differs from reconciled fleet result"
      fi
    else
      [[ -n "$worktree" && ( \
        "$cleanup_phase" == $'removing\n'"$worktree" || \
        ( ( "$cleanup_phase" == "$partial_phase" || \
            "$cleanup_phase" == "$removing_phase" ) && \
          "$retry_type" == "$wt_type" && \
          ( "$retry_type" == git || "$retry_type" == treehouse ) && \
          -n "$retry_root" ) || \
        "$cleanup_phase" == $'reconciled-absent\n'"$worktree" \
      ) ]] || \
        _die "$repo_name has no reconciled cleanup phase for its absent worktree"

      evidence_dir="$repo_dir/terminal-evidence"
      [[ -f "$evidence_dir/.sergeant-status" ]] || \
        _die "$repo_name reconciled cleanup evidence is missing"
      worktree_status="$(tr -d '\n' < "$evidence_dir/.sergeant-status")"
      [[ "$worktree_status" == "$status" ]] || \
        _die "$repo_name cleanup evidence differs from reconciled fleet status"
      if [[ "$status" == "done" ]]; then
        [[ -s "$evidence_dir/.sergeant-result" ]] || \
          _die "$repo_name reconciled cleanup evidence requires a result"
        cmp -s "$repo_dir/result" "$evidence_dir/.sergeant-result" || \
          _die "$repo_name cleanup evidence differs from reconciled fleet result"
      fi
      if [[ "$cleanup_phase" == $'removing\n'"$worktree" ]]; then
        _record_cleanup_phase "$repo_dir" reconciled-absent "$worktree" || \
          _die "Failed to reconcile completed worktree removal: $repo_name"
      fi
    fi
  done
}

_require_clean_worktrees() {
  local changes repo_dir repo_name worktree

  for repo_dir in "$TASK_DIR"/*/; do
    [[ -d "$repo_dir" ]] || continue
    repo_dir="${repo_dir%/}"
    repo_name="$(basename "$repo_dir")"
    if [[ -n "$FILTER_REPO" && "$repo_name" != "$FILTER_REPO" ]]; then
      continue
    fi

    worktree="$(cat "$repo_dir/worktree" 2>/dev/null || true)"
    [[ -n "$worktree" && -d "$worktree" ]] || continue
    git -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1 || \
      _die "Cannot verify $repo_name worktree before cleanup: $worktree"
    changes="$(git -C "$worktree" status --porcelain --untracked-files=all -- \
      . ':(exclude).sergeant-*')" || \
      _die "Cannot inspect $repo_name worktree before cleanup: $worktree"
    [[ -z "$changes" ]] || \
      _die "$repo_name worktree has uncommitted changes; cleanup refused"
  done
}

_stage_worker_evidence() {
  local evidence evidence_dir repo_dir="$1" worktree="$2"

  evidence_dir="$repo_dir/terminal-evidence"
  for evidence in "$worktree"/.sergeant-*; do
    [[ -f "$evidence" ]] || continue
    mkdir -p "$evidence_dir"
    cp -p "$evidence" "$evidence_dir/" || \
      _die "Failed to preserve worker evidence before cleanup: $evidence"
  done
}

_remove_worker_evidence() {
  local evidence worktree="$1"

  for evidence in "$worktree"/.sergeant-*; do
    [[ -f "$evidence" ]] || continue
    rm -f "$evidence" || \
      _die "Failed to remove staged worker evidence before cleanup: $evidence"
  done
}

_restore_worker_evidence() {
  local evidence evidence_dir="$1/terminal-evidence" worktree="$2"

  [[ -d "$worktree" && -d "$evidence_dir" ]] || return 0
  for evidence in "$evidence_dir"/.sergeant-*; do
    [[ -f "$evidence" ]] || continue
    cp -p "$evidence" "$worktree/" || \
      _die "Failed to restore worker evidence after cleanup failure: $evidence"
  done
}

_record_cleanup_phase() {
  local repo_dir="$1" phase="$2" worktree="$3"
  shift 3

  {
    printf '%s\n%s\n' "$phase" "$worktree"
    [[ $# -eq 0 ]] || printf '%s\n' "$@"
  } > "$repo_dir/cleanup-phase.tmp" &&
    mv "$repo_dir/cleanup-phase.tmp" "$repo_dir/cleanup-phase"
}

_repo_identity() {
  local remote roots repo_root="$1"

  roots="$(git -C "$repo_root" rev-list --max-parents=0 --all 2>/dev/null | sort)"
  [[ -n "$roots" ]] || return 1
  remote="$(git -C "$repo_root" config --get remote.origin.url 2>/dev/null || true)"
  printf '%s\n%s\n' "$remote" "$roots" | git hash-object --stdin
}

_record_cleanup_owner() {
  local holder identity repo_dir="$1" repo_root="$2" worktree="$3" wt_type="$4"

  identity="$(_repo_identity "$repo_root")" || return 1
  holder=""
  [[ "$wt_type" != "treehouse" ]] || \
    holder="$(tr -d '\n' < "$repo_dir/wt_holder" 2>/dev/null || true)"
  printf '1\n%s\n%s\n%s\n%s\n%s\n' \
    "$repo_root" "$worktree" "$wt_type" "$identity" "$holder" \
    > "$repo_dir/cleanup-owner.tmp" &&
    mv "$repo_dir/cleanup-owner.tmp" "$repo_dir/cleanup-owner"
}

_validate_retry_owner() {
  local config_file configured_root expected_holder expected_root holder i identity \
    owner_holder owner_identity owner_root owner_type owner_worktree project raw_path repo_count \
    repo_dir="$1" repo_name="$2" worktree="$3" retry_type="$4" retry_root="$5"

  [[ "$(sed -n '1p' "$repo_dir/cleanup-owner" 2>/dev/null || true)" == "1" ]] || \
    _die "Retry owner identity is missing: $repo_name"
  owner_root="$(sed -n '2p' "$repo_dir/cleanup-owner")"
  owner_worktree="$(sed -n '3p' "$repo_dir/cleanup-owner")"
  owner_type="$(sed -n '4p' "$repo_dir/cleanup-owner")"
  owner_identity="$(sed -n '5p' "$repo_dir/cleanup-owner")"
  owner_holder="$(sed -n '6p' "$repo_dir/cleanup-owner")"
  [[ "$retry_root" == "$owner_root" && "$worktree" == "$owner_worktree" && \
    "$retry_type" == "$owner_type" ]] || \
    _die "Retry cleanup state does not match its recorded owner: $repo_name"

  project="$(sed -n 's/^Project:[[:space:]]*//p' "$TASK_DIR/brief.md" 2>/dev/null || true)"
  [[ -n "$project" && "$project" != *$'\n'* && "$project" != */* ]] || \
    _die "Cannot resolve retry owner project: $repo_name"
  config_file="$SERGEANT_CONFIG/$project.yaml"
  [[ -f "$config_file" && ! -L "$config_file" ]] || \
    _die "Cannot resolve retry owner project config: $project"

  _require_yq
  repo_count="$(yq '.repos | length' "$config_file")"
  raw_path=""
  for ((i=0; i<repo_count; i++)); do
    if [[ "$(yq ".repos[$i].name" "$config_file")" == "$repo_name" ]]; then
      [[ -z "$raw_path" ]] || _die "Retry owner repo is ambiguous: $repo_name"
      raw_path="$(yq ".repos[$i].path" "$config_file")"
    fi
  done
  [[ -n "$raw_path" && "$raw_path" != "null" ]] || \
    _die "Cannot resolve retry owner repo: $repo_name"

  configured_root="$(_resolve_path "$raw_path")"
  [[ -d "$configured_root" && ! -L "$configured_root" ]] || \
    _die "Retry owner repo is missing or aliased: $configured_root"
  expected_root="$(cd "$configured_root" && pwd -P)"
  [[ "$configured_root" == "$expected_root" ]] || \
    _die "Retry owner repo is symlink-aliased: $configured_root"
  [[ "$retry_root" == "$expected_root" && ! -L "$retry_root" ]] || \
    _die "Retry owner repo does not match persisted cleanup root: $repo_name"
  identity="$(_repo_identity "$expected_root")" || \
    _die "Cannot identify retry owner repo: $repo_name"
  [[ "$identity" == "$owner_identity" ]] || \
    _die "Retry owner repo identity changed: $repo_name"

  if [[ "$retry_type" == "treehouse" ]]; then
    expected_holder="sgt-${TASK_ID}-${repo_name}"
    holder="$(tr -d '\n' < "$repo_dir/wt_holder" 2>/dev/null || true)"
    [[ "$holder" == "$expected_holder" && "$owner_holder" == "$expected_holder" ]] || \
      _die "Retry treehouse lease does not match its owner: $repo_name"
  fi
}

_require_terminal_repos
_require_clean_worktrees

echo "=== sgt-cleanup: $TASK_ID ==="
echo ""

for repo_dir in "$TASK_DIR"/*/; do
  [[ -d "$repo_dir" ]] || continue
  repo_dir="${repo_dir%/}"
  repo_name="$(basename "$repo_dir")"

  if [[ -n "$FILTER_REPO" && "$repo_name" != "$FILTER_REPO" ]]; then
    continue
  fi

  worktree="$(cat "$repo_dir/worktree" 2>/dev/null || echo "")"
  status="$(cat "$repo_dir/status" 2>/dev/null || echo "unknown")"
  wt_type="$(cat "$repo_dir/wt_type" 2>/dev/null || echo "git")"

  echo "--- $repo_name (status: $status, type: $wt_type) ---"

  _stop_local_worker "$repo_dir" "$worktree"

  cwd_pids="$(_worktree_cwd_pids "$worktree")"
  [[ -z "$cwd_pids" ]] || \
    _die "Processes still have $worktree as their current directory: $(tr '\n' ' ' <<< "$cwd_pids")"

  if [[ -z "$worktree" ]]; then
    echo "  no worktree recorded — skipping"
    echo ""
    continue
  fi

  if [[ ! -d "$worktree" ]]; then
    retry_type="$(sed -n '3p' "$repo_dir/cleanup-phase" 2>/dev/null || true)"
    retry_root="$(sed -n '4p' "$repo_dir/cleanup-phase" 2>/dev/null || true)"
    if [[ -n "$retry_root" ]]; then
      _validate_retry_owner "$repo_dir" "$repo_name" "$worktree" \
        "$retry_type" "$retry_root"
      echo "  retrying interrupted $retry_type removal: $worktree"
      if [[ "$retry_type" == "treehouse" ]]; then
        if ! (cd "$retry_root" && treehouse return "$worktree" 2>&1 | sed 's/^/  /'); then
          _die "Failed to reconcile interrupted treehouse removal: $worktree"
        fi
      elif ! git -C "$retry_root" worktree remove "$worktree" 2>&1 | sed 's/^/  /'; then
        _die "Failed to reconcile interrupted git worktree removal: $worktree"
      fi
      [[ ! -d "$worktree" ]] || \
        _die "Interrupted removal retry left the worktree directory present: $worktree"
      _record_cleanup_phase "$repo_dir" reconciled-absent "$worktree" || \
        _die "Failed to publish reconciled cleanup phase: $repo_name"
      echo ""
      continue
    fi
    echo "  worktree not found or already removed: $worktree"
    echo ""
    continue
  fi

  if [[ "$wt_type" == "treehouse" ]]; then
    git_file="$worktree/.git"
    [[ -f "$git_file" ]] || \
      _die "Cannot identify treehouse lease; fleet state preserved: $worktree"
    git_dir_line="$(cat "$git_file")"
    git_dir="${git_dir_line#gitdir: }"
    main_git="$(dirname "$(dirname "$git_dir")")"
    retry_root="$(dirname "$main_git")"
  else
    repo_base_name="$(basename "$worktree" | sed "s/-sgt-${TASK_ID}$//")"
    retry_root="$(dirname "$worktree")/$repo_base_name"
    [[ -d "$retry_root/.git" ]] || \
      _die "Main repo not found; fleet state preserved: $retry_root"
  fi

  _stage_worker_evidence "$repo_dir" "$worktree"
  if ! _record_cleanup_owner "$repo_dir" "$retry_root" "$worktree" "$wt_type"; then
    _restore_worker_evidence "$repo_dir" "$worktree"
    _die "Failed to record cleanup owner before worktree removal: $TASK_ID/$repo_name"
  fi
  if ! _record_cleanup_phase "$repo_dir" removing "$worktree" \
    "$wt_type" "$retry_root"; then
    _restore_worker_evidence "$repo_dir" "$worktree"
    _die "Failed to record cleanup phase before worktree removal: $repo_name"
  fi
  _remove_worker_evidence "$worktree"

  if [[ "$wt_type" == "treehouse" ]]; then
    echo "  returning treehouse lease: $worktree"
    if ! (cd "$retry_root" && treehouse return "$worktree" 2>&1 | sed 's/^/  /'); then
      if [[ ! -d "$worktree" ]]; then
        _record_cleanup_phase "$repo_dir" partial-removal "$worktree" \
          "$wt_type" "$retry_root" || \
          _die "Failed to record partial treehouse removal: $repo_name"
        _die "Treehouse return failed after worktree removal; retry required: $worktree"
      fi
      _restore_worker_evidence "$repo_dir" "$worktree"
      _die "Failed to return treehouse lease; fleet state preserved: $worktree"
    fi
  else
    echo "  removing git worktree: $worktree"
    if ! git -C "$retry_root" worktree remove "$worktree" 2>&1 | sed 's/^/  /'; then
      if [[ ! -d "$worktree" ]]; then
        _record_cleanup_phase "$repo_dir" partial-removal "$worktree" \
          "$wt_type" "$retry_root" || \
          _die "Failed to record partial git worktree removal: $repo_name"
        _die "Git worktree removal failed after removing the directory; retry required: $worktree"
      fi
      _restore_worker_evidence "$repo_dir" "$worktree"
      _die "Failed to remove git worktree; fleet state preserved: $worktree"
    fi
  fi

  [[ ! -d "$worktree" ]] || {
    _restore_worker_evidence "$repo_dir" "$worktree"
    _die "Worktree removal reported success but the directory remains: $worktree"
  }
  _record_cleanup_phase "$repo_dir" reconciled-absent "$worktree" || \
    _die "Failed to publish reconciled cleanup phase: $repo_name"

  echo ""
done

# Only remove fleet state if cleaning all repos (no FILTER_REPO)
if [[ -z "$FILTER_REPO" ]]; then
  echo "Removing fleet state: $TASK_DIR"

  # ── Wiki: log the cleanup event ─────────────────────────────────────────
  _result="$(cat "$TASK_DIR/"*"/.sergeant-result" 2>/dev/null | head -1 || true)"
  _status="$(cat "$TASK_DIR/"*"/.sergeant-status" 2>/dev/null | head -1 || true)"
  _sgt_wiki_write \
    "sgt-cleanup: $TASK_ID" \
    "activity" \
    "Cleaned up task $TASK_ID (${_status:-unknown})" \
    "sergeant,cleanup,$TASK_ID" \
    "## Cleanup

- **Task ID:** \`$TASK_ID\`
- **Final status:** ${_status:-unknown}
- **Result:** ${_result:-none}"

  rm -rf "$TASK_DIR"
fi

echo "Done."
