#!/usr/bin/env bash
# sgt-cleanup — Remove worktrees and fleet state for a completed task
#
# Handles both treehouse-leased worktrees (treehouse return) and
# plain git worktrees (git worktree remove).
#
# task-id must be the fleet-owned task directory basename. Cleanup rejects
# paths, traversal tokens, and symlink aliases before touching fleet state.
#
# Usage:
#   sgt-cleanup <task-id>           # remove all worktrees + fleet state
#   sgt-cleanup <task-id> <repo>    # remove one repo's worktree only

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_sgt-lib.sh
source "$SCRIPT_DIR/_sgt-lib.sh"
# shellcheck source=bin/_sgt-response-lock.sh
source "$SCRIPT_DIR/_sgt-response-lock.sh"

[[ $# -ge 1 ]] || _die "Usage: sgt-cleanup <task-id> [repo]"
TASK_ID="$1"
FILTER_REPO="${2:-}"

case "$TASK_ID" in
  ""|"."|".."|/*|*/*)
    _die "Invalid task ID: $TASK_ID"
    ;;
esac

TASK_DIR="$FLEET_DIR/$TASK_ID"

[[ ! -L "$TASK_DIR" ]] || _die "Invalid task ID: $TASK_ID"

if [[ ! -d "$TASK_DIR" ]]; then
  echo "Task already cleaned up: $TASK_ID"
  exit 0
fi

FLEET_ROOT="$(cd "$FLEET_DIR" && pwd -P)"
TASK_ROOT="$(cd "$TASK_DIR" && pwd -P)"
[[ "$TASK_ROOT" == "$FLEET_ROOT/$TASK_ID" ]] || _die "Invalid task ID: $TASK_ID"

_worktree_cwd_pids() {
  local worktree="$1"
  local canonical_worktree current_pid error error_file line output path process_pids

  [[ -d "$worktree" ]] || return 0
  canonical_worktree="$(cd "$worktree" && pwd -P)"
  command -v lsof >/dev/null 2>&1 || _die "lsof is required to verify worktree process cleanup"
  process_pids="$(ps -axo pid= | tr -d ' ' || true)"
  [[ -n "$process_pids" ]] || return 0
  error_file="$(mktemp)"
  output="$(lsof -w -S2 -a -d cwd -Fn \
    -p "$(tr '\n' ',' <<< "$process_pids" | sed 's/,$//')" 2> "$error_file" || true)"
  if [[ -s "$error_file" ]]; then
    error="$(cat "$error_file")"
    rm -f "$error_file"
    _die "Failed to inspect process working directories: $error"
  fi
  rm -f "$error_file"
  current_pid=""

  while IFS= read -r line; do
    case "$line" in
      p*)
        current_pid="${line#p}"
        ;;
      n*)
        path="${line#n}"
        if [[ "$path" == "$canonical_worktree" || "$path" == "$canonical_worktree/"* ]]; then
          printf '%s\n' "$current_pid"
        fi
        ;;
    esac
  done <<< "$output"
}

_process_tree_records() {
  local root_pid="$1"
  local child_pid identity

  for child_pid in $(pgrep -P "$root_pid" 2>/dev/null || true); do
    _process_tree_records "$child_pid"
  done
  identity="$(ps -o lstart= -p "$root_pid" 2>/dev/null | sed 's/^ *//;s/ *$//' || true)"
  [[ -n "$identity" ]] && printf '%s|%s\n' "$root_pid" "$identity"
}

_recorded_tree_pids() {
  local records="$1"
  local identity pid

  while IFS='|' read -r pid identity; do
    [[ -n "$pid" ]] && printf '%s\n' "$pid"
  done <<< "$records"
}

_live_recorded_tree_pids() {
  local records="$1"
  local current_identity identity pid

  while IFS='|' read -r pid identity; do
    [[ -n "$pid" && -n "$identity" ]] || continue
    current_identity="$(ps -o lstart= -p "$pid" 2>/dev/null | sed 's/^ *//;s/ *$//' || true)"
    [[ "$current_identity" == "$identity" ]] && printf '%s\n' "$pid"
  done <<< "$records"
}

_terminate_pids() {
  local pids="$1"
  local signal="${2:-TERM}"
  local pid

  [[ -n "$pids" ]] || return 0
  while IFS= read -r pid; do
    [[ -n "$pid" && "$pid" != "$$" ]] || continue
    kill -"$signal" "$pid" 2>/dev/null || true
  done <<< "$pids"
}

_process_group_pids() {
  local process_group="$1"

  [[ -n "$process_group" ]] || return 0
  pgrep -g "$process_group" 2>/dev/null || true
}

_terminate_process_group() {
  local process_group="$1"
  local signal="${2:-TERM}"

  [[ -n "$process_group" ]] || return 0
  kill -"$signal" -- -"$process_group" 2>/dev/null || true
}

_stop_local_worker() {
  local repo_dir="$1"
  local worktree="$2"
  local pane pane_info pane_dead pane_pid pane_pgid tree_records tree_pids live_tree_pids cwd_pids

  pane="$(cat "$repo_dir/pane" 2>/dev/null || true)"
  tree_records=""
  tree_pids=""

  if [[ -n "$pane" ]]; then
    command -v tmux >/dev/null 2>&1 || _die "tmux is required to terminate recorded worker pane $pane"
    pane_info="$(_sgt_pane_identity "$pane" || true)"

    if [[ -n "$pane_info" ]]; then
      pane_dead="${pane_info%%|*}"
      pane_info="${pane_info#*|}"
      pane_info="${pane_info#*|}"
      pane_pid="${pane_info%%|*}"

      if [[ "$pane_dead" != "0" ]]; then
        echo "  worker pane already stopped: $pane"
      elif ! _sgt_pane_identity_matches "$pane" "$repo_dir"; then
        echo "  recorded pane no longer belongs to this worker: $pane"
      else
        tree_records="$(_process_tree_records "$pane_pid")"
        tree_pids="$(_recorded_tree_pids "$tree_records")"
        pane_pgid="$(ps -o pgid= -p "$pane_pid" 2>/dev/null | tr -d ' ' || true)"
        echo "  terminating worker pane: $pane"
        tmux kill-pane -t "$pane" 2>/dev/null || \
          ! tmux display-message -p -t "$pane" '#{pane_id}' >/dev/null 2>&1 || \
          _die "Failed to terminate worker pane $pane"
      fi
    else
      echo "  worker pane already gone: $pane"
    fi
  fi

  _terminate_pids "$tree_pids"
  _terminate_process_group "${pane_pgid:-}"

  for _ in $(seq 1 50); do
    live_tree_pids="$(printf '%s\n%s\n' \
      "$(_process_group_pids "${pane_pgid:-}")" \
      "$(_live_recorded_tree_pids "$tree_records")" | sed '/^$/d' | sort -u)"
    [[ -z "$live_tree_pids" ]] && break
    sleep 0.1
  done

  if [[ -n "$live_tree_pids" ]]; then
    _terminate_process_group "${pane_pgid:-}" KILL
    _terminate_pids "$(_live_recorded_tree_pids "$tree_records")" KILL
    for _ in $(seq 1 20); do
      live_tree_pids="$(printf '%s\n%s\n' \
        "$(_process_group_pids "${pane_pgid:-}")" \
        "$(_live_recorded_tree_pids "$tree_records")" | sed '/^$/d' | sort -u)"
      [[ -z "$live_tree_pids" ]] && break
      sleep 0.1
    done
  fi

  [[ -z "$live_tree_pids" ]] || \
    _die "Worker processes did not terminate: $(tr '\n' ' ' <<< "$live_tree_pids")"
  cwd_pids="$(_worktree_cwd_pids "$worktree")"
  [[ -z "$cwd_pids" ]] || \
    _die "Other processes still have $worktree as their current directory: $(tr '\n' ' ' <<< "$cwd_pids")"
}

_stop_recorded_validation_group() {
  local recorded_pid="$1" recorded_pgid="$2" recorded_start="$3"
  local actual_start actual_pgid live_pids

  if kill -0 "$recorded_pid" 2>/dev/null; then
    actual_start="$(ps -o lstart= -p "$recorded_pid" 2>/dev/null | awk '{$1=$1; print}' || true)"
    [[ "$actual_start" == "$recorded_start" ]] || \
      _die "Validation owner PID was reused; refusing process termination: $recorded_pid"
    actual_pgid="$(ps -o pgid= -p "$recorded_pid" 2>/dev/null | tr -d ' ' || true)"
    [[ "$actual_pgid" == "$recorded_pgid" ]] || \
      _die "Validation owner process group changed; refusing process termination: $recorded_pid"
  else
    live_pids="$(_process_group_pids "$recorded_pgid")"
    [[ -n "$live_pids" ]] || return 0
    [[ "$recorded_pid" == "$recorded_pgid" ]] || \
      _die "Validation pane disappeared with unverified detached descendants in process group $recorded_pgid"
  fi

  _terminate_process_group "$recorded_pgid"
  for _ in $(seq 1 50); do
    live_pids="$(_process_group_pids "$recorded_pgid")"
    [[ -z "$live_pids" ]] && return 0
    sleep 0.1
  done
  _terminate_process_group "$recorded_pgid" KILL
  for _ in $(seq 1 20); do
    live_pids="$(_process_group_pids "$recorded_pgid")"
    [[ -z "$live_pids" ]] && return 0
    sleep 0.1
  done
  _die "Validation processes did not terminate: $(tr '\n' ' ' <<< "$live_pids")"
}

_stop_validation_pane() {
  local repo_dir="$1" pane pane_identity expected_identity pane_info pane_pid pane_pgid
  local tree_records tree_pids live_tree_pids recorded_pid recorded_pgid recorded_start actual_start
  pane="$(cat "$repo_dir/validation_pane" 2>/dev/null || true)"
  [[ -n "$pane" ]] || return 0
  recorded_pid="$(cat "$repo_dir/validation_pane_pid" 2>/dev/null || true)"
  recorded_pgid="$(cat "$repo_dir/validation_process_group" 2>/dev/null || true)"
  recorded_start="$(cat "$repo_dir/validation_process_start" 2>/dev/null || true)"
  [[ -n "$recorded_pid" && -n "$recorded_pgid" && -n "$recorded_start" ]] || \
    _die "Validation pane ownership provenance is incomplete: $pane"
  if ! tmux display-message -p -t "$pane" '#{pane_id}' >/dev/null 2>&1; then
    _stop_recorded_validation_group "$recorded_pid" "$recorded_pgid" "$recorded_start"
    return 0
  fi
  if tmux display-message -p -t "$pane" '#{pane_id}' >/dev/null 2>&1; then
    pane_identity="$(_sgt_pane_identity "$pane")"
    expected_identity="$(_sgt_read_owned_file "$repo_dir/validation_pane_identity" \
      2>/dev/null || true)"
    if [[ "${pane_identity%%|*}" != "0" ]]; then
      if [[ "$pane_identity" == "||||" ]]; then
        _stop_recorded_validation_group "$recorded_pid" "$recorded_pgid" "$recorded_start"
        return 0
      fi
      [[ -n "$expected_identity" && "$pane_identity" == "1|${expected_identity#*|}" ]] || \
        _die "Recorded validation pane identity does not match: $pane (expected $expected_identity, actual $pane_identity)"
      _stop_recorded_validation_group "$recorded_pid" "$recorded_pgid" "$recorded_start"
      tmux kill-pane -t "$pane" 2>/dev/null || true
      return 0
    fi
    _sgt_pane_identity_matches "$pane" "$repo_dir" validation_pane_identity || \
      _die "Recorded validation pane identity does not match: $pane"
    pane_info="${pane_identity#*|}"
    pane_info="${pane_info#*|}"
    pane_pid="${pane_info%%|*}"
    [[ "$pane_pid" == "$recorded_pid" ]] || \
      _die "Validation pane PID does not match recorded ownership: $pane_pid"
    actual_start="$(ps -o lstart= -p "$pane_pid" 2>/dev/null | awk '{$1=$1; print}' || true)"
    [[ "$actual_start" == "$recorded_start" ]] || \
      _die "Validation owner PID was reused; refusing process termination: $recorded_pid"
    tree_records="$(_process_tree_records "$pane_pid")"
    tree_pids="$(_recorded_tree_pids "$tree_records")"
    pane_pgid="$(ps -o pgid= -p "$pane_pid" 2>/dev/null | tr -d ' ' || true)"
    [[ "$pane_pgid" == "$recorded_pgid" ]] || \
      _die "Validation owner process group changed; refusing process termination: $recorded_pid"
    tmux kill-pane -t "$pane" || _die "Failed to terminate validation pane $pane"
    _terminate_pids "$tree_pids"
    _terminate_process_group "$pane_pgid"
    for _ in $(seq 1 50); do
      live_tree_pids="$(printf '%s\n%s\n' \
        "$(_process_group_pids "$pane_pgid")" \
        "$(_live_recorded_tree_pids "$tree_records")" | sed '/^$/d' | sort -u)"
      [[ -z "$live_tree_pids" ]] && break
      sleep 0.1
    done
    if [[ -n "$live_tree_pids" ]]; then
      _terminate_process_group "$pane_pgid" KILL
      _terminate_pids "$(_live_recorded_tree_pids "$tree_records")" KILL
    fi
    for _ in $(seq 1 20); do
      live_tree_pids="$(printf '%s\n%s\n' \
        "$(_process_group_pids "$pane_pgid")" \
        "$(_live_recorded_tree_pids "$tree_records")" | sed '/^$/d' | sort -u)"
      [[ -z "$live_tree_pids" ]] && break
      sleep 0.1
    done
    [[ -z "$live_tree_pids" ]] || \
      _die "Validation processes did not terminate: $(tr '\n' ' ' <<< "$live_tree_pids")"
  fi
}

_response_archive_field() {
  local key="$1" proof_file="$2"
  awk -F= -v key="$key" '
    $1 == key { count++; value = substr($0, length(key) + 2) }
    END { if (count == 1 && value != "") print value; else exit 1 }
  ' "$proof_file"
}

_require_response_cleanup_safe() {
  local repo_dir="$1" worktree="$2"
  local applied_status archive response_generation response_id response_proof_root

  response_proof_root="$worktree"
  [[ -n "$response_proof_root" && -d "$response_proof_root" ]] || \
    response_proof_root="$repo_dir/terminal-evidence"

  if [[ -e "$repo_dir/response" || -L "$repo_dir/response" ||
        -e "$response_proof_root/.sergeant-response" || -L "$response_proof_root/.sergeant-response" ||
        -e "$response_proof_root/.sergeant-response-id" || -L "$response_proof_root/.sergeant-response-id" ||
        -e "$response_proof_root/.sergeant-response-generation" || -L "$response_proof_root/.sergeant-response-generation" ||
        -e "$response_proof_root/.sergeant-response-applied" || -L "$response_proof_root/.sergeant-response-applied" ]]; then
    _die "$(basename "$repo_dir") has pending or incomplete response acknowledgement"
  fi

  if [[ ! -e "$repo_dir/response_id" && ! -L "$repo_dir/response_id" &&
        ! -e "$repo_dir/response_generation" && ! -L "$repo_dir/response_generation" &&
        ! -e "$repo_dir/response_ack" && ! -L "$repo_dir/response_ack" &&
        ! -e "$repo_dir/response-archive" && ! -L "$repo_dir/response-archive" &&
        ! -e "$response_proof_root/.sergeant-response-ack" && ! -L "$response_proof_root/.sergeant-response-ack" ]]; then
    return 0
  fi

  response_id="$(cat "$repo_dir/response_id" 2>/dev/null || true)"
  response_generation="$(cat "$repo_dir/response_generation" 2>/dev/null || true)"
  archive="$repo_dir/response-archive/$response_id"
  [[ "$response_id" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ &&
     "$response_generation" =~ ^[1-9][0-9]*$ &&
     "$(cat "$repo_dir/response_ack" 2>/dev/null || true)" == "$response_id" &&
     "$(cat "$response_proof_root/.sergeant-response-ack" 2>/dev/null || true)" == "$response_id" &&
     -d "$archive" && ! -L "$archive" ]] || \
    _die "$(basename "$repo_dir") has pending or incomplete response acknowledgement"
  for archive_file in body gate_generation applied_status proof; do
    [[ -f "$archive/$archive_file" && ! -L "$archive/$archive_file" ]] || \
      _die "$(basename "$repo_dir") has pending or incomplete response acknowledgement"
  done
  applied_status="$(cat "$archive/applied_status")"
  [[ "$(cat "$archive/gate_generation")" == "$response_generation" &&
     "$(_response_archive_field response_id "$archive/proof" 2>/dev/null || true)" == "$response_id" &&
     "$(_response_archive_field gate_generation "$archive/proof" 2>/dev/null || true)" == "$response_generation" &&
     "$(_response_archive_field status "$archive/proof" 2>/dev/null || true)" == "$applied_status" ]] || \
    _die "$(basename "$repo_dir") has pending or incomplete response acknowledgement"
}

_require_terminal_repos() {
  local cleanup_phase evidence_dir repo_dir repo_name status worktree worktree_status

  for repo_dir in "$TASK_DIR"/*/; do
    [[ -d "$repo_dir" ]] || continue
    repo_dir="${repo_dir%/}"
    repo_name="$(basename "$repo_dir")"
    if [[ -n "$FILTER_REPO" && "$repo_name" != "$FILTER_REPO" ]]; then
      continue
    fi

    status="$(tr -d '\n' < "$repo_dir/status" 2>/dev/null || echo unknown)"
    case "$status" in
      done)
        [[ -s "$repo_dir/result" ]] || \
          _die "$repo_name is not safely terminal: done requires a reconciled result"
        ;;
      failed:\ *[![:space:]]) ;;
      *) _die "$repo_name is not terminal: $status" ;;
    esac

    worktree="$(cat "$repo_dir/worktree" 2>/dev/null || true)"
    _require_response_cleanup_safe "$repo_dir" "$worktree"
    cleanup_phase="$(cat "$repo_dir/cleanup-phase" 2>/dev/null || true)"
    if [[ -n "$worktree" && -d "$worktree" ]]; then
      if [[ "$cleanup_phase" == $'removing\n'"$worktree" ]]; then
        _restore_worker_evidence "$repo_dir" "$worktree" || \
          _die "$repo_name: evidence restore failed during removing-state replay; replay aborted"
      fi
      [[ -f "$worktree/.sergeant-status" ]] || \
        _die "$repo_name worktree terminal proof is missing"
      worktree_status="$(tr -d '\n' < "$worktree/.sergeant-status")"
      [[ "$worktree_status" == "$status" ]] || \
        _die "$repo_name is not reconciled: fleet status $status differs from worktree status $worktree_status"
      if [[ "$status" == "done" ]]; then
        [[ -s "$worktree/.sergeant-result" ]] || \
          _die "$repo_name worktree is not safely terminal: done requires a result"
        cmp -s "$repo_dir/result" "$worktree/.sergeant-result" || \
          _die "$repo_name worktree result differs from reconciled fleet result"
      fi
    else
      # Worktree is absent or was never recorded.
      if [[ -z "$worktree" ]]; then
        # No worktree was ever assigned -- skip terminal-evidence checks.
        continue
      fi

      # Worktree recorded but now absent. If no cleanup-phase exists the worktree
      # was externally removed before sgt-cleanup ran. Synthesize terminal evidence
      # from fleet state so absent-worktree replay is idempotent.
      if [[ -z "$cleanup_phase" ]]; then
        evidence_dir="$repo_dir/terminal-evidence"
        if [[ ! -f "$evidence_dir/.sergeant-status" ]]; then
          mkdir -p "$evidence_dir"
          cp -p "$repo_dir/status" "$evidence_dir/.sergeant-status" ||\
            _die "$repo_name cannot synthesize terminal evidence: fleet status missing"
          [[ ! -f "$repo_dir/result" ]] ||
            cp -p "$repo_dir/result" "$evidence_dir/.sergeant-result" 2>/dev/null || true
        fi
        _record_cleanup_phase "$repo_dir" reconciled-absent "$worktree" ||\
          _die "$repo_name failed to record reconciled-absent for externally removed worktree"
        cleanup_phase=$'reconciled-absent\n'"$worktree"
      fi

      [[ "$cleanup_phase" == $'removing\n'"$worktree" ||
         "$cleanup_phase" == $'reconciled-absent\n'"$worktree" ]] ||
        _die "$repo_name has no reconciled cleanup phase for its absent worktree"

      evidence_dir="$repo_dir/terminal-evidence"
      [[ -f "$evidence_dir/.sergeant-status" ]] ||
        _die "$repo_name reconciled cleanup evidence is missing"
      worktree_status="$(tr -d '\n' < "$evidence_dir/.sergeant-status")"
      [[ "$worktree_status" == "$status" ]] ||
        _die "$repo_name cleanup evidence differs from reconciled fleet status"
      if [[ "$status" == "done" ]]; then
        [[ -s "$evidence_dir/.sergeant-result" ]] ||
          _die "$repo_name reconciled cleanup evidence requires a result"
        cmp -s "$repo_dir/result" "$evidence_dir/.sergeant-result" ||
          _die "$repo_name cleanup evidence differs from reconciled fleet result"
      fi
      if [[ "$cleanup_phase" == $'removing\n'"$worktree" ]]; then
        _record_cleanup_phase "$repo_dir" reconciled-absent "$worktree" ||
          _die "Failed to reconcile completed worktree removal: $repo_name"
      fi
    fi
  done
}

_require_clean_worktrees() {
  local changes repo_dir repo_name worktree

  for repo_dir in "$TASK_DIR"/*/; do
    [[ -d "$repo_dir" ]] || continue
    repo_dir="${repo_dir%/}"
    repo_name="$(basename "$repo_dir")"
    if [[ -n "$FILTER_REPO" && "$repo_name" != "$FILTER_REPO" ]]; then
      continue
    fi

    worktree="$(cat "$repo_dir/worktree" 2>/dev/null || true)"
    [[ -n "$worktree" && -d "$worktree" ]] || continue
    git -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1 || \
      _die "Cannot verify $repo_name worktree before cleanup: $worktree"
    changes="$(git -C "$worktree" status --porcelain --untracked-files=all -- \
      . ':(exclude).sergeant-*')" || \
      _die "Cannot inspect $repo_name worktree before cleanup: $worktree"
    [[ -z "$changes" ]] || \
      _die "$repo_name worktree has uncommitted changes; cleanup refused"
  done
}

_stage_worker_evidence() {
  local evidence evidence_dir repo_dir="$1" worktree="$2"

  evidence_dir="$repo_dir/terminal-evidence"
  for evidence in "$worktree"/.sergeant-*; do
    [[ -f "$evidence" ]] || continue
    mkdir -p "$evidence_dir"
    cp -p "$evidence" "$evidence_dir/" || \
      _die "Failed to preserve worker evidence before cleanup: $evidence"
  done
}

_remove_worker_evidence() {
  local evidence worktree="$1"

  for evidence in "$worktree"/.sergeant-*; do
    [[ -f "$evidence" ]] || continue
    rm -f "$evidence" || \
      _die "Failed to remove staged worker evidence before cleanup: $evidence"
  done
}

_restore_worker_evidence() {
  local evidence evidence_dir="$1/terminal-evidence" worktree="$2"

  [[ -d "$worktree" && -d "$evidence_dir" ]] || return 0
  for evidence in "$evidence_dir"/.sergeant-*; do
    [[ -f "$evidence" ]] || continue
    cp -p "$evidence" "$worktree/" || \
      _die "Failed to restore worker evidence after cleanup failure: $evidence"
  done
}

_record_cleanup_phase() {
  local repo_dir="$1" phase="$2" worktree="$3"

  printf '%s\n%s\n' "$phase" "$worktree" > "$repo_dir/cleanup-phase.tmp" &&
    mv "$repo_dir/cleanup-phase.tmp" "$repo_dir/cleanup-phase"
}

_validation_object_identity() {
  [[ -e "$1" && ! -L "$1" ]] || return 1
  stat -c '%d:%i:%w' -- "$1" 2>/dev/null || stat -f '%d:%i:%B' "$1" 2>/dev/null
}

_validation_path_identity() {
  local identity
  identity="$(_validation_object_identity "$1")" || return 1
  if [[ -f "$1" ]]; then
    printf '%s:%s\n' "$identity" "$(cksum < "$1")"
  else
    printf '%s\n' "$identity"
  fi
}

_validation_checkout_matches() {
  local checkout="$1" expected_path="$2" expected_identity="$3" expected_git_dir="$4"
  local expected_git_identity="$5" expected_head="$6" expected_owner="$7"
  local git_dir owner_file
  [[ -d "$checkout" && ! -L "$checkout" ]] || return 1
  [[ "$(_validation_path_identity "$checkout" || true)" == "$expected_identity" ]] || return 1
  git_dir="$(git -C "$checkout" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || \
    return 1
  if [[ -n "$expected_path" ]]; then
    [[ "$git_dir" == "$expected_git_dir" ]] || return 1
  fi
  [[ "$(_validation_path_identity "$git_dir" || true)" == "$expected_git_identity" ]] || return 1
  [[ "$(git -C "$checkout" rev-parse HEAD 2>/dev/null || true)" == "$expected_head" ]] || \
    return 1
  owner_file="$git_dir/sergeant-validation-owner"
  [[ -f "$owner_file" && ! -L "$owner_file" && "$(cat "$owner_file")" == \
    "$expected_owner" ]] || return 1
}
_validation_checkout_provenance_mode() {
  local repo_dir="$1" head="$2" present=0 path
  for path in "$repo_dir/validation_worktree_identity" "$repo_dir/validation_worktree_git_dir" \
    "$repo_dir/validation_worktree_git_identity" "$repo_dir/validation_worktree_owner"; do
    [[ -e "$path" || -L "$path" ]] && present=$((present + 1))
  done
  if [[ "$present" -eq 4 ]]; then
    printf 'exact\n'
  elif [[ "$present" -eq 0 && -n "$head" ]]; then
    printf 'legacy\n'
  else
    printf 'invalid\n'
  fi
}
_validation_legacy_checkout_matches() {
  local checkout="$1" expected_path="$2" expected_head="$3"
  [[ -d "$checkout" && ! -L "$checkout" ]] || return 1
  [[ -z "$expected_path" || "$checkout" == "$expected_path" ]] || return 1
  git -C "$checkout" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 1
  [[ -n "$expected_head" && "$(git -C "$checkout" rev-parse HEAD 2>/dev/null || true)" == \
    "$expected_head" ]]
}

_require_terminal_repos
_require_clean_worktrees

echo "=== sgt-cleanup: $TASK_ID ==="
echo ""

for repo_dir in "$TASK_DIR"/*/; do
  [[ -d "$repo_dir" ]] || continue
  repo_dir="${repo_dir%/}"
  repo_name="$(basename "$repo_dir")"

  if [[ -n "$FILTER_REPO" && "$repo_name" != "$FILTER_REPO" ]]; then
    continue
  fi

  worktree="$(cat "$repo_dir/worktree" 2>/dev/null || echo "")"
  status="$(cat "$repo_dir/status" 2>/dev/null || echo "unknown")"
  wt_type="$(cat "$repo_dir/wt_type" 2>/dev/null || echo "git")"

  _sgt_response_lock_acquire "$repo_dir"
  trap '_sgt_response_lock_release' EXIT
  _require_response_cleanup_safe "$repo_dir" "$worktree"

  echo "--- $repo_name (status: $status, type: $wt_type) ---"

  _stop_validation_pane "$repo_dir"
  _stop_local_worker "$repo_dir" "$worktree"

  validation_worktree="$(cat "$repo_dir/validation_worktree" 2>/dev/null || true)"
  if [[ -n "$validation_worktree" && ( -e "$validation_worktree" || -L "$validation_worktree" ) ]]; then
    [[ "$validation_worktree" == "${worktree}-validation-${TASK_ID}" ]] || \
      _die "Validation worktree path is outside the recorded ownership boundary: $validation_worktree"
    validation_head="$(cat "$repo_dir/validation_head" 2>/dev/null || true)"
    validation_mode="$(_validation_checkout_provenance_mode "$repo_dir" "$validation_head")"
    case "$validation_mode" in
      exact)
        validation_identity="$(cat "$repo_dir/validation_worktree_identity" 2>/dev/null || true)"
        validation_git_dir="$(cat "$repo_dir/validation_worktree_git_dir" 2>/dev/null || true)"
        validation_git_identity="$(cat "$repo_dir/validation_worktree_git_identity" 2>/dev/null || true)"
        validation_owner="$(cat "$repo_dir/validation_worktree_owner" 2>/dev/null || true)"
        [[ -n "$validation_identity" && -n "$validation_git_dir" && \
          -n "$validation_git_identity" && -n "$validation_head" && -n "$validation_owner" ]] || \
          _die "Validation checkout ownership provenance is incomplete: $validation_worktree"
        [[ "$validation_owner" == "$TASK_ID/$repo_name/validation-launch|"*"|$validation_head" ]] || \
          _die "Validation checkout owner provenance does not match: $validation_worktree"
        _validation_checkout_matches "$validation_worktree" "$validation_worktree" \
          "$validation_identity" "$validation_git_dir" "$validation_git_identity" \
          "$validation_head" "$validation_owner" || \
          _die "Validation checkout identity does not match recorded ownership: $validation_worktree"
        ;;
      legacy)
        _validation_legacy_checkout_matches "$validation_worktree" "$validation_worktree" \
          "$validation_head" || \
          _die "Validation checkout does not match retry-safe legacy state: $validation_worktree"
        ;;
      *)
        _die "Validation checkout ownership provenance is incomplete: $validation_worktree"
        ;;
    esac
    validation_cwd_pids="$(_worktree_cwd_pids "$validation_worktree")"
    [[ -z "$validation_cwd_pids" ]] || \
      _die "Processes still have $validation_worktree as their current directory: $(tr '\n' ' ' <<< "$validation_cwd_pids")"
    validation_quarantine="${validation_worktree}.cleanup.$$.$RANDOM"
    [[ ! -e "$validation_quarantine" && ! -L "$validation_quarantine" ]] || \
      _die "Validation cleanup quarantine already exists: $validation_quarantine"
    mv "$validation_worktree" "$validation_quarantine" || \
      _die "Failed to stage validation checkout cleanup: $validation_worktree"
    case "$validation_mode" in
      exact)
        if ! _validation_checkout_matches "$validation_quarantine" "" "$validation_identity" \
          "$validation_git_dir" "$validation_git_identity" "$validation_head" "$validation_owner"; then
          if [[ ! -e "$validation_worktree" && ! -L "$validation_worktree" ]]; then
            mv "$validation_quarantine" "$validation_worktree" 2>/dev/null || true
          fi
          _die "Validation checkout changed during cleanup and was preserved: $validation_worktree"
        fi
        ;;
      legacy)
        if ! _validation_legacy_checkout_matches "$validation_quarantine" "" \
          "$validation_head"; then
          if [[ ! -e "$validation_worktree" && ! -L "$validation_worktree" ]]; then
            mv "$validation_quarantine" "$validation_worktree" 2>/dev/null || true
          fi
          _die "Validation checkout changed during cleanup and was preserved: $validation_worktree"
        fi
        ;;
    esac
    rm -rf "$validation_quarantine"
  fi

  cwd_pids="$(_worktree_cwd_pids "$worktree")"
  [[ -z "$cwd_pids" ]] || \
    _die "Processes still have $worktree as their current directory: $(tr '\n' ' ' <<< "$cwd_pids")"

  if [[ -z "$worktree" ]]; then
    echo "  no worktree recorded — skipping"
    echo ""
    _sgt_response_lock_release
    trap - EXIT
    continue
  fi

  if [[ ! -d "$worktree" ]]; then
    echo "  worktree not found or already removed: $worktree"
    # Record reconciled-absent so future replays are idempotent.
    _record_cleanup_phase "$repo_dir" reconciled-absent "$worktree" 2>/dev/null || true
    echo ""
    _sgt_response_lock_release
    trap - EXIT
    continue
  fi

  _stage_worker_evidence "$repo_dir" "$worktree"
  if ! _record_cleanup_phase "$repo_dir" removing "$worktree"; then
    _restore_worker_evidence "$repo_dir" "$worktree" || true
    _die "Failed to record cleanup phase before worktree removal: $repo_name"
  fi
  _remove_worker_evidence "$worktree"

  if [[ "$wt_type" == "treehouse" ]]; then
    # Find the main repo path to run treehouse return from
    # Worktree is inside ~/.treehouse/<slug>/<n>/<repo-name>
    # We need to run treehouse return from the main repo that owns the pool
    #
    # Strategy: find the main repo by looking at the .git file inside the worktree
    git_file="$worktree/.git"
    if [[ -f "$git_file" ]]; then
      # .git file contains: gitdir: /path/to/main/.git/worktrees/<name>
      git_dir_line="$(cat "$git_file")"
      git_dir="${git_dir_line#gitdir: }"
      # main repo .git is two levels up from .git/worktrees/<name>
      main_git="$(dirname "$(dirname "$git_dir")")"
      main_repo="$(dirname "$main_git")"
      echo "  returning treehouse lease: $worktree"
      if ! (cd "$main_repo" && treehouse return "$worktree" 2>&1 | sed 's/^/  /'); then
        _restore_worker_evidence "$repo_dir" "$worktree" || true
        _die "Failed to return treehouse lease; fleet state preserved: $worktree"
      fi
    else
      _restore_worker_evidence "$repo_dir" "$worktree" || true
      _die "Cannot identify treehouse lease; fleet state preserved: $worktree"
    fi
  else
    # Plain git worktree — find main repo as sibling (name before -sgt- suffix)
    repo_base_name="$(basename "$worktree" | sed "s/-sgt-${TASK_ID}$//")"
    repo_base="$(dirname "$worktree")/$repo_base_name"

    if [[ -d "$repo_base/.git" ]]; then
      echo "  removing git worktree: $worktree"
      if ! git -C "$repo_base" worktree remove "$worktree" 2>&1 | sed 's/^/  /'; then
        _restore_worker_evidence "$repo_dir" "$worktree" || true
        _die "Failed to remove git worktree; fleet state preserved: $worktree"
      fi
    else
      _restore_worker_evidence "$repo_dir" "$worktree" || true
      _die "Main repo not found; fleet state preserved: $repo_base"
    fi
  fi

  [[ ! -d "$worktree" ]] || {
    _restore_worker_evidence "$repo_dir" "$worktree" || true
    _die "Worktree removal reported success but the directory remains: $worktree"
  }
  _record_cleanup_phase "$repo_dir" reconciled-absent "$worktree" || \
    _die "Failed to publish reconciled cleanup phase: $repo_name"

  echo ""
  _sgt_response_lock_release
  trap - EXIT
done

# Only remove fleet state if cleaning all repos (no FILTER_REPO)
if [[ -z "$FILTER_REPO" ]]; then
  echo "Removing fleet state: $TASK_DIR"

  # ── Wiki: log the cleanup event ─────────────────────────────────────────
  _result="$(cat "$TASK_DIR/"*"/.sergeant-result" 2>/dev/null | head -1 || true)"
  _status="$(cat "$TASK_DIR/"*"/.sergeant-status" 2>/dev/null | head -1 || true)"
  _sgt_wiki_write \
    "sgt-cleanup: $TASK_ID" \
    "activity" \
    "Cleaned up task $TASK_ID (${_status:-unknown})" \
    "sergeant,cleanup,$TASK_ID" \
    "## Cleanup

- **Task ID:** \`$TASK_ID\`
- **Final status:** ${_status:-unknown}
- **Result:** ${_result:-none}"

  rm -rf "$TASK_DIR"
fi

echo "Done."
