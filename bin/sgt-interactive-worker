#!/usr/bin/env bash
# sgt-interactive-worker - Own one persistent interactive agent pane.

set -uo pipefail

[[ $# -eq 3 ]] || {
  echo "Usage: sgt-interactive-worker <repo-state-dir> <worktree> <agent>" >&2
  exit 2
}

REPO_STATE="$1"
WORKTREE="$2"
AGENT="$3"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_sgt-lib.sh
source "$SCRIPT_DIR/_sgt-lib.sh"

[[ -d "$WORKTREE" ]] || {
  echo "ERROR: worktree unavailable: $WORKTREE" >&2
  exit 2
}
[[ -t 0 && -t 1 ]] || {
  echo "ERROR: interactive worker requires a terminal" >&2
  exit 2
}
harness="$(basename "$AGENT")"
case "$harness" in
  opencode|oc|goose|claude) ;;
  *)
    echo "ERROR: unsupported interactive agent: $AGENT" >&2
    exit 2
    ;;
esac

mkdir -p "$REPO_STATE"

_status() {
  tr -d '\n' < "$WORKTREE/.sergeant-status" 2>/dev/null || echo "in_progress"
}

_sync_state() {
  local status
  status="$(_status)"
  printf '%s\n' "$status" > "$REPO_STATE/status"
  if [[ "$status" == "done" && -s "$WORKTREE/.sergeant-result" ]]; then
    cp "$WORKTREE/.sergeant-result" "$REPO_STATE/result"
  else
    rm -f "$REPO_STATE/result"
  fi
}

_finish() {
  local exit_code="$1" status
  trap - EXIT
  [[ -z "${notification_pid:-}" ]] || kill "$notification_pid" 2>/dev/null || true
  status="$(_status)"
  case "$status" in
    done)
      if [[ ! -s "$WORKTREE/.sergeant-result" ]]; then
        status="orphaned"
      fi
      ;;
    needs_input|blocked)
      _sync_state
      rm -f "$REPO_STATE/diagnostic"
      "$SCRIPT_DIR/sgt-td-memory" handoff "$REPO_STATE" "$WORKTREE" || true
      exit "$exit_code"
      ;;
    failed:*) ;;
    *) status="orphaned" ;;
  esac
  if [[ "$status" == "orphaned" ]]; then
    printf 'orphaned\n' > "$WORKTREE/.sergeant-status"
    printf 'orphaned\n' > "$REPO_STATE/status"
    {
      printf 'reason: interactive %s session exited before terminal completion\n' "$harness"
      printf 'exit code: %s\n' "$exit_code"
    } > "$REPO_STATE/diagnostic"
    "$SCRIPT_DIR/sgt-td-memory" handoff "$REPO_STATE" "$WORKTREE" || true
  else
    _sync_state
    rm -f "$REPO_STATE/diagnostic"
  fi
  exit "$exit_code"
}

_deliver_notifications() {
  local notification_file="$WORKTREE/.sergeant-notification"
  local notification_id expected_id acknowledged delivered delivered_identity pane_identity state_dir pending target_identity
  while :; do
    notification_id="$(sed -n 's/^notification_id=//p' "$notification_file" 2>/dev/null || true)"
    expected_id="$(cat "$REPO_STATE/notification_id" 2>/dev/null || true)"
    acknowledged="$(cat "$WORKTREE/.sergeant-notification-ack" 2>/dev/null || true)"
    delivered="$(cat "$REPO_STATE/notification_delivered" 2>/dev/null || true)"
    delivered_identity="$(cat "$REPO_STATE/notification_delivered_pane_identity" 2>/dev/null || true)"
    pane_identity="$(_sgt_pane_identity "${TMUX_PANE:-}")" || pane_identity=""
    target_identity="$(cat "$REPO_STATE/notification_target_pane_identity" 2>/dev/null || true)"
    if [[ -n "$notification_id" && "$notification_id" == "$expected_id" &&
          -n "$pane_identity" && "$target_identity" == "$pane_identity" &&
          ( "$delivered" != "$notification_id" || "$delivered_identity" != "$pane_identity" ) ]]; then
      if [[ "$acknowledged" == "$notification_id" && "$delivered" == "$notification_id" &&
            "$delivered_identity" != "$pane_identity" ]]; then
        rm -f "$WORKTREE/.sergeant-notification-ack"
        acknowledged=""
      fi
      if [[ "$acknowledged" == "$notification_id" ]]; then
        state_dir="$REPO_STATE/notifications/$notification_id"
        mkdir -p "$state_dir" || {
          sleep "${SGT_NOTIFICATION_RETRY_INTERVAL:-1}"
          continue
        }
        pending="$state_dir/acknowledged.tmp.$$"
        printf '%s\n' "$notification_id" > "$pending"
        if ! mv "$pending" "$state_dir/acknowledged"; then
          rm -f "$pending"
          sleep "${SGT_NOTIFICATION_RETRY_INTERVAL:-1}"
          continue
        fi
        pending="$state_dir/delivered.tmp.$$"
        printf '%s\n' "$notification_id" > "$pending"
        if ! mv "$pending" "$state_dir/delivered"; then
          rm -f "$pending"
          sleep "${SGT_NOTIFICATION_RETRY_INTERVAL:-1}"
          continue
        fi
        pending="$REPO_STATE/notification_delivered_pane_identity.tmp.$$"
        printf '%s\n' "$pane_identity" > "$pending"
        if ! mv "$pending" "$REPO_STATE/notification_delivered_pane_identity"; then
          rm -f "$pending"
          sleep "${SGT_NOTIFICATION_RETRY_INTERVAL:-1}"
          continue
        fi
        pending="$REPO_STATE/notification_delivered.tmp.$$"
        printf '%s\n' "$notification_id" > "$pending"
        if ! mv "$pending" "$REPO_STATE/notification_delivered"; then
          rm -f "$pending"
        fi
      elif [[ -n "${TMUX_PANE:-}" ]]; then
        tmux send-keys -t "$TMUX_PANE" -l -- \
          "Sergeant notification $notification_id is available in .sergeant-notification. Read it, write $notification_id to .sergeant-notification-ack before acting, then follow it once." 2>/dev/null || true
        tmux send-keys -t "$TMUX_PANE" Enter 2>/dev/null || true
      fi
    fi
    sleep "${SGT_NOTIFICATION_RETRY_INTERVAL:-1}"
  done
}

[[ -f "$WORKTREE/.sergeant-status" ]] || printf 'in_progress\n' > "$WORKTREE/.sergeant-status"
_sync_state
printf 'interactive\n' > "$REPO_STATE/worker_mode"
trap '_finish $?' EXIT

cd "$WORKTREE" || exit 2
_deliver_notifications &
notification_pid=$!
case "$harness" in
  goose) "$AGENT" session ;;
  opencode|oc) "$AGENT" --dangerously-skip-permissions ;;
  *) "$AGENT" ;;
esac
